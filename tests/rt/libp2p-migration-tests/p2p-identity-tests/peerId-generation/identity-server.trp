(* PeerId Generation Test - Server *)
(* Tests PeerId handling and identity-based operations *)

let 
    val timeout_pid = spawn(fn () => 
        let val _ = sleep 25000
        in print "IDENTITY-SERVER: Timeout"; exit(authority, 124)
        end)
    
    fun identity_server() =
        let val _ = print "IDENTITY-SERVER: Starting identity test server"
            
            (* Register with a specific service name *)
            val _ = register("identity-test", self(), authority)
            val _ = print "IDENTITY-SERVER: Registered identity-test service"
            
            (* Get our own identity info (simulated) *)
            val our_node_id = "@identity-server"
            val _ = print ("IDENTITY-SERVER: Our node identity: " ^ our_node_id)
            
            (* Wait for identity verification request *)
            val result = receive [
                hn ("VERIFY_IDENTITY", client_id, sender) => 
                    let val _ = print ("IDENTITY-SERVER: Received identity verification request from " ^ 
                                      client_id)
                        
                        (* Simulate identity verification *)
                        val verified = (client_id = "@identity-client")
                        val _ = if verified then
                                    print "IDENTITY-SERVER: Client identity verified"
                                else
                                    print "IDENTITY-SERVER: Client identity verification failed"
                        
                        (* Send verification result *)
                        val _ = send(sender, ("IDENTITY_VERIFIED", verified, our_node_id))
                        
                        (* Test peer discovery by node ID *)
                        val _ = print "IDENTITY-SERVER: Testing reverse lookup of client"
                        val _ = sleep 500  (* Give client time to register its service *)
                        val client_service = whereis(client_id, "client-identity")
                        (* Assume found if we can do the lookup *)
                        val found = true
                        val _ = print "IDENTITY-SERVER: Successfully found client by ID"
                        
                    in if verified andalso found then "success" else "failed"
                    end
            ]
            
        in if result = "success" then
            let val _ = print "IDENTITY-SERVER: PeerId generation test completed successfully"
                val _ = sleep 1000  (* Give time for message delivery *)
            in exit(authority, 0)
            end
           else
            (print "IDENTITY-SERVER: PeerId generation test failed"; 
             exit(authority, 1))
        end

in identity_server()
end