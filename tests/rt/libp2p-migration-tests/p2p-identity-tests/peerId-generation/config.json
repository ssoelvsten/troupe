{
  "test_name": "p2p-peerId-generation",
  "timeout": 30,
  "coordination": "parallel",
  "network": {
    "use_relay": false,
    "bootstrap_peers": []
  },
  "nodes": [
    {
      "id": "identity-server",
      "script": "identity-server.trp",
      "port": 6793,
      "expected_exit_code": 0,
      "extra_argv": "--debug-p2p"
    },
    {
      "id": "identity-client",
      "script": "identity-client.trp", 
      "port": 6794,
      "start_delay": 2,
      "expected_exit_code": 0,
      "extra_argv": "--debug-p2p"
    }
  ],
  "output": {
    "merge_strategy": "timestamp",
    "filter_patterns": ["uuid", "timestamp"]
  }
}