{
  "test_name": "p2p-whereis-blocking",
  "timeout": 45,
  "coordination": "parallel",
  "network": {
    "use_relay": false,
    "bootstrap_peers": []
  },
  "nodes": [
    {
      "id": "delayed-server",
      "script": "delayed-server.trp",
      "port": 6791,
      "start_delay": 10,
      "expected_exit_code": 0,
      "extra_argv": "--debug-p2p"
    },
    {
      "id": "retry-client",
      "script": "retry-client.trp", 
      "port": 6792,
      "start_delay": 0,
      "expected_exit_code": 0,
      "extra_argv": "--debug-p2p"
    }
  ],
  "output": {
    "merge_strategy": "timestamp",
    "filter_patterns": ["uuid", "timestamp", "peer_id"]
  }
}