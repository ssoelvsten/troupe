(* Whereis Blocking Test - Delayed Server *)
(* This server starts late to test whereis blocking behavior *)

let 
    val timeout_pid = spawn(fn () => 
        let val _ = sleep 30000
        in print "DELAYED-SERVER: Timeout"; exit(authority, 124)
        end)
    
    fun delayed_server() =
        let val _ = print "DELAYED-SERVER: Starting after delay"
            (* Register service *)
            val _ = register("retry-test", self(), authority)
            val _ = print "DELAYED-SERVER: Registered retry-test service"
            
            (* Wait for client connection attempts *)
            val result = receive [
                hn ("RETRY_TEST", attempt_num, sender) => 
                    let val _ = print ("DELAYED-SERVER: Received connection from client, attempt #" ^ 
                                      intToString(attempt_num))
                        (* Send success response *)
                        val _ = send(sender, ("RETRY_SUCCESS", attempt_num))
                        val _ = print "DELAYED-SERVER: Sent success response"
                    in "success"
                    end
            ]
            
        in if result = "success" then
            let val _ = print "DELAYED-SERVER: Connection retry test completed successfully"
                val _ = sleep 1000  (* Give time for message delivery *)
            in exit(authority, 0)
            end
           else
            (print "DELAYED-SERVER: Connection retry test failed"; 
             exit(authority, 1))
        end

in delayed_server()
end