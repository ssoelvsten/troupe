(* P2P Test Utilities *)
(* Shared helper functions for libp2p migration tests *)

let
    (* Measure time taken for an operation *)
    fun measureTime(operation) =
        let val start = getTime()
            val result = operation()
            val elapsed = getTime() - start
        in (result, elapsed)
        end
    
    (* Measure connection establishment time *)
    fun measureConnectionTime(target, service) =
        measureTime(fn () => whereis(target, service))
    
    (* Test P2P connection - note that whereis blocks FOREVER with no timeout *)
    fun testConnection(target, service) =
        whereis(target, service)
    
    (* Safe whereis with timeout - prevents hanging forever *)
    fun whereisWithTimeout(node, service, timeoutMs) =
        let val parent = self()
            
            val whereis_pid = spawn(fn () =>
                let val pid = whereis(node, service)
                in send(parent, ("WHEREIS_RESULT", pid))
                end)
            
            val timeout_proc = spawn(fn () =>
                let val _ = sleep timeoutMs
                in send(parent, ("WHEREIS_TIMEOUT", ()))
                end)
            
            val result = receive [
                hn ("WHEREIS_RESULT", pid) => ("found", pid),
                hn ("WHEREIS_TIMEOUT", ()) => ("timeout", parent)  (* return parent as dummy *)
            ]
        in result
        end
    
    (* Send message and wait for response with timeout *)
    fun sendAndReceiveWithTimeout(target, message, timeoutMs) =
        let val timeout_pid = spawn(fn () =>
                let val _ = sleep timeoutMs
                in send(self(), ("TIMEOUT", "Operation timed out"))
                end)
            
            val _ = send(target, message)
            
            val result = receive [
                hn ("TIMEOUT", msg) => ("timeout", msg),
                hn (tag, data) => (tag, data)
            ]
        in result
        end
    
    (* Test bidirectional communication *)
    fun testBidirectionalComm(remote, testId) =
        let (* Send ping *)
            val _ = send(remote, ("PING", testId, self()))
            
            (* Wait for pong *)
            val pongResult = receive [
                hn ("PONG", id) => 
                    if id = testId then "success" else "id_mismatch"
            ]
        in pongResult = "success"
        end
    
    (* Spawn remote process and verify it's running *)
    fun spawnAndVerify(node, processFunc) =
        let val pid = spawn(node, processFunc)
            val _ = sleep 500  (* Give process time to start *)
            
            (* Send test message to verify process is alive *)
            val _ = send(pid, ("HEALTH_CHECK", self()))
            
            val result = receive [
                hn ("HEALTH_OK", sender) => 
                    if sender = pid then "verified" else "wrong_sender"
            ]
        in (pid, result = "verified")
        end
    
    (* Log with test prefix *)
    fun testLog(testName, message) =
        print(testName ^ ": " ^ message)
    
    (* Create a test timeout process *)
    fun createTestTimeout(timeoutMs, testName) =
        spawn(fn () =>
            let val _ = sleep timeoutMs
            in print(testName ^ ": TIMEOUT - Test exceeded time limit");
               exit(authority, 124)
            end)
    
    (* Validate error handling *)
    (* Note: Simplified since Troupe doesn't have full exception handling *)
    fun expectError(operation, expectedErrorType) =
        (* In a real implementation, this would catch and validate errors *)
        false
    
    (* Performance assertion *)
    fun assertPerformance(operation, maxTimeMs, testName) =
        let val (result, elapsed) = measureTime(operation)
        in if elapsed > maxTimeMs then
               (testLog(testName, "PERFORMANCE WARNING: Operation took " ^ 
                        intToString(elapsed) ^ "ms (max: " ^ 
                        intToString(maxTimeMs) ^ "ms)");
                false)
           else
               (testLog(testName, "Performance OK: " ^ intToString(elapsed) ^ "ms");
                true)
        end
    
    (* Export utilities *)
    val utils = {
        measureTime = measureTime,
        measureConnectionTime = measureConnectionTime,
        testConnection = testConnection,
        whereisWithTimeout = whereisWithTimeout,
        sendAndReceiveWithTimeout = sendAndReceiveWithTimeout,
        testBidirectionalComm = testBidirectionalComm,
        spawnAndVerify = spawnAndVerify,
        testLog = testLog,
        createTestTimeout = createTestTimeout,
        expectError = expectError,
        assertPerformance = assertPerformance
    }

in utils
end