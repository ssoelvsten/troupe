(* Async Stream Operations Test - Client *)
(* Tests async stream handling critical for libp2p v0.46+ *)

let 
    val timeout_pid = spawn(fn () => 
        let val _ = sleep 25000
        in print "STREAM-CLIENT: Timeout"; exit(authority, 124)
        end)
    
    fun measure_transfer_time(operation) =
        let val start = getTime()
            val result = operation()
            val elapsed = getTime() - start
        in (result, elapsed)
        end
    
    fun stream_client() =
        let val _ = print "STREAM-CLIENT: Starting async stream test client"
            
            (* Find stream server *)
            val _ = sleep 1000  (* Give server time to register *)
            val server = whereis("@stream-server", "stream-test")
            val _ = print "STREAM-CLIENT: Found stream server"
            
            (* Test 1: Small message (tests basic async operation) *)
            val _ = print "\nSTREAM-CLIENT: Test 1 - Small message async operation"
            val small_msg = "Hello Stream"
            val (small_result, small_time) = measure_transfer_time(fn () =>
                let val _ = send(server, ("SMALL_MSG", small_msg, self()))
                in receive [
                    hn ("SMALL_ACK", ack) => 
                        (print ("STREAM-CLIENT: Small message acknowledged: " ^ ack); true)
                ]
                end
            )
            val _ = print ("STREAM-CLIENT: Small message round-trip: " ^ 
                          intToString(small_time) ^ "ms")
            
            (* Test 2: Large message (tests chunked/async transfer) *)
            val _ = print "\nSTREAM-CLIENT: Test 2 - Large message async transfer"
            val large_size = 1000  (* Request 1KB of data *)
            val (large_result, large_time) = measure_transfer_time(fn () =>
                let val _ = send(server, ("LARGE_MSG", large_size, self()))
                in receive [
                    hn ("LARGE_DATA", data) => 
                        let val _ = print ("STREAM-CLIENT: Received large data")
                            (* Check if we got data by seeing if it's non-empty *)
                            val got_data = data <> ""
                        in got_data
                        end
                ]
                end
            )
            val _ = print ("STREAM-CLIENT: Large message transfer time: " ^ 
                          intToString(large_time) ^ "ms")
            
            (* Test 3: Concurrent streams (tests multiplexing) *)
            val _ = print "\nSTREAM-CLIENT: Test 3 - Concurrent stream operations"
            val _ = print "STREAM-CLIENT: Sending multiple concurrent requests"
            
            (* Send multiple requests without waiting *)
            val _ = send(server, ("CONCURRENT_TEST", 1, self()))
            val _ = send(server, ("CONCURRENT_TEST", 2, self()))
            val _ = send(server, ("CONCURRENT_TEST", 3, self()))
            
            (* Collect responses - they may arrive out of order *)
            fun collect_responses(count, received_ids) =
                if count <= 0 then received_ids
                else
                    receive [
                        hn ("STREAM_RESULT", id, status) =>
                            let val _ = print ("STREAM-CLIENT: Received response for stream " ^ 
                                             intToString(id) ^ ": " ^ status)
                            in collect_responses(count - 1, id :: received_ids)
                            end
                    ]
            
            val received = collect_responses(3, [])
            (* Check if we got 3 responses by counting *)
            val concurrent_success = case received of
                [_, _, _] => true
              | _ => false
            val _ = print ("STREAM-CLIENT: Concurrent test: " ^ 
                          (if concurrent_success then "PASSED" else "FAILED"))
            
            (* Summary *)
            val _ = print "\nSTREAM-CLIENT: Async stream test summary:"
            val _ = print ("  - Small message async: " ^ 
                          (if small_result then "PASSED" else "FAILED"))
            val _ = print ("  - Large message transfer: " ^ 
                          (if large_result then "PASSED" else "FAILED"))
            val _ = print ("  - Concurrent streams: " ^ 
                          (if concurrent_success then "PASSED" else "FAILED"))
            val _ = print "\nSTREAM-CLIENT: Performance metrics:"
            val _ = print ("  - Small message RTT: " ^ intToString(small_time) ^ "ms")
            val _ = print ("  - Large transfer time: " ^ intToString(large_time) ^ "ms")
            val throughput = if large_time > 0 then 
                                large_size * 1000 div large_time
                             else 0
            val _ = print ("  - Throughput: ~" ^ intToString(throughput) ^ " bytes/sec")
            
            val all_passed = small_result andalso large_result andalso concurrent_success
            
        in if all_passed then
            (print "\nSTREAM-CLIENT: All async stream operations tests PASSED"; 
             exit(authority, 0))
           else
            (print "\nSTREAM-CLIENT: Some async stream operations tests FAILED"; 
             exit(authority, 1))
        end

in stream_client()
end