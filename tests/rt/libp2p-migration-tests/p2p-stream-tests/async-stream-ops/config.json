{
  "test_name": "p2p-async-stream-ops",
  "timeout": 35,
  "coordination": "parallel",
  "network": {
    "use_relay": false,
    "bootstrap_peers": []
  },
  "nodes": [
    {
      "id": "stream-server",
      "script": "stream-server.trp",
      "port": 6795,
      "expected_exit_code": 0,
      "extra_argv": "--debug-p2p"
    },
    {
      "id": "stream-client",
      "script": "stream-client.trp", 
      "port": 6796,
      "start_delay": 2,
      "expected_exit_code": 0,
      "extra_argv": "--debug-p2p"
    }
  ],
  "output": {
    "merge_strategy": "timestamp",
    "filter_patterns": ["uuid", "timestamp", "peer_id"]
  }
}