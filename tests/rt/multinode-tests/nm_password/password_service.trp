(* Example of non-malleable information flow in §2.1 in Cecchetti et al. CCS'17 *)
let (* Time out with a non-zero exit code after 60 seconds *)
    val timeout_pid = spawn(fn () => 
        let val _ = sleep 60000
        in exit(authority, 124)
        end)

    val _ = register("checker", self(), authority)

    (* Highly secret password and its predicate *)
    val password = "cecchetti" raisedTo `<ethan; #root-integrity>`
    fun isPassword (guess) = let val result = guess = password
                             in declassify(result, authority, `<; #root-integrity>`)
                             end

    (* Deferred execution of 'isPassword password' *)
    fun deferred () = isPassword password
in (* Send 'isPassword' to the first one asking for it *)
   receive [hn ("PRED", p) => send (p, ("PRED", isPassword))]
end