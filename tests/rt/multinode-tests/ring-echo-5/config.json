      "port": 6791,
      "start_delay": 1,
      "expected_exit_code": 124
    },
    {
      "id": "intermediary3", 
      "script": "intermediary3.trp",
      "port": 6792,
      "start_delay": 1,
      "expected_exit_code": 124
    },
    {
      "id": "intermediary4", 
      "script": "intermediary4.trp",
      "port": 6793,
      "start_delay": 1,
      "expected_exit_code": 124
    },
    {
      "id": "intermediary5", 
      "script": "intermediary5.trp",
      "port": 6794,
