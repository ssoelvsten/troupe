(* Basic Echo Client Test - Finite version *)
(* Sends one message and verifies response *)

let 
    val timeout_pid = spawn(fn () => 
        let val _ = sleep 20000 (* 20 second timeout *)
        in exit(authority, 124) (* Timeout exit code *)
        end)
    
    fun echo_client() = 
        let val _ = print "CLIENT: Starting echo client"
            val _ = sleep 2000  (* Give server time to register *)
            
            val echo_server = whereis("@server", "echo")
            val _ = print "CLIENT: Found echo server"
            
            val test_msg = "Hello World"
            val _ = print ("CLIENT: Sending message: " ^ test_msg)
            val _ = send(echo_server, ("ECHO", test_msg, self()))
            
            val response = receive [hn ("REPLY", x) => x]
            val _ = print ("CLIENT: Received response: " ^ response)
            
        in if response = test_msg then
            (print "CLIENT: Echo test successful"; exit(authority, 0))
           else
            (print "CLIENT: Echo test failed - wrong response"; exit(authority, 1))
        end

in echo_client()
end