{
  "test_name": "basic-echo",
  "timeout": 30,
  "coordination": "parallel",
  "network": {
    "relay_port": 5555,
    "use_relay": true
  },
  "nodes": [
    {
      "id": "server",
      "script": "echo-server.trp",
      "port": 6789,
      "expected_exit_code": 0
    },
    {
      "id": "client", 
      "script": "echo-client.trp",
      "port": 6790,
      "start_delay": 1,
      "expected_exit_code": 0
    }
  ],
  "output": {
    "merge_strategy": "timestamp",
    "filter_patterns": ["uuid", "timestamp", "peer_id"]
  }
}