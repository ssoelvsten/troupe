(* Basic Echo Server Test - Finite version *)
(* Handles exactly one echo request then exits successfully *)

let 
    val timeout_pid = spawn(fn () => 
        let val _ = sleep 25 (* 25 second timeout *)
        in exit(authority, 124) (* Timeout exit code *)
        end)
    
    fun echo_server() =
        let val _ = print "SERVER: Starting echo server"
            val _ = register("echo", self(), authority)
            val _ = print "SERVER: Registered echo service"
            
            (* Handle exactly one echo request *)
            val result = receive [
                hn ("ECHO", msg, sender) => 
                    let val _ = print ("SERVER: Received echo request: " ^ msg)
                        val _ = send(sender, ("REPLY", msg))
                        val _ = print ("SERVER: Sent reply: " ^ msg)
                    in "success"
                    end
            ]
            
        in if result = "success" then
            (print "SERVER: Echo test completed successfully"; 
             exit(authority, 0))
           else
            (print "SERVER: Echo test failed"; 
             exit(authority, 1))
        end

in echo_server()
end