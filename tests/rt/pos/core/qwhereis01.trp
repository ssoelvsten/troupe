(* Test qwhereis primitive - returns a record with processId field *)
(* For local lookups, no quarantineAuth field is present *)

let val myPid = self ()
    val n = node myPid
    val _ = register ("testService", myPid, authority)
    val result = qwhereis (n, "testService")
    val msg = case result of
                  (* For local lookup, only processId is present (no quarantine) *)
                  {processId=pid, ..} =>
                      if pid = myPid then
                          "OK: qwhereis returned correct processId"
                      else
                          "FAIL: qwhereis returned wrong processId"
                | _ => "FAIL: unexpected result structure"
in print msg
end
