
(* positive; *)

let val main = self () 
    val _ = spawn ( fn () => if (true raisedTo `<alice & bob;#root-integrity>`) then send (main, 1) else ())
    val _ = spawn ( fn () => if (true raisedTo `<bob;#root-integrity>`) then send (main, 2) else ())
                              

    val auth_alice = attenuate (authority, `<alice;#root-integrity>`)

    val c = raisembox (`<alice;#root-integrity>`) 

    (* observe that ranged receive takes place over a range that
      is higher than our clearance; this is okay as long as 
      we have enough authority to bridge the gap
    *)

    val r1 = rcv (`<bob;#root-integrity>`, `<alice & bob;#root-integrity>`, [hn x => x])
    val _ = printWithLabels r1 
    val _ = lowermbox (c, auth_alice)

    (* the mailbox clearance at this point is restored to BOT *)
    (* the blocking label is as high as {alice, bob} beacuse of the receive *)
    val _ = debugpc()
    val r2 = rcv (`<bob;#root-integrity>`, `<bob;#root-integrity>`, [hn x => x])
    val _ = debugpc ()
    val _ = printWithLabels r2
in ()
end
