(* 

Created: 2021-08-06; updated 2021-08-09; AA

This test case demonstrates the need to add lclear label to the 
values obtained through the mailbox (which includes both `peek`
and `consume` operations)

The example is based on the masters thesis by Martin, Kristian, and Emil
on the formalization of Troupe in Coq. 
   
*)

(* I will need two processes *)

let fun f () = 
	let  val c = raisembox (`<bob;#root-integrity>`)
	     val x = consume  (0, `<alice;#root-integrity>`, `<alice & bob;#root-integrity>`) 
	     val _ = debugpc ()
	     val _ = blockdeclto (authority , `<alice;#root-integrity>`)
	     val _ = lowermbox (c, authority)
	     val _ = debugpc ()
	     val _ = peek  (0, `<alice;#root-integrity>`, `<alice;#root-integrity>`)
	     val _ = debugpc ()
	in ladv (`<alice;#root-integrity>`, ()) 
	end 
    val p1 = spawn f 
    fun g () = if true raisedTo `<alice;#root-integrity>` then 
    			send (p1, "HELLO");
               		send (p1, "BYE")
	        else () 
    val p2 = spawn g 
in (p1, p2)
end
