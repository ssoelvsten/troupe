let val x = 10 raisedTo `<#root-confidentiality; #null-integrity>`
    val y = 20 raisedTo `<#null-confidentiality; #null-integrity>`
    val z = 30 raisedTo `<#root-confidentiality; #root-integrity>`
    val w = 40 raisedTo `<#null-confidentiality; #root-integrity>`
    val a1 = 100 raisedTo `<alice; #null-integrity>`
    val a2 = 200 raisedTo `<alice; #root-integrity>`
    val a3 = 300 raisedTo `<#root-confidentiality; bob>`
    val a4 = 400 raisedTo `<#null-confidentiality; bob>`
in printWithLabels (x, y, z, w, a1, a2, a3, a4)
end