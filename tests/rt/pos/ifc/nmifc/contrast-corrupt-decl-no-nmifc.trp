(* NMIFC Contrast Test: Corrupt Label Declassification WITHOUT NMIFC

   This test demonstrates that declassification from a corrupt label SUCCEEDS
   when NMIFC is NOT enabled. This is the "unsafe" behavior that NMIFC prevents.

   The label {alice,bob} = <alice & bob; alice | bob> is corrupt because
   (alice | bob) does NOT imply (alice & bob).

   Without NMIFC: Only authority check is performed, which passes with root authority.
   With NMIFC: Robustness check fails (see robust-corrupt-label.trp in neg/ifc/nmifc/).

   This test runs WITHOUT --nmifc flag (no .options file).

   Expected: Declassification succeeds, prints 42

   See: nmifc-summary.md for details on the robustness condition
*)

let val x = 42 raisedTo `{alice,bob}`
    (* {alice,bob} = <alice & bob; alice | bob> -- a corrupt label *)

    (* Declassify: change confidentiality to TRUE, preserve integrity as alice|bob *)
    (* This succeeds without NMIFC but would fail with NMIFC enabled *)
    val y = declassify (x, authority, `<#null-confidentiality; alice|bob>`)
    val _ = blockdown authority
in print y
end
