(* NMIFC Contrast Test: Cross-Dimensional Block Downgrade from Corrupt BL WITHOUT NMIFC

   This test demonstrates that `blockdownto` from a corrupt blocking level SUCCEEDS
   when NMIFC is NOT enabled. This is the "unsafe" behavior that NMIFC prevents.

   The label {alice,bob} = <alice & bob; alice | bob> is corrupt because
   (alice | bob) does NOT imply (alice & bob).

   Without NMIFC: Only authority check is performed, which passes with root authority.
   With NMIFC: Robustness check fails (see crossdim-blockdownto-corrupt-label.trp in neg/ifc/nmifc/).

   This test runs WITHOUT --nmifc flag (uses --no-nmifc in .options file).

   Expected: blockdownto succeeds, prints "done"

   See: nmifc-summary.md for details on the robustness condition
*)

let
    (* Create value with corrupt label {alice,bob} = <alice & bob; alice | bob> *)
    val corruptValue = true raisedTo `{alice,bob}`

    (* Branch on it to raise BL to the corrupt label. PC stays at BOT. *)
    val _ = if corruptValue then () else ()
    (* Now: PC = BOT, BL = {alice,bob} = <alice & bob; alice | bob> (corrupt) *)

    (* Cross-dimensional downgrade of blocking level to BOT *)
    (* This succeeds without NMIFC but would fail with NMIFC enabled *)
    val _ = blockdownto (authority, `<#null-confidentiality; #root-integrity>`)
in print "done"
end
