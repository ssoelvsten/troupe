(* NMIFC Contrast Test: Cross-Dimensional Downgrade from Corrupt Label WITHOUT NMIFC

   This test demonstrates that `downgrade` from a corrupt label SUCCEEDS
   when NMIFC is NOT enabled. This is the "unsafe" behavior that NMIFC prevents.

   The label {alice,bob} = <alice & bob; alice | bob> is corrupt because
   (alice | bob) does NOT imply (alice & bob).

   Without NMIFC: Only authority check is performed, which passes with root authority.
   With NMIFC: Robustness check fails (see crossdim-downgrade-corrupt-label.trp in neg/ifc/nmifc/).

   This test runs WITHOUT --nmifc flag (uses --no-nmifc in .options file).

   Expected: Downgrade succeeds, prints 42

   See: nmifc-summary.md for details on the robustness condition
*)

let val x = 42 raisedTo `{alice,bob}`
    (* {alice,bob} = <alice & bob; alice | bob> -- a corrupt label *)

    (* Cross-dimensional downgrade to BOT *)
    (* This succeeds without NMIFC but would fail with NMIFC enabled *)
    val y = downgrade (x, authority, `<#null-confidentiality; #root-integrity>`)
in print y
end
