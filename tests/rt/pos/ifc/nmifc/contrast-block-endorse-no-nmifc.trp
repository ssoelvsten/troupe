(* NMIFC Contrast Test: Blocking Level Endorsement WITHOUT NMIFC

   This test demonstrates that blockendorseto from a corrupt PC SUCCEEDS
   when NMIFC is NOT enabled. This is the "unsafe" behavior that NMIFC prevents.

   Setup:
   1. Create a value with corrupt label {alice,bob} = <alice & bob; alice | bob>
   2. Branch on that value, which taints the PC with the corrupt label
   3. Attempt blockendorseto - succeeds without NMIFC

   Without NMIFC: Only authority check is performed, which passes with root authority.
   With NMIFC: Transparency check fails (see block-transp-corrupt-label.trp in neg/ifc/nmifc/).

   This test runs WITHOUT --nmifc flag (explicit --no-nmifc in options).

   Expected: blockendorseto succeeds, prints "success"

   See: nmifc-summary.md for details on the transparency condition
*)

let val corruptValue = true raisedTo `{alice,bob}`
    (* {alice,bob} = <alice & bob; alice | bob> -- a corrupt label *)

    (* Branch on corrupt value, tainting the PC *)
    val _ = if corruptValue then () else ()

    (* Now PC is tainted with corrupt label *)
    (* This succeeds without NMIFC but would fail with NMIFC enabled *)
    val _ = blockendorseto (authority, `<alice&bob; #root-integrity>`)
in print "success"
end
