(* Performance test for HAMT - reasonable scale *)

import lists
import hamt

datatype Atoms = NONE | SOME

let
  (* Timing utility *)
  fun timeOp name f =
    let val start = getTime ()
        val result = f ()
        val endTime = getTime ()
        val duration = endTime - start
    in (print (name ^ ": " ^ intToString duration ^ " ms"); result)
    end

  fun assert cond msg =
    if cond then () else print ("ASSERTION FAILED: " ^ msg)

  (* Test 1: Insert 1000 integer keys *)
  val _ = print "\n=== Test 1: Insert 1000 integers ==="
  fun insertInts n trie =
    if n = 0 then trie
    else insertInts (n - 1) (insert trie n (n * n))

  val t1000 = timeOp "Insert 1000 integers" (fn () => insertInts 1000 (empty ()))
  val _ = assert (size t1000 = 1000) "Should have 1000 entries"

  (* Test 2: Lookup performance *)
  val _ = print "\n=== Test 2: Lookup performance ==="
  fun lookupAll n trie =
    if n = 0 then ()
    else (lookup trie n; lookupAll (n - 1) trie)

  val _ = timeOp "Lookup 1000 keys" (fn () => lookupAll 1000 t1000)

  (* Test 3: String keys *)
  val _ = print "\n=== Test 3: Insert 500 string keys ==="
  fun insertStrings n trie =
    if n = 0 then trie
    else insertStrings (n - 1) (insert trie ("key" ^ intToString n) ("value" ^ intToString n))

  val tStr = timeOp "Insert 500 strings" (fn () => insertStrings 500 (empty ()))
  val _ = assert (size tStr = 500) "Should have 500 entries"

  (* Test 4: Mixed operations *)
  val _ = print "\n=== Test 4: Mixed operations ==="
  fun mixedOps n trie =
    if n = 0 then trie
    else
      let val t1 = insert trie n n
          val t2 = if n mod 3 = 0 then remove t1 (n div 2) else t1
          val _ = lookup t2 (n - 1)
      in mixedOps (n - 1) t2
      end

  val tMixed = timeOp "500 mixed operations" (fn () => mixedOps 500 (empty ()))
  val _ = print ("Final size: " ^ intToString (size tMixed))

  (* Test 5: Negative integers *)
  val _ = print "\n=== Test 5: Negative integers ==="
  fun insertNegatives n trie =
    if n = 0 then trie
    else insertNegatives (n - 1) (insert trie (0 - n) ("neg" ^ intToString n))

  val tNeg = timeOp "Insert 100 negatives" (fn () => insertNegatives 100 (empty ()))
  val _ = assert (size tNeg = 100) "Should have 100 entries"

  (* Verify a few lookups *)
  val _ = case lookup tNeg (0 - 50) of
            (SOME, v) => assert (v = "neg50") "Should find neg50"
          | _ => assert false "Should find -50"

in
  print "\n=== Performance test complete ==="
end
