(* Extended HAMT Correctness Tests *)
(* This suite tests edge cases and invariants to guide optimization efforts *)

import lists
import hamt

(* Option type must match the one in HAMT library *)
datatype Atoms = NONE | SOME

let
  (* Test utilities *)
  fun assert cond msg =
    if cond then ()
    else let val _ = printWithLabels ("FAIL:", msg) in exit (authority, 1) end

  fun assertEq actual expected msg =
    assert (actual = expected) (msg ^ " - Expected: " ^ toString expected ^ ", Got: " ^ toString actual)

  fun assertLookup trie key expected msg =
    case lookup trie key of
      (SOME, v) => assertEq v expected msg
    | _ => assert false (msg ^ " - Key not found: " ^ toString key)

  fun assertNotFound trie key msg =
    case lookup trie key of
      NONE => ()
    | _ => assert false (msg ^ " - Key should not be found: " ^ toString key)

  (* Generate test data *)
  fun range n =
    let fun gen i acc = if i < 1 then acc else gen (i-1) (i::acc)
    in gen n []
    end

  (* Test deep collisions - keys that hash to same value *)
  fun generateCollisionKeys n baseHash =
    let
      (* Create keys that will have the same hash by exploiting the hash function *)
      fun makeCollisionKey i =
        (* These patterns are designed to collide in the polynomial hash *)
        let val base = "collision_" ^ intToString baseHash
        in base ^ "_variant_" ^ intToString i
        end
    in map makeCollisionKey (range n)
    end

  val _ = printWithLabels "=== Extended HAMT Correctness Tests ==="

  (* Test 1: Hash distribution and collision patterns *)
  val _ = printWithLabels "\nTest 1: Hash collision patterns"

  (* Insert many entries that will collide at different levels *)
  val collisionKeys1 = generateCollisionKeys 10 1
  val collisionTrie1 = foldl (fn (k, t) => insert t k k) (empty()) collisionKeys1

  (* Verify all keys are present despite collisions *)
  val _ = foldl (fn (k, _) => assertLookup collisionTrie1 k k "Collision key lookup") () collisionKeys1
  val _ = assert (size collisionTrie1 = 10) "All collision keys should be stored"

  (* Test 2: Tree depth stress - force deep trees *)
  val _ = printWithLabels "\nTest 2: Deep tree structure"

  (* Create keys that will create a deep path in the trie *)
  fun deepPathKeys n =
    let
      (* Keys designed to have same index at multiple levels *)
      fun makeDeepKey i =
        let val base = 0
            (* Shift pattern to create same index at each level *)
            val pattern = foldl (fn (j, acc) => acc orb (base << (j * 5))) 0 (range 6)
        in pattern + i
        end
    in map makeDeepKey (range n)
    end

  val deepKeys = deepPathKeys 20
  val deepTrie = foldl (fn (k, t) => insert t k ("value_" ^ intToString k)) (empty()) deepKeys
  val _ = assert (size deepTrie = 20) "Deep path keys should all be stored"

  (* Test 3: Bitmap edge cases - all bits set *)
  val _ = printWithLabels "\nTest 3: Bitmap saturation"

  (* Insert 32 keys that will fill all positions in a bitmap node *)
  fun bitmapSaturationKeys level =
    map (fn i => i << (level * 5)) (range 32)

  val satKeys = bitmapSaturationKeys 0
  val satTrie = foldl (fn (k, t) => insert t k k) (empty()) satKeys
  val _ = assert (size satTrie = 32) "Should handle full bitmap (32 entries)"

  (* Verify removal from saturated bitmap *)
  val satRemoved = remove satTrie (16 << 0)
  val _ = assert (size satRemoved = 31) "Should have 31 after removal"
  val _ = assertNotFound satRemoved 16 "Removed key should not be found"

  (* Test 4: Node type transitions *)
  val _ = printWithLabels "\nTest 4: Node type transitions"

  (* Test leaf -> collision -> bitmap transitions *)
  val trans1 = insert (empty()) "key1" 1
  (* Force a collision by using keys with same hash *)
  val trans2 = insert trans1 "key1_collision" 2  (* This might create collision node *)
  val trans3 = insert trans2 "different_hash" 3  (* This should force bitmap node *)

  val _ = assertLookup trans3 "key1" 1 "Original key after transitions"
  val _ = assert (size trans3 >= 2) "Should have multiple entries"

  (* Test 5: Removal edge cases *)
  val _ = printWithLabels "\nTest 5: Removal edge cases"

  (* Remove from collision node *)
  val coll = fromList [("a", 1), ("aa", 2), ("aaa", 3)]
  val collRemoved = remove coll "aa"
  val _ = assertLookup collRemoved "a" 1 "First collision entry remains"
  val _ = assertLookup collRemoved "aaa" 3 "Third collision entry remains"
  val _ = assertNotFound collRemoved "aa" "Removed collision entry"

  (* Remove last entry from collision node - should convert to leaf *)
  val collRemoved2 = remove collRemoved "aaa"
  val _ = assertLookup collRemoved2 "a" 1 "Last collision entry becomes leaf"
  val _ = assert (size collRemoved2 = 1) "Only one entry remains"

  (* Test 6: Large value handling *)
  val _ = printWithLabels "\nTest 6: Large value storage"

  fun makeLargeValue n =
    foldl (fn (i, s) => s ^ "x") "" (range n)

  val largeTrie = fromList [
    ("small", "tiny"),
    ("medium", makeLargeValue 100),
    ("large", makeLargeValue 1000),
    ("huge", makeLargeValue 10000)
  ]

  val _ = assert (size largeTrie = 4) "Should store all sizes"
  val _ = case lookup largeTrie "huge" of
            (SOME, v) => assert (strlen v = 10000) "Large value preserved"
          | _ => assert false "Large value not found"

  (* Test 7: Persistence verification with complex operations *)
  val _ = printWithLabels "\nTest 7: Complex persistence patterns"

  val base = fromList (map (fn i => (i, i * i)) (range 100))

  (* Create multiple versions *)
  val v1 = insert base 101 10201
  val v2 = remove base 50
  val v3 = insert v2 50 2500  (* Re-insert with different value *)

  (* Verify base is unchanged *)
  val _ = assertLookup base 50 2500 "Base should have original value"
  val _ = assertNotFound base 101 "Base should not have v1's addition"
  val _ = assert (size base = 100) "Base size unchanged"

  (* Verify each version *)
  val _ = assertLookup v1 101 10201 "v1 has new entry"
  val _ = assert (size v1 = 101) "v1 size increased"

  val _ = assertNotFound v2 50 "v2 missing removed key"
  val _ = assert (size v2 = 99) "v2 size decreased"

  val _ = assertLookup v3 50 2500 "v3 has re-inserted key"
  val _ = assert (size v3 = 100) "v3 size back to original"

  (* Test 8: Iterator correctness (toList/fromList roundtrip) *)
  val _ = printWithLabels "\nTest 8: Iterator correctness"

  fun testRoundtrip pairs =
    let val trie = fromList pairs
        val extracted = toList trie
        val rebuilt = fromList extracted
    in
      (* Verify same size *)
      assert (size trie = size rebuilt) "Roundtrip preserves size";
      (* Verify all keys present *)
      foldl (fn ((k, v), _) => assertLookup rebuilt k v "Roundtrip preserves entries") () pairs
    end

  val _ = testRoundtrip (map (fn i => ("key" ^ intToString i, i)) (range 50))

  (* Test 9: Mixed type keys *)
  val _ = printWithLabels "\nTest 9: Mixed type keys"

  val mixedTrie = empty()
  val m1 = insert mixedTrie 42 "number key"
  val m2 = insert m1 "string" "string key"
  val m3 = insert m2 0 "zero"
  val m4 = insert m3 "" "empty string"
  val m5 = insert m4 (-100) "negative"

  val _ = assertLookup m5 42 "number key" "Number key lookup"
  val _ = assertLookup m5 "string" "string key" "String key lookup"
  val _ = assertLookup m5 0 "zero" "Zero key lookup"
  val _ = assertLookup m5 "" "empty string" "Empty string lookup"
  val _ = assertLookup m5 (-100) "negative" "Negative key lookup"
  val _ = assert (size m5 = 5) "All mixed keys stored"

  (* Test 10: Hash function properties *)
  val _ = printWithLabels "\nTest 10: Hash function verification"

  (* Verify hash determinism *)
  val h1 = hash "test"
  val h2 = hash "test"
  val _ = assert (h1 = h2) "Hash should be deterministic"

  (* Verify hash range *)
  val testVals = ["", "a", "ab", "abc", "abcd", "abcde", intToString 12345, intToString (-67890)]
  val hashes = map hash testVals
  val _ = foldl (fn (h, _) => assert (h >= 0 andalso h < 1073741824) "Hash in valid range") () hashes

  (* Test 11: Extreme removal patterns *)
  val _ = printWithLabels "\nTest 11: Extreme removal patterns"

  (* Build large trie *)
  val largeTrie = fromList (map (fn i => (i, i)) (range 1000))

  (* Remove every other element *)
  val evenRemoved = foldl (fn (i, t) => if i mod 2 = 0 then remove t i else t) largeTrie (range 1000)
  val _ = assert (size evenRemoved = 500) "Half elements removed"

  (* Verify remaining elements *)
  val _ = foldl (fn (i, _) =>
    if i mod 2 = 1
    then assertLookup evenRemoved i i "Odd elements remain"
    else assertNotFound evenRemoved i "Even elements removed"
  ) () (range 100)  (* Check first 100 *)

  (* Test 12: Collision node stress *)
  val _ = printWithLabels "\nTest 12: Collision node stress"

  (* Force many collisions *)
  fun makeCollisionTrie n =
    let
      (* These keys are designed to have the same hash *)
      val keys = map (fn i => "coll_" ^ intToString (i mod 5) ^ "_" ^ intToString i) (range n)
    in fromList (map (fn k => (k, k)) keys)
    end

  val collTrie = makeCollisionTrie 50
  val _ = assert (size collTrie = 50) "All collision entries stored"

  (* Test 13: Memory pattern verification *)
  val _ = printWithLabels "\nTest 13: Memory efficiency patterns"

  (* Create tries with different patterns and verify structure *)
  val sparse = fromList [(1, "a"), (1000, "b"), (1000000, "c")]
  val dense = fromList (map (fn i => (i, intToString i)) (range 100))

  val _ = assert (size sparse = 3) "Sparse trie correct size"
  val _ = assert (size dense = 100) "Dense trie correct size"

  (* Test 14: Update patterns *)
  val _ = printWithLabels "\nTest 14: Update patterns"

  (* Repeated updates to same key *)
  val updateTrie = foldl (fn (i, t) => insert t "key" i) (empty()) (range 1000)
  val _ = assertLookup updateTrie "key" 1000 "Last update value retained"
  val _ = assert (size updateTrie = 1) "Size remains 1 after updates"

  (* Test 15: Edge case key patterns *)
  val _ = printWithLabels "\nTest 15: Edge case key patterns"

  val edgeTrie = fromList [
    (0, "zero"),
    (1, "one"),
    (-1, "minus one"),
    (1073741823, "max positive"),  (* 2^30 - 1 *)
    (-1073741824, "min negative"), (* -2^30 *)
    ("", "empty string"),
    (" ", "space"),
    ("\n", "newline"),
    ("\t", "tab"),
    ("null", "null string"),
    ("undefined", "undefined string")
  ]

  val _ = assert (size edgeTrie = 11) "All edge case keys stored"
  val _ = assertLookup edgeTrie 0 "zero" "Zero key"
  val _ = assertLookup edgeTrie "" "empty string" "Empty string key"

in
  printWithLabels "\nAll extended correctness tests passed!"
end
