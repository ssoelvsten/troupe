(* Optimized HAMT implementation *)

import lists

datatype Atoms = NONE | SOME

let 
  (* Constants *)
  val SHIFT = 5
  val BRANCH_FACTOR = 32
  val MASK = 31
  
  (* Character code at index *)
  fun charCode s idx = charCodeAtWithDefault (s, idx, 63)
  
  (* Optimized hash function *)
  fun hash x = 
    let val typ = getType x
    in
      if typ = "number" 
      then 
        (* Knuth's multiplicative hash *)
        let val h = x * 2654435761 mod 1073741824
        in if h < 0 then h + 1073741824 else h
        end  
      else 
        (* Optimized string hash - unroll small strings *)
        let val s = toString x
            val len = strlen s
            fun hashStr idx acc =
              if idx >= len then acc
              else hashStr (idx + 1) ((acc * 31 + charCode s idx) mod 1073741824)
        in 
          (* Fast path for small strings *)
          if len = 0 then 0
          else if len = 1 then charCode s 0
          else if len = 2 then (31 * charCode s 0 + charCode s 1) mod 1073741824
          else hashStr 0 0
        end
    end
             
  fun getIndex hashval level = (hashval >> (level * SHIFT)) andb MASK
    
  (* Bitmap operations *)
  fun setBit bitmap pos = bitmap orb (1 << pos)
  fun testBit bitmap pos = ((bitmap >> pos) andb 1) = 1
  fun clearBit bitmap pos = bitmap andb ((-1) xorb (1 << pos))
    
  (* Optimized popcount using parallel bit counting *)
  fun popcount n =
    let 
      val m1 = 1431655765
      val m2 = 858993459
      val m4 = 252645135
      val m8 = 16843009
      
      val n1 = (n andb m1) + ((n >> 1) andb m1)
      val n2 = (n1 andb m2) + ((n1 >> 2) andb m2)
      val n3 = (n2 andb m4) + ((n2 >> 4) andb m4)
      val result = ((n3 * m8) >> 24) andb 255
    in result
    end
    
  fun positionInBitmap bitmap pos =
    let val mask = (1 << pos) - 1
        val masked = bitmap andb mask
    in popcount masked
    end
    
  (* Optimized array operations - still use lists but minimize traversals *)
  fun arrayGet arr idx = 
    case (idx, arr) of
      (0, x::xs) => x
    | (n, x::xs) => arrayGet xs (n - 1)
    | _ => {}
    
  (* Optimized arraySet - use accumulator to avoid append *)
  fun arraySet arr idx value =
    let fun set i [] acc = rev acc
          | set i (x::xs) acc = 
              if i = 0 
              then rev acc @ (value :: xs)
              else set (i-1) xs (x::acc)
    in set idx arr []
    end
    
  fun arrayInsert arr idx value =
    let fun ins i [] acc = rev (value :: acc)
          | ins i (x::xs) acc =
              if i = 0
              then rev acc @ (value :: x :: xs)
              else ins (i-1) xs (x::acc)
    in ins idx arr []
    end
    
  fun arrayRemove arr idx =
    let fun rem i [] acc = rev acc
          | rem i (x::xs) acc =
              if i = 0
              then rev acc @ xs
              else rem (i-1) xs (x::acc)
    in rem idx arr []
    end
    
  (* Enhanced node types with size tracking *)
  (* Empty: {} *)
  (* Leaf: {tag = "leaf", key, value, hash} *)
  (* BitmapNode: {tag = "bitmap", bitmap, children, size} *)
  (* CollisionNode: {tag = "collision", hash, entries, size} *)
    
  fun empty () = {}
  
  (* Optimized collision lookup using early termination *)
  fun findInEntries key [] = NONE
    | findInEntries key ((k, v)::es) =
        if k = key then (SOME, v) else findInEntries key es
  
  (* Insert with size tracking *)
  fun insert trie key value =
    let val h = hash key
        fun insertNode node h key value level =
          case node of
            {} => {tag = "leaf", key = key, value = value, hash = h}
          | {tag = "leaf", key = k, value = v, hash = oldHash, ..} =>
              if h = oldHash then
                if key = k then
                  (* Value update - reuse node if value unchanged *)
                  if v = value then node
                  else {tag = "leaf", key = key, value = value, hash = h}
                else
                  {tag = "collision", hash = h, entries = [(k, v), (key, value)], size = 2}
              else
                let val idx1 = getIndex oldHash level
                    val idx2 = getIndex h level
                    val child1 = node  (* Reuse existing leaf *)
                    val child2 = {tag = "leaf", key = key, value = value, hash = h}
                in if idx1 = idx2 then
                     let val subNode = insertNode child1 h key value (level + 1)
                         val nodeSize = case subNode of
                                         {size = s, ..} => s
                                       | _ => 2  (* Leaf or collision *)
                     in {tag = "bitmap", bitmap = setBit 0 idx1, children = [subNode], size = nodeSize}
                     end
                   else
                     let val bitmap = setBit (setBit 0 idx1) idx2
                         val children = if idx1 < idx2 then [child1, child2] else [child2, child1]
                     in {tag = "bitmap", bitmap = bitmap, children = children, size = 2}
                     end
                end
          | {tag = "bitmap", bitmap = bm, children = ch, size = sz, ..} =>
              let val idx = getIndex h level
              in if testBit bm idx then
                   let val pos = positionInBitmap bm idx
                       val child = arrayGet ch pos
                       val oldChildSize = case child of
                                           {size = s, ..} => s
                                         | _ => 1
                       val newChild = insertNode child h key value (level + 1)
                       val newChildSize = case newChild of
                                           {size = s, ..} => s
                                         | _ => 1
                       val sizeDiff = newChildSize - oldChildSize
                   in {tag = "bitmap", bitmap = bm, children = arraySet ch pos newChild, 
                       size = sz + sizeDiff}
                   end
                 else
                   let val pos = positionInBitmap bm idx
                       val newChild = {tag = "leaf", key = key, value = value, hash = h}
                       val newBitmap = setBit bm idx
                       val newChildren = arrayInsert ch pos newChild
                   in {tag = "bitmap", bitmap = newBitmap, children = newChildren, size = sz + 1}
                   end
              end
          | {tag = "collision", hash = collHash, entries = entries, size = sz, ..} =>
              if h = collHash then
                case findInEntries key entries of
                  NONE => {tag = "collision", hash = collHash, 
                          entries = append entries [(key, value)], size = sz + 1}
                | _ => 
                    let val newEntries = map (fn (k, v) => 
                            if k = key then (key, value) else (k, v)) entries
                    in {tag = "collision", hash = collHash, entries = newEntries, size = sz}
                    end
              else
                (* Convert collision node to bitmap node *)
                let val idx = getIndex collHash level
                    val startNode = {tag = "bitmap", bitmap = setBit 0 idx, 
                                   children = [node], size = sz}
                in insertNode startNode h key value level
                end
          | _ => node
    in insertNode trie h key value 0
    end
    
  (* Optimized lookup *)
  fun lookup trie key =
    let val h = hash key
        fun lookupNode node h key level =
          case node of
            {} => NONE
          | {tag = "leaf", key = k, value = v, ..} =>
              if k = key then (SOME, v) else NONE
          | {tag = "bitmap", bitmap = bm, children = ch, ..} =>
              let val idx = getIndex h level
              in if testBit bm idx then
                   lookupNode (arrayGet ch (positionInBitmap bm idx)) h key (level + 1)
                 else NONE
              end
          | {tag = "collision", entries = entries, ..} =>
              findInEntries key entries
          | _ => NONE
    in lookupNode trie h key 0
    end
    
  (* Remove with size tracking *)
  fun remove trie key =
    let val h = hash key
        fun removeNode node h key level =
          case node of
            {} => {}
          | {tag = "leaf", key = k, ..} =>
              if k = key then {} else node
          | {tag = "bitmap", bitmap = bm, children = ch, size = sz, ..} =>
              let val idx = getIndex h level
              in if testBit bm idx then
                   let val pos = positionInBitmap bm idx
                       val child = arrayGet ch pos
                       val oldChildSize = case child of
                                           {size = s, ..} => s
                                         | _ => 1
                       val newChild = removeNode child h key (level + 1)
                   in case newChild of
                        {} => 
                          let val newBitmap = clearBit bm idx
                              val newChildren = arrayRemove ch pos
                              val childCount = length newChildren
                          in if childCount = 1 andalso level > 0 then
                               first newChildren
                             else if newBitmap = 0 then {}
                             else {tag = "bitmap", bitmap = newBitmap, children = newChildren, 
                                   size = sz - oldChildSize}
                          end
                      | _ => 
                          let val newChildSize = case newChild of
                                                 {size = s, ..} => s
                                               | _ => 1
                              val sizeDiff = oldChildSize - newChildSize
                          in {tag = "bitmap", bitmap = bm, children = arraySet ch pos newChild,
                              size = sz - sizeDiff}
                          end
                   end
                 else node
              end
          | {tag = "collision", hash = collHash, entries = entries, size = sz, ..} =>
              let val newEntries = filter (fn (k, v) => k <> key) entries
                  val entryCount = length newEntries
              in case entryCount of
                   0 => {}
                 | 1 => let val (k, v) = first newEntries
                        in {tag = "leaf", key = k, value = v, hash = collHash}
                        end
                 | _ => {tag = "collision", hash = collHash, entries = newEntries, size = entryCount}
              end
          | _ => node
    in removeNode trie h key 0
    end
    
  fun contains trie key =
    case lookup trie key of
      NONE => false
    | _ => true
    
  (* Optimized size - O(1) for nodes with size field *)
  fun size trie =
    case trie of
      {} => 0
    | {size = s, ..} => s
    | {tag = "leaf", ..} => 1
    | _ => length (keys trie)  (* Fallback for malformed nodes *)
    
  (* Keys/values/toList remain the same but could be optimized with continuations *)
  fun keys trie =
    let fun collectKeys node acc =
          case node of
            {} => acc
          | {tag = "leaf", key = k, ..} => k :: acc
          | {tag = "bitmap", children = ch, ..} =>
              foldl (fn (child, a) => collectKeys child a) acc ch
          | {tag = "collision", entries = entries, ..} =>
              foldl (fn ((k, v), a) => k :: a) acc entries
          | _ => acc
    in collectKeys trie []
    end
    
  fun values trie =
    let fun collectValues node acc =
          case node of
            {} => acc
          | {tag = "leaf", value = v, ..} => v :: acc
          | {tag = "bitmap", children = ch, ..} =>
              foldl (fn (child, a) => collectValues child a) acc ch
          | {tag = "collision", entries = entries, ..} =>
              foldl (fn ((k, v), a) => v :: a) acc entries
          | _ => acc
    in collectValues trie []
    end
    
  fun toList trie =
    let fun collectPairs node acc =
          case node of
            {} => acc
          | {tag = "leaf", key = k, value = v, ..} => (k, v) :: acc
          | {tag = "bitmap", children = ch, ..} =>
              foldl (fn (child, a) => collectPairs child a) acc ch
          | {tag = "collision", entries = entries, ..} =>
              append entries acc
          | _ => acc
    in collectPairs trie []
    end
    
  fun fromList pairs =
    foldl (fn ((k, v), t) => insert t k v) (empty ()) pairs

in
  (* Export public functions *)
  [ ("empty", empty)
  , ("insert", insert)
  , ("lookup", lookup)
  , ("remove", remove)
  , ("contains", contains)
  , ("keys", keys)
  , ("values", values)
  , ("toList", toList)
  , ("fromList", fromList)
  , ("size", size)
  , ("hash", hash)
  , ("NONE", NONE)
  , ("SOME", SOME)
  ]
end