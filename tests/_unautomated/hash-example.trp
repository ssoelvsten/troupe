(* Example of using the hash function from HAMT library *)
import hamt

let
  (* Generate 100 random numbers *)
  fun generateRandoms n acc =
    if n = 0 then acc
    else
      let val r = random ()
          val num = stringToInt (intToString (floor (r * 9999.0)))
      in generateRandoms (n - 1) (num :: acc)
      end

  val randomNumbers = generateRandoms 100 []

  val _ = printWithLabels "Hash function examples:"
  val _ = printWithLabels ""

  (* Show first 10 hash results *)
  val _ = printWithLabels "First 10 hash results:"
  fun showFirst lst n =
    case (lst, n) of
      ([], _) => ()
    | (_, 0) => ()
    | (x::xs, n) =>
        let val h = hash x
            val _ = printWithLabels ("Number:", x, "Hash:", h)
        in showFirst xs (n - 1)
        end
  val _ = showFirst randomNumbers 10

  val _ = printWithLabels ""
  val _ = printWithLabels "Hash distribution analysis (first 5 bits):"

  (* Count how many hashes fall into each bucket *)
  fun countInBucket lst bucket =
    case lst of
      [] => 0
    | x::xs =>
        let val h = hash x
            val b = h andb 31
        in (if b = bucket then 1 else 0) + countInBucket xs bucket
        end

  fun showBuckets b =
    if b >= 32 then ()
    else
      let val count = countInBucket randomNumbers b
          val _ = if count > 0
                  then printWithLabels ("Bucket", b, ":", count, "items")
                  else ()
      in showBuckets (b + 1)
      end
  val _ = showBuckets 0

  val _ = printWithLabels ""
  val _ = printWithLabels "Hash examples with different types:"

  (* Test hash function with strings *)
  val _ = printWithLabels ("Hash of 'hello':", hash "hello")
  val _ = printWithLabels ("Hash of 'world':", hash "world")
  val _ = printWithLabels ("Hash of 'troupe':", hash "troupe")
  val _ = printWithLabels ("Hash of empty string:", hash "")
  val _ = printWithLabels ("Hash of long string:", hash "This is a much longer string to test the hash function")

  (* Test hash function with various numbers *)
  val _ = printWithLabels ""
  val _ = printWithLabels "Hash of special numbers:"
  val _ = printWithLabels ("Hash of 0:", hash 0)
  val _ = printWithLabels ("Hash of 1:", hash 1)
  val _ = printWithLabels ("Hash of -1:", hash (-1))
  val _ = printWithLabels ("Hash of 42:", hash 42)
  val _ = printWithLabels ("Hash of -42:", hash (-42))
  val _ = printWithLabels ("Hash of 1000000:", hash 1000000)
  val _ = printWithLabels ("Hash of -1000000:", hash (-1000000))

  (* Show how hash values are used in HAMT for indexing *)
  val _ = printWithLabels ""
  val _ = printWithLabels "HAMT index calculation examples:"

  (* Test with a string *)
  val testString = "test"
  val hashString = hash testString
  val _ = printWithLabels ("Value:", testString, "Hash:", hashString)
  val _ = printWithLabels ("  Level 0 index:", (hashString >> 0) andb 31)
  val _ = printWithLabels ("  Level 1 index:", (hashString >> 5) andb 31)
  val _ = printWithLabels ("  Level 2 index:", (hashString >> 10) andb 31)
  val _ = printWithLabels ("  Level 3 index:", (hashString >> 15) andb 31)

  val _ = printWithLabels ""

  (* Test with a number *)
  val testNumber = 12345
  val hashNumber = hash testNumber
  val _ = printWithLabels ("Value:", testNumber, "Hash:", hashNumber)
  val _ = printWithLabels ("  Level 0 index:", (hashNumber >> 0) andb 31)
  val _ = printWithLabels ("  Level 1 index:", (hashNumber >> 5) andb 31)
  val _ = printWithLabels ("  Level 2 index:", (hashNumber >> 10) andb 31)
  val _ = printWithLabels ("  Level 3 index:", (hashNumber >> 15) andb 31)

  (* Summary statistics *)
  val _ = printWithLabels ""
  val _ = printWithLabels "Summary statistics for 100 random numbers:"

  (* Find min and max hash *)
  fun findMinMax lst =
    case lst of
      [] => (0, 0)
    | x::xs =>
        let val h = hash x
            fun iter lst minH maxH =
              case lst of
                [] => (minH, maxH)
              | y::ys =>
                  let val hy = hash y
                  in iter ys (if hy < minH then hy else minH) (if hy > maxH then hy else maxH)
                  end
        in iter xs h h
        end

  val (minHash, maxHash) = findMinMax randomNumbers
  val _ = printWithLabels ("Minimum hash:", minHash)
  val _ = printWithLabels ("Maximum hash:", maxHash)

  (* Count collisions (simplified) *)
  fun countCollisions lst =
    let fun hasHashInRest h rest =
          case rest of
            [] => false
          | x::xs => (hash x = h) orelse hasHashInRest h xs
        fun countDups lst count =
          case lst of
            [] => count
          | x::xs =>
              let val h = hash x
              in if hasHashInRest h xs
                 then countDups xs (count + 1)
                 else countDups xs count
              end
    in countDups lst 0
    end

  val collisions = countCollisions randomNumbers
  val _ = printWithLabels ("Hash collisions found:", collisions)
  val _ = printWithLabels ("Unique hashes:", 100 - collisions)

in printWithLabels "Hash example completed!"
end

