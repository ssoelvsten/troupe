(* HAMT Optimization Benchmark *)

import lists
import hamt as orig

(* For now, we'll use the original implementation for both tests *)
(* The optimized version would need to be compiled as a library first *)
let
    val optEmpty = orig.empty
    val optInsert = orig.insert
    val optLookup = orig.lookup
    val optRemove = orig.remove
    val optSize = orig.size
    val optFromList = orig.fromList
    val optToList = orig.toList
in

(* Option type must match *)
datatype Atoms = NONE | SOME

let
  (* Timing utility *)
  fun timeOp name f =
    let val start = getTime ()
        val result = f ()
        val endTime = getTime ()
        val duration = endTime - start
    in (printWithLabels (name, ":", duration, "ms"); result)
    end

  (* Test data generation *)
  fun range n =
    let fun gen i acc = if i < 1 then acc else gen (i-1) (i::acc)
    in gen n []
    end

  fun generatePairs n =
    map (fn i => ("key_" ^ intToString i, i)) (range n)

  val _ = printWithLabels "=== HAMT Optimization Benchmark ==="

  (* Test 1: Sequential insertions *)
  val _ = printWithLabels "\nTest 1: Sequential insertions (5000 items)"

  val testPairs = generatePairs 5000

  val origTrie = timeOp "Original: 5000 insertions" (fn () =>
    foldl (fn ((k, v), t) => orig.insert t k v) (orig.empty ()) testPairs)

  val optTrie = timeOp "Optimized: 5000 insertions" (fn () =>
    foldl (fn ((k, v), t) => optInsert t k v) (optEmpty ()) testPairs)

  (* Test 2: Size calculation *)
  val _ = printWithLabels "\nTest 2: Size calculation (1000 calls on 5000-item trie)"

  val _ = timeOp "Original: 1000 size calls" (fn () =>
    foldl (fn (_, _) => orig.size origTrie) () (range 1000))

  val _ = timeOp "Optimized: 1000 size calls" (fn () =>
    foldl (fn (_, _) => optSize optTrie) () (range 1000))

  (* Test 3: Random lookups *)
  val _ = printWithLabels "\nTest 3: Random lookups (1000 lookups)"

  val lookupKeys = map (fn i => "key_" ^ intToString ((i * 7919) mod 5000)) (range 1000)

  val _ = timeOp "Original: 1000 lookups" (fn () =>
    foldl (fn (k, _) => orig.lookup origTrie k) () lookupKeys)

  val _ = timeOp "Optimized: 1000 lookups" (fn () =>
    foldl (fn (k, _) => optLookup optTrie k) () lookupKeys)

  (* Test 4: Mixed operations *)
  val _ = printWithLabels "\nTest 4: Mixed operations (insert/lookup/remove)"

  fun mixedOps insertFn lookupFn removeFn emptyFn n =
    let fun ops t i =
          if i > n then t
          else
            let val key = "mix_" ^ intToString i
                val op_type = i mod 3
            in case op_type of
                 0 => ops (insertFn t key i) (i + 1)
               | 1 => (lookupFn t key; ops t (i + 1))
               | _ => ops (removeFn t key) (i + 1)
            end
    in ops (emptyFn ()) 1
    end

  val _ = timeOp "Original: 3000 mixed operations" (fn () =>
    mixedOps orig.insert orig.lookup orig.remove orig.empty 3000)

  val _ = timeOp "Optimized: 3000 mixed operations" (fn () =>
    mixedOps optInsert optLookup optRemove optEmpty 3000)

  (* Test 5: Collision handling *)
  val _ = printWithLabels "\nTest 5: Collision stress test (500 colliding keys)"

  (* Generate keys that will collide *)
  val collisionPairs = map (fn i =>
    let val base = intToString (i mod 10)
        val key = foldl (fn (_, s) => s ^ base) base (range (i mod 5 + 1))
    in (key, i)
    end) (range 500)

  val _ = timeOp "Original: 500 collision insertions" (fn () =>
    foldl (fn ((k, v), t) => orig.insert t k v) (orig.empty ()) collisionPairs)

  val _ = timeOp "Optimized: 500 collision insertions" (fn () =>
    foldl (fn ((k, v), t) => optInsert t k v) (optEmpty ()) collisionPairs)

  (* Test 6: fromList performance *)
  val _ = printWithLabels "\nTest 6: fromList performance (2000 items)"

  val fromListPairs = generatePairs 2000

  val _ = timeOp "Original: fromList 2000" (fn () =>
    orig.fromList fromListPairs)

  val _ = timeOp "Optimized: fromList 2000" (fn () =>
    optFromList fromListPairs)

  (* Test 7: Removal performance *)
  val _ = printWithLabels "\nTest 7: Removal performance (remove 500 from 1000)"

  val removeTrie1 = orig.fromList (generatePairs 1000)
  val removeTrie2 = optFromList (generatePairs 1000)
  val removeKeys = map (fn i => "key_" ^ intToString i) (range 500)

  val _ = timeOp "Original: 500 removals" (fn () =>
    foldl (fn (k, t) => orig.remove t k) removeTrie1 removeKeys)

  val _ = timeOp "Optimized: 500 removals" (fn () =>
    foldl (fn (k, t) => optRemove t k) removeTrie2 removeKeys)

  (* Test 8: Value updates (same key) *)
  val _ = printWithLabels "\nTest 8: Value updates (1000 updates to same key)"

  val _ = timeOp "Original: 1000 updates" (fn () =>
    foldl (fn (i, t) => orig.insert t "updateKey" i) (orig.empty ()) (range 1000))

  val _ = timeOp "Optimized: 1000 updates" (fn () =>
    foldl (fn (i, t) => optInsert t "updateKey" i) (optEmpty ()) (range 1000))

  (* Test 9: Small string hashing *)
  val _ = printWithLabels "\nTest 9: Small string performance (1000 single-char keys)"

  val smallKeys = map (fn i => (charToString (65 + (i mod 26)), i)) (range 1000)

  val _ = timeOp "Original: 1000 small strings" (fn () =>
    foldl (fn ((k, v), t) => orig.insert t k v) (orig.empty ()) smallKeys)

  val _ = timeOp "Optimized: 1000 small strings" (fn () =>
    foldl (fn ((k, v), t) => optInsert t k v) (optEmpty ()) smallKeys)

in
  printWithLabels "\nBenchmark completed!"
end

end
