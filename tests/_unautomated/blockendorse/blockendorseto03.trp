(* Test 3: blockendorseto interaction with processes - positive test *)
let fun worker () =
      let val msg = peek (0, `{}`, `{}`)
          val _ = blockendorseto (authority, `<secret;#root-integrity>`)
          (* This should prevent endorsement to secret label *)
          val _ = debugpc ()
      in print msg
      end
    val p = spawn worker
    val sensitiveData = "data" raisedTo `<public;#root-integrity>`
in send (p, sensitiveData);
   send (p, "done")
end