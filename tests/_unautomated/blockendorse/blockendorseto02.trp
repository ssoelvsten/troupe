(* Test 2: blockendorseto with multiple labels - positive test *)
let val secret = true
    val labeled = secret raisedTo `<alice & bob;>`
    val aliceAuth = attenuate (authority, `<alice;>`)
    val bobAuth = attenuate (authority, `<bob;>`)
    val _ = blockendorseto (authority, `<alice;>`)
    (* Endorsement to alice should be blocked, but bob should work *)
    val endorsed = endorse (labeled, bobAuth, `<bob;>`)
in printWithLabels endorsed
end