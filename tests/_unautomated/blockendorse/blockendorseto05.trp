(* Test 5: blockendorseto with partial blocking - positive test *)
let val data = "sensitive"
    val aliceData = data raisedTo `<alice;>`
    val bobData = data raisedTo `<bob;>`
    val _ = blockendorseto (authority, `<alice;>`)
    val bobAuth = attenuate (authority, `<bob;>`)
    (* Endorsing bob data should still work *)
    val endorsedBob = endorse (bobData, bobAuth, `<bob;>`)
    val _ = printWithLabels endorsedBob
    (* But operations involving alice should be restricted *)
    val _ = if aliceData == "sensitive" then () else ()
in print "test completed"
end