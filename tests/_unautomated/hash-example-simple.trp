(* Simple example of using the hash function from HAMT library *)
import hamt

let 
  val _ = printWithLabels "Hash function examples from HAMT library:"
  val _ = printWithLabels ""
  
  (* Test hash function with various numbers *)
  val _ = printWithLabels "Hash of numbers 1-20:"
  fun showHashes n =
    if n > 20 then ()
    else 
      let val h = hash n
          val _ = printWithLabels ("Number:", n, "Hash:", h)
      in showHashes (n + 1)
      end
  val _ = showHashes 1
  
  val _ = printWithLabels ""
  val _ = printWithLabels "Hash distribution for numbers 1-100 (first 5 bits):"
  
  (* Count bucket distribution *)
  fun analyzeBuckets maxNum =
    let fun countForBucket bucket n count =
          if n > maxNum then count
          else 
            let val h = hash n
                val b = h andb 31
            in countForBucket bucket (n + 1) (if b = bucket then count + 1 else count)
            end
        fun showBucket b =
          if b >= 32 then ()
          else
            let val count = countForBucket b 1 0
                val _ = if count > 0 
                        then printWithLabels ("Bucket", b, ":", count, "items")
                        else ()
            in showBucket (b + 1)
            end
    in showBucket 0
    end
  val _ = analyzeBuckets 100
  
  val _ = printWithLabels ""
  val _ = printWithLabels "Hash examples with strings:"
  val _ = printWithLabels ("Hash of 'hello':", hash "hello")
  val _ = printWithLabels ("Hash of 'world':", hash "world") 
  val _ = printWithLabels ("Hash of 'troupe':", hash "troupe")
  val _ = printWithLabels ("Hash of '':", hash "")
  val _ = printWithLabels ("Hash of 'a':", hash "a")
  val _ = printWithLabels ("Hash of 'aa':", hash "aa")
  val _ = printWithLabels ("Hash of 'aaa':", hash "aaa")
  
  val _ = printWithLabels ""
  val _ = printWithLabels "Special number hashes:"
  val _ = printWithLabels ("Hash of 0:", hash 0)
  val _ = printWithLabels ("Hash of -1:", hash (-1))
  val _ = printWithLabels ("Hash of 1073741824:", hash 1073741824)
  val _ = printWithLabels ("Hash of 2147483647:", hash 2147483647)
  
  (* Show HAMT indexing *)
  val _ = printWithLabels ""
  val _ = printWithLabels "HAMT index calculation example:"
  val testVal = "example"
  val h = hash testVal
  val _ = printWithLabels ("Value:", testVal)
  val _ = printWithLabels ("Hash:", h)
  val _ = printWithLabels ("Level 0 index (bits 0-4):", (h >> 0) andb 31)
  val _ = printWithLabels ("Level 1 index (bits 5-9):", (h >> 5) andb 31)
  val _ = printWithLabels ("Level 2 index (bits 10-14):", (h >> 10) andb 31)
  val _ = printWithLabels ("Level 3 index (bits 15-19):", (h >> 15) andb 31)
  val _ = printWithLabels ("Level 4 index (bits 20-24):", (h >> 20) andb 31)
  val _ = printWithLabels ("Level 5 index (bits 25-29):", (h >> 25) andb 31)
  
  (* Test Knuth's multiplicative hash *)
  val _ = printWithLabels ""
  val _ = printWithLabels "Testing hash quality (Knuth's multiplicative hash):"
  val _ = printWithLabels ("42 * 2654435761 mod 1073741824 =", hash 42)
  val _ = printWithLabels ("43 * 2654435761 mod 1073741824 =", hash 43)
  val _ = printWithLabels ("Difference:", hash 43 - hash 42)
    
in printWithLabels "Hash example completed!"
end