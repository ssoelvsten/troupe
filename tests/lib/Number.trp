import Unit
import Number

let val tests = group "Number" [
            group "maxInt / minInt" [
                it "maxInt++ = maxInt" (isEq maxInt (maxInt + 1))
              , it "minInt-- = minInt" (isEq minInt (minInt - 1))
            ],
            group "abs" [
                it "keeps 0 as is"    (isEq 0 (abs 0))
              , it "keeps +2 as is"   (isEq 2 (abs 2))
              , it "negates -1 as is" (isEq 1 (abs (-1)))
            ],
            group "min" [
                it "returns 1  for ( 1, 2)" (isEq  1   (min ( 1, 2)))
              , it "returns -1 for ( 1, 0)" (isEq  0   (min ( 1, 0)))
              , it "returns -1 for (-1, 0)" (isEq (-1) (min (-1, 0)))
            ],
            group "max" [
                it "returns 2 for ( 1, 2)" (isEq 2 (max ( 1, 2)))
              , it "returns 2 for ( 3, 1)" (isEq 3 (max ( 3, 1)))
              , it "returns 0 for (-1, 0)" (isEq 0 (max (-1, 0)))
            ],
            group "ceil" [
                it "returns 0 for 0"    (isEq 0    (ceil 0))
              , it "returns 1 for 1"    (isEq 1    (ceil 1))
              , it "returns -1 for -1"  (isEq (-1) (ceil (-1)))
              , it "returns 2 for 3/2"  (isEq 2    (ceil (3/2)))
              , it "returns 2 for 4/3"  (isEq 2    (ceil (4/3)))
              , it "returns 2 for 5/3"  (isEq 2    (ceil (5/3)))
              , it "returns 9 for 42/5" (isEq 9    (ceil (42/5)))
              , it "returns 8 for 43/5" (isEq 9    (ceil (43/5)))
            ],
            group "floor" [
                it "returns 0 for 0"    (isEq 0    (floor 0))
              , it "returns 1 for 1"    (isEq 1    (floor 1))
              , it "returns -1 for -1"  (isEq (-1) (floor (-1)))
              , it "returns 1 for 3/2"  (isEq 1    (floor (3/2)))
              , it "returns 1 for 4/3"  (isEq 1    (floor (4/3)))
              , it "returns 1 for 5/3"  (isEq 1    (floor (5/3)))
              , it "returns 8 for 42/5" (isEq 8    (floor (42/5)))
              , it "returns 8 for 43/5" (isEq 8    (floor (43/5)))
            ],
            group "floor" [
                it "returns 0 for 0"    (isEq 0    (round 0))
              , it "returns 1 for 1"    (isEq 1    (round 1))
              , it "returns -1 for -1"  (isEq (-1) (round (-1)))
              , it "returns 2 for 3/2"  (isEq 2    (round (3/2)))
              , it "returns 1 for 4/3"  (isEq 1    (round (4/3)))
              , it "returns 2 for 5/3"  (isEq 2    (round (5/3)))
              , it "returns 8 for 42/5" (isEq 8    (round (42/5)))
              , it "returns 9 for 43/5" (isEq 9    (round (43/5)))
            ],
            group "sqrt" [
                it "returns 0 for 0"    (isEq 0    (sqrt 0))
              , it "returns 1 for 1"    (isEq 1    (sqrt 1))
              , it "returns 2 for 4"    (isEq 2    (sqrt 4))
              , it "returns 3 for 9"    (isEq 3    (sqrt 9))
            ],
            group "isInt" [
                it "accepts 0"     (isTrue  (isInt 0))
              , it "accepts 1"     (isTrue  (isInt 1))
              , it "accepts -1"    (isTrue  (isInt (-1)))
              , it "accepts 42"    (isTrue  (isInt 42))
              , it "accepts 0/2"   (isTrue  (isInt (0/2)))
              , it "accepts 1/-1"  (isTrue  (isInt (1/(-1))))
              , it "accepts -1/1"  (isTrue  (isInt ((-1)/1)))
              , it "accepts 42/42" (isTrue  (isInt (42/42)))
              , it "rejects 3/2"   (isFalse (isInt (3/2)))
              , it "rejects 42/5"  (isFalse (isInt (42/5)))
            ],
            group "toInt" [
                it "leaves 0 as is"         (isEq 0               (toInt 0))
              , it "leaves 1 as is"         (isEq 1               (toInt 1))
              , it "leaves -1 as is"        (isEq (-1)            (toInt (-1)))
              , it "leaves 42 as is"        (isEq 42              (toInt 42))
              , it "omits fraction for 3/2" (isEq 1               (toInt (3/2)))
              , it "omits fraction for 5/2" (isEq 2               (toInt (5/2)))
            ],
            group "toInt32" [
                it "leaves 0 as is"         (isEq 0               (toInt32 0))
              , it "leaves 1 as is"         (isEq 1               (toInt32 1))
              , it "leaves -1 as is"        (isEq (-1)            (toInt32 (-1)))
              , it "leaves 42 as is"        (isEq 42              (toInt32 42))
              , it "omits fraction for 3/2" (isEq 1               (toInt32 (3/2)))
              , it "truncates  2^33-1"      (isEq maxInt32 (toInt32 (2*2*2*(1 << 30))))
              , it "truncates -2^33-1"      (isEq minInt32 (toInt32 (-(2*2*2*(1 << 30) - 1))))
            ],
            group "toString" [
                it "returns '0'        for 0"    (isEq "0"                  (toString 0))
              , it "returns '0'        for 0/2"  (isEq "0"                  (toString (0/2)))
              , it "returns '1'        for 1"    (isEq "1"                  (toString 1))
              , it "returns '1.5'      for 3/2"  (isEq "1.5"                (toString (3/2)))
              , it "returns '0.333...' for 1/3"  (isEq "0.3333333333333333" (toString (1/3)))
            ],
            group "fromString" [
                it "returns 0     for '0'"    (isEq 0            (fromString "0"))
              , it "returns 0     for '0.'"   (isEq 0            (fromString "0."))
              , it "returns 0     for '0.0'"  (isEq 0            (fromString "0.00"))
              , it "returns 42    for '42'"   (isEq 42           (fromString "42"))
              , it "returns 42/10 for '4.2'"  (isEq (42/10)      (fromString "4.2"))
            ]
        ]
in run authority tests end
