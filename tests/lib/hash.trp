import hash

let (* Tests for 'hashKnuth' *)
    val _ = print ("hashMultiplyShift -42 31   = " ^ (intToString (hashMultiplyShift (-42)  31  )))
    val _ = print ("hashMultiplyShift -42 16   = " ^ (intToString (hashMultiplyShift (-42)  16  )))
    val _ = print ("hashMultiplyShift -1  31   = " ^ (intToString (hashMultiplyShift (-1)   31  )))
    val _ = print ("hashMultiplyShift  0  31   = " ^ (intToString (hashMultiplyShift  0     31  )))
    val _ = print ("hashMultiplyShift  1  -1   = " ^ (intToString (hashMultiplyShift  1    (-1))))
    val _ = print ("hashMultiplyShift  1   0   = " ^ (intToString (hashMultiplyShift  1      0  )))
    val _ = print ("hashMultiplyShift  1   3   = " ^ (intToString (hashMultiplyShift  1      3  )))
    val _ = print ("hashMultiplyShift  1   8   = " ^ (intToString (hashMultiplyShift  1      8  )))
    val _ = print ("hashMultiplyShift  1  31   = " ^ (intToString (hashMultiplyShift  1     31  )))
    val _ = print ("hashMultiplyShift  42  8   = " ^ (intToString (hashMultiplyShift  42     8  )))
    val _ = print ("hashMultiplyShift  42  8.5 = " ^ (intToString (hashMultiplyShift  42    (17/2))))
    val _ = print ("hashMultiplyShift  42 12   = " ^ (intToString (hashMultiplyShift  42    12  )))
    val _ = print ("hashMultiplyShift  42 31   = " ^ (intToString (hashMultiplyShift  42    31  )))

    (* Tests for 'hashInt' *)
    val _ = print ""
    val _ = print ("hashInt -100 = " ^ (intToString (hashInt (-100))))
    val _ = print ("hashInt -11  = " ^ (intToString (hashInt (-11))))
    val _ = print ("hashInt -10  = " ^ (intToString (hashInt (-10))))
    val _ = print ("hashInt -7   = " ^ (intToString (hashInt (-7))))
    val _ = print ("hashInt -5   = " ^ (intToString (hashInt (-5))))
    val _ = print ("hashInt -3   = " ^ (intToString (hashInt (-3))))
    val _ = print ("hashInt -2   = " ^ (intToString (hashInt (-2))))
    val _ = print ("hashInt -1   = " ^ (intToString (hashInt (-1))))
    val _ = print ("hashInt  0   = " ^ (intToString (hashInt  0)))
    val _ = print ("hashInt  1   = " ^ (intToString (hashInt  1)))
    val _ = print ("hashInt  2   = " ^ (intToString (hashInt  2)))
    val _ = print ("hashInt  3   = " ^ (intToString (hashInt  3)))
    val _ = print ("hashInt  4   = " ^ (intToString (hashInt  4)))
    val _ = print ("hashInt  5   = " ^ (intToString (hashInt  5)))
    val _ = print ("hashInt  6   = " ^ (intToString (hashInt  6)))
    val _ = print ("hashInt  7   = " ^ (intToString (hashInt  7)))
    val _ = print ("hashInt  8   = " ^ (intToString (hashInt  8)))
    val _ = print ("hashInt  9   = " ^ (intToString (hashInt  9)))
    val _ = print ("hashInt  10  = " ^ (intToString (hashInt  10)))
    val _ = print ("hashInt  11  = " ^ (intToString (hashInt  11)))
    val _ = print ("hashInt  13  = " ^ (intToString (hashInt  13)))
    val _ = print ("hashInt  42  = " ^ (intToString (hashInt  42)))
    val _ = print ("hashInt  63  = " ^ (intToString (hashInt  63)))
    val _ = print ("hashInt  64  = " ^ (intToString (hashInt  64)))
    val _ = print ("hashInt  100 = " ^ (intToString (hashInt  100)))
    val _ = print ("hashInt  127 = " ^ (intToString (hashInt  127)))

    (* Tests for 'hashString' *)
    val _ = print ""
    val _ = print ("hashString ''   = " ^ (intToString (hashString "")))
    val _ = print ("hashString 'a'  = " ^ (intToString (hashString "a")))
    val _ = print ("hashString 'b'  = " ^ (intToString (hashString "b")))
    val _ = print ("hashString 'c'  = " ^ (intToString (hashString "c")))
    val _ = print ("hashString 'aa' = " ^ (intToString (hashString "aa")))
    val _ = print ("hashString 'ab' = " ^ (intToString (hashString "ab")))
    val _ = print ("hashString 'ba' = " ^ (intToString (hashString "ba")))
    val _ = print ("hashString 'bb' = " ^ (intToString (hashString "bb")))
    val _ = print ("hashString 'bc' = " ^ (intToString (hashString "bc")))
    val _ = print ("hashString 'cb' = " ^ (intToString (hashString "cb")))
    val _ = print ("hashString 'ac' = " ^ (intToString (hashString "ac")))
    val _ = print ("hashString 'ca' = " ^ (intToString (hashString "ca")))
    val _ = print ("hashString 'aslan'  = " ^ (intToString (hashString "aslan")))
    val _ = print ("hashString 'ananas' = " ^ (intToString (hashString "ananas")))
    val _ = print ("hashString 'banana' = " ^ (intToString (hashString "banana")))

    (* Tests for 'hash' *)
    val _ = print ""
    val _ = print ("hash 0    = " ^ (intToString (hash 0)))
    val _ = print ("hash 42   = " ^ (intToString (hash 42)))
    val _ = print ("hash 100  = " ^ (intToString (hash 100)))
    val _ = print ("hash ''   = " ^ (intToString (hash "")))
    val _ = print ("hash 'a'  = " ^ (intToString (hash "a")))
    val _ = print ("hash 'ba' = " ^ (intToString (hash "ba")))

in () end
