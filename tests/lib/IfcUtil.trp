import IfcUtil

let fun printpc () =
        print ("pc", _pc (), "bl", _bl ())

    (* Constants *)
    val _ = print (flowsTo (IfcUtil.root, IfcUtil.root))
    val _ = print (flowsTo (IfcUtil.root, IfcUtil.null))
    val _ = print (flowsTo (IfcUtil.root, IfcUtil.bot))
    val _ = print (flowsTo (IfcUtil.root, IfcUtil.top))

    val _ = print (flowsTo (IfcUtil.null, IfcUtil.root))
    val _ = print (flowsTo (IfcUtil.null, IfcUtil.null))
    val _ = print (flowsTo (IfcUtil.null, IfcUtil.bot))
    val _ = print (flowsTo (IfcUtil.null, IfcUtil.top))

    val _ = print (flowsTo (IfcUtil.bot, IfcUtil.root))
    val _ = print (flowsTo (IfcUtil.bot, IfcUtil.null))
    val _ = print (flowsTo (IfcUtil.bot, IfcUtil.bot))
    val _ = print (flowsTo (IfcUtil.bot, IfcUtil.top))

    val _ = print (flowsTo (IfcUtil.top, IfcUtil.root))
    val _ = print (flowsTo (IfcUtil.top, IfcUtil.null))
    val _ = print (flowsTo (IfcUtil.top, IfcUtil.bot))
    val _ = print (flowsTo (IfcUtil.top, IfcUtil.top))

    (* `declassifyDeep`, `endorseDeep`, and `downgradeDeep` *)
    val alice  = `<alice; alice>`
    val aliceC = `<alice; #root-integrity>`

    val bob  = `<bob; bob>`

    val x  = 1 raisedTo alice
    val x' = IfcUtil.endorseDeep (x, authority, aliceC)
    val _ = printWithLabels x'
    val _ = printWithLabels (IfcUtil.declassifyDeep (x', authority, IfcUtil.bot))
    val _ = printWithLabels (IfcUtil.downgradeDeep (x, authority, IfcUtil.bot))

    val x  = "secret!" raisedTo alice
    val x' = IfcUtil.endorseDeep (x, authority, aliceC)
    val _ = printWithLabels x'
    val _ = printWithLabels (IfcUtil.declassifyDeep (x', authority, IfcUtil.bot))
    val _ = printWithLabels (IfcUtil.downgradeDeep (x, authority, IfcUtil.bot))

    val x  = (1 raisedTo alice, 2 raisedTo alice) raisedTo alice
    val x' = IfcUtil.endorseDeep (x, authority, aliceC)
    val _ = printWithLabels x'
    val _ = printWithLabels (IfcUtil.declassifyDeep (x', authority, IfcUtil.bot))
    val _ = printWithLabels (IfcUtil.downgradeDeep (x, authority, IfcUtil.bot))

    val x  = ((1, 2 raisedTo alice) raisedTo alice, 3 raisedTo alice) raisedTo alice
    val x' = IfcUtil.endorseDeep (x, authority, aliceC)
    val _ = printWithLabels x'
    val _ = printWithLabels (IfcUtil.declassifyDeep (x', authority, IfcUtil.bot))
    val _ = printWithLabels (IfcUtil.downgradeDeep (x, authority, IfcUtil.bot))

    val x = (1, (2 raisedTo alice, 3 raisedTo bob) raisedTo bob)
    val _ = printWithLabels (IfcUtil.downgradeDeep (x, authority, IfcUtil.bot))

    val x = (1, 2 raisedTo alice, 3 raisedTo bob) raisedTo alice
    val _ = printWithLabels (IfcUtil.downgradeDeep (x, authority, IfcUtil.bot))

    val x = [ 1
            , 2 raisedTo alice
            , (3 raisedTo bob, 4) raisedTo alice
            , (5, [6 raisedTo bob])
            ] raisedTo alice
    val _ = printWithLabels (IfcUtil.downgradeDeep (x, authority, IfcUtil.bot))

    (* `freadlnPini` *)
    val _ = blockdecl authority

    val x = IfcUtil.freadlnPini (stdin authority, authority)
    val _ = printWithLabels x
    val _ = printpc ()

    (* `freadlnAtLevel` *)
    val _ = blockdecl authority

    val x = IfcUtil.freadlnAtLevel (stdin authority, authority, IfcUtil.bot)
    val _ = printWithLabels x
    val _ = printpc ()

in () end
