import Unit
import StencilVector

let val tests = group "StencilVector" [
            group "maskBits" [
                it "is a number" (isEq "number" (getType maskBits))
                ],
            group "maskMax" [
                it "is a number"         (isEq "number"                 (getType maskMax))
              , it "is 2^{maskBits} - 1" (isEq ((1 << maskBits) - 1) (maskMax))
            ],
            let val sv = empty
            in group "empty" [
                    it "has no members" [
                        isFalse (mem sv 0)
                      , isFalse (mem sv 1)
                      , isFalse (mem sv 2)
                      , isFalse (mem sv 3)
                      , isFalse (mem sv 7)
                      , isFalse (mem sv 16)
                      , isFalse (mem sv 30)
                      , isFalse (mem sv 31)
                    ]
                  , it "provides default with getOrDefault [0]" (isEq 42 (getOrDefault sv 0 42))
                  , it "provides default with getOrDefault [1]" (isEq () (getOrDefault sv 1 ()))
                  , it "is valid"          (isTrue (valid sv))
                  , it "is null"           (isTrue (null sv))
                  , it "has 0 as its mask" (isEq 0 (mask sv))
                  , it "has length 0"      (isEq 0 (length sv))
                ]
            end,
            let val sv = set (empty) 0 42
            in group "set (empty) 0 42" [
                    it "has a member at [0]" (isTrue (mem sv 0))
                  , it "provides value with get [0]"          (isEq 42 (get sv 0))
                  , it "provides value with getOrDefault [0]" (isEq 42 (getOrDefault sv 0 ()))
                  , it "has no other members" [
                        isFalse (mem sv 1)
                      , isFalse (mem sv 2)
                      , isFalse (mem sv 3)
                      , isFalse (mem sv 7)
                      , isFalse (mem sv 16)
                      , isFalse (mem sv 30)
                      , isFalse (mem sv 31)
                    ]
                  , it "provides default with getOrDefault [1]" (isEq () (getOrDefault sv 1 ()))
                  , it "is valid"          (isTrue (valid sv))
                  , it "is not null"       (isFalse (null sv))
                  , it "has 1 as its mask" (isEq 1 (mask sv))
                  , it "has length 1"      (isEq 1 (length sv))
                ]
            end,
            let val sv = set (empty) 1 "a"
            in group "set (empty) 1 'a'" [
                    it "has a member at [1]" (isTrue (mem sv 1))
                  , it "provides value with get [1]"          (isEq "a" (get sv 1))
                  , it "provides value with getOrDefault [1]" (isEq "a" (getOrDefault sv 1 ()))
                  , it "has no other members" [
                        isFalse (mem sv 0)
                      , isFalse (mem sv 2)
                      , isFalse (mem sv 3)
                      , isFalse (mem sv 7)
                      , isFalse (mem sv 16)
                      , isFalse (mem sv 30)
                      , isFalse (mem sv 31)
                    ]
                  , it "provides default with getOrDefault [0]" (isEq ()  (getOrDefault sv 0 ()))
                  , it "is valid"          (isTrue (valid sv))
                  , it "is not null"       (isFalse (null sv))
                  , it "has 2 as its mask" (isEq 2 (mask sv))
                  , it "has length 1"      (isEq 1 (length sv))
                ]
            end,
            let val sv = set (empty) 31 []
            in group "set (empty) 31 []" [
                    it "has a member at [31]" (isTrue (mem sv 31))
                  , it "provides value with get [31]"          (isEq [] (get sv 31))
                  , it "provides value with getOrDefault [31]" (isEq [] (getOrDefault sv 31 ()))
                  , it "has no other members" [
                        isFalse (mem sv 0)
                      , isFalse (mem sv 1)
                      , isFalse (mem sv 2)
                      , isFalse (mem sv 3)
                      , isFalse (mem sv 7)
                      , isFalse (mem sv 16)
                      , isFalse (mem sv 30)
                    ]
                  , it "provides default with getOrDefault [0]" (isEq () (getOrDefault sv 0 ()))
                  , it "is valid"                      (isTrue (valid sv))
                  , it "is not null"                   (isFalse (null sv))
                  , it "has (-)2147483648 as its mask" (isEq (-2147483648) (mask sv))
                  , it "has length 1"                  (isEq 1 (length sv))
                ]
            end,
            let val sv  = singleton 2 42
                val sv' = set (empty) 2 42
            in group "singleton 2 42" [
                    it "is equivalent to (set (empty) 2 42)" (isEq sv' sv)
                ]
            end,
            let val sv  = singleton 4 "b"
                val sv' = set (empty) 4 "b"
            in group "singleton 4 'b'" [
                    it "is equivalent to (set (empty) 4 'b')" (isEq sv' sv)
                ]
            end,
            let val sv = set (singleton 0 (0,21)) 1 (1,42)
            in group "set (singleton 0 (0,21)) 1 (1,42)" [
                    it "has a member at [0]" (isTrue (mem sv 0))
                  , it "provides value with get [0]"          (isEq (0,21) (get sv 0))
                  , it "provides value with getOrDefault [0]" (isEq (0,21) (getOrDefault sv 0 (-1)))
                  , it "has a member at [1]" (isTrue (mem sv 1))
                  , it "provides value with get [1]"          (isEq (1,42) (get sv 1))
                  , it "provides value with getOrDefault [1]" (isEq (1,42) (getOrDefault sv 1 (-1)))
                  , it "has no other members" [
                        isFalse (mem sv 2)
                      , isFalse (mem sv 3)
                      , isFalse (mem sv 4)
                      , isFalse (mem sv 7)
                      , isFalse (mem sv 16)
                      , isFalse (mem sv 30)
                      , isFalse (mem sv 31)
                    ]
                  , it "provides default with getOrDefault [2]" (isEq (-1) (getOrDefault sv 2 (-1)))
                  , it "provides default with getOrDefault [4]" (isEq (-1) (getOrDefault sv 4 (-1)))
                  , it "is valid"           (isTrue (valid sv))
                  , it "is not null"        (isFalse (null sv))
                  , it "has 3 as its mask"  (isEq 3 (mask sv))
                  , it "has length 2"       (isEq 2 (length sv))
                ]
            end,
            let val sv = set (singleton 1 (1,42)) 0 (0,21)
            in group "set (singleton 1 (1,42)) 0 (0,21)" [
                    it "has a member at [0]" (isTrue (mem sv 0))
                  , it "provides value with get [0]"          (isEq (0,21) (get sv 0))
                  , it "provides value with getOrDefault [0]" (isEq (0,21) (getOrDefault sv 0 (-1)))
                  , it "has a member at [1]" (isTrue (mem sv 1))
                  , it "provides value with get [1]"          (isEq (1,42) (get sv 1))
                  , it "provides value with getOrDefault [1]" (isEq (1,42) (getOrDefault sv 1 (-1)))
                  , it "has no other members" [
                        isFalse (mem sv 2)
                      , isFalse (mem sv 3)
                      , isFalse (mem sv 4)
                      , isFalse (mem sv 7)
                      , isFalse (mem sv 16)
                      , isFalse (mem sv 30)
                      , isFalse (mem sv 31)
                    ]
                  , it "provides default with getOrDefault [2]" (isEq (-1) (getOrDefault sv 2 (-1)))
                  , it "provides default with getOrDefault [4]" (isEq (-1) (getOrDefault sv 4 (-1)))
                  , it "is valid"           (isTrue (valid sv))
                  , it "is not null"        (isFalse (null sv))
                  , it "has 3 as its mask"  (isEq 3 (mask sv))
                  , it "has length 2"       (isEq 2 (length sv))
                ]
            end,
            let val sv = set (set (singleton 0 (0,true)) 1 (1,42)) 0 (0,false)
            in group "set (set (singleton 0 (0,true)) 1 (1,42)) 0 (0,false)" [
                    it "has a member at [0]" (isTrue (mem sv 0))
                  , it "provides value with get [0]"          (isEq (0,false) (get sv 0))
                  , it "provides value with getOrDefault [0]" (isEq (0,false) (getOrDefault sv 0 (-1)))
                  , it "has a member at [1]" (isTrue (mem sv 1))
                  , it "provides value with get [1]"          (isEq (1,42) (get sv 1))
                  , it "provides value with getOrDefault [1]" (isEq (1,42) (getOrDefault sv 1 (-1)))
                  , it "has no other members" [
                        isFalse (mem sv 2)
                      , isFalse (mem sv 3)
                      , isFalse (mem sv 4)
                      , isFalse (mem sv 7)
                      , isFalse (mem sv 16)
                      , isFalse (mem sv 30)
                      , isFalse (mem sv 31)
                    ]
                  , it "provides default with getOrDefault [2]" (isEq (-1) (getOrDefault sv 2 (-1)))
                  , it "provides default with getOrDefault [4]" (isEq (-1) (getOrDefault sv 4 (-1)))
                  , it "is valid"           (isTrue (valid sv))
                  , it "is not null"        (isFalse (null sv))
                  , it "has 3 as its mask"  (isEq 3 (mask sv))
                  , it "has length 2"       (isEq 2 (length sv))
                ]
            end,
            let val sv = set (singleton 1 42) 3 21
            in group "set (singleton 1 42) 3 21" [
                    it "has a member at [1]" (isTrue (mem sv 1))
                  , it "provides value with get [1]"          (isEq 42 (get sv 1))
                  , it "provides value with getOrDefault [1]" (isEq 42 (getOrDefault sv 1 (-1)))
                  , it "has a member at [3]" (isTrue (mem sv 3))
                  , it "provides value with get [3]"          (isEq 21 (get sv 3))
                  , it "provides value with getOrDefault [1]" (isEq 21 (getOrDefault sv 3 (-1)))
                  , it "has no other members" [
                        isFalse (mem sv 0)
                      , isFalse (mem sv 2)
                      , isFalse (mem sv 4)
                      , isFalse (mem sv 7)
                      , isFalse (mem sv 16)
                      , isFalse (mem sv 30)
                      , isFalse (mem sv 31)
                    ]
                  , it "provides default with getOrDefault [2]" (isEq (-1) (getOrDefault sv 2 (-1)))
                  , it "provides default with getOrDefault [4]" (isEq (-1) (getOrDefault sv 4 (-1)))
                  , it "is valid"           (isTrue (valid sv))
                  , it "is not null"        (isFalse (null sv))
                  , it "has 10 as its mask" (isEq 10 (mask sv))
                  , it "has length 2"       (isEq 2 (length sv))
                ]
            end,
            let val sv = set (singleton 2 false) 2 true
            in group "set (singleton 2 false) 2 true" [
                    it "has a member at [2]" (isTrue (mem sv 2))
                  , it "provides value with get [2]" (isEq true (get sv 2))
                  , it "has no other members" [
                        isFalse (mem sv 0)
                      , isFalse (mem sv 1)
                      , isFalse (mem sv 3)
                      , isFalse (mem sv 4)
                      , isFalse (mem sv 7)
                      , isFalse (mem sv 16)
                      , isFalse (mem sv 30)
                      , isFalse (mem sv 31)
                    ]
                  , it "is valid"          (isTrue (valid sv))
                  , it "is not null"       (isFalse (null sv))
                  , it "has 4 as its mask" (isEq 4 (mask sv))
                  , it "has length 1"      (isEq 1 (length sv))
                ]
            end,
            let val sv = unset (singleton 7 42) 7
            in group "unset (singleton 7 42) 7" [
                    it "is equivalent to (empty)" (isEq empty sv)
                ]
            end,
            let val sv = unset (set (singleton 2 false) 4 true) 4
            in group "unset (set (singleton 2 false) 4 true) 2" [
                    it "is equivalent to (singleton 2 false)" (isEq (singleton 2 false) sv)
                  , it "provides value with getOrDefault [2]" (isEq false (getOrDefault sv 2 (-1)))
                  , it "provides default with getOrDefault [4]" (isEq (-1) (getOrDefault sv 4 (-1)))
                ]
            end,
            let val sv = unset (set (set (empty) 2 false) 4 true) 2
            in group "unset (set (set (empty) 2 false) 4 true) 2" [
                    it "is equivalent to (singleton 4 true)" (isEq (singleton 4 true) sv)
                  , it "provides default with getOrDefault [2]" (isEq (-1) (getOrDefault sv 2 (-1)))
                  , it "provides value with getOrDefault [4]" (isEq true (getOrDefault sv 4 (-1)))
                ]
            end,
            let fun inc x = x+1
                fun dec x = x-1
            in group "map (+/- 1)" [
                    it "does nothing to (empty)" (isEq empty (map inc empty))
                  , let val sv  = singleton 2 1
                        val sv' = map inc (singleton 2 0)
                    in it "can increment (singleton 2 0)" (isEq sv sv')
                    end
                  , let val sv  = set (singleton 1 2) 3 3
                        val sv' = map inc (set (singleton 1 1) 3 2)
                    in it "can increment (set (singleton 1 1) 3 2)" (isEq sv sv')
                    end
                  , let val sv  = set (singleton 1 0) 3 1
                        val sv' = map dec (set (singleton 1 1) 3 2)
                    in it "can decrement (set (singleton 1 1) 3 2)" (isEq sv sv')
                    end
                ]
            end,
            let fun sum (x,y) = x+y
            in group "fold (+)" [
                    it "returns initial value for (empty)" (isEq 0 (fold sum 0 empty))
                  , let val sv = singleton 4 42
                    in it "computes 42 for (singleton 4 42)" (isEq 42 (fold sum 0 sv))
                    end
                  , let val sv = set (singleton 4 42) 2 21
                    in it "computes 64 for (set (singleton 4 42) 2 21)" (isEq 63 (fold sum 0 sv))
                    end
                ]
            end
        ]
in run authority tests end
