import qualified Unit
import qualified StencilVector

let val tests = Unit.group "StencilVector" [
            Unit.group "maskBits" [
                Unit.it "is a number" (Unit.isEq "number" (getType StencilVector.maskBits))
                ],
            Unit.group "maskMax" [
                Unit.it "is a number"         (Unit.isEq "number"                 (getType StencilVector.maskMax))
              , Unit.it "is 2^{maskBits} - 1" (Unit.isEq ((1 << StencilVector.maskBits) - 1) (StencilVector.maskMax))
            ],
            let val sv = StencilVector.empty
            in Unit.group "empty" [
                    Unit.it "has no members" [
                        Unit.isFalse (StencilVector.mem sv 0)
                      , Unit.isFalse (StencilVector.mem sv 1)
                      , Unit.isFalse (StencilVector.mem sv 2)
                      , Unit.isFalse (StencilVector.mem sv 3)
                      , Unit.isFalse (StencilVector.mem sv 7)
                      , Unit.isFalse (StencilVector.mem sv 16)
                      , Unit.isFalse (StencilVector.mem sv 30)
                      , Unit.isFalse (StencilVector.mem sv 31)
                    ]
                  , Unit.it "provides default with getOrDefault [0]" (Unit.isEq 42 (StencilVector.getOrDefault sv 0 42))
                  , Unit.it "provides default with getOrDefault [1]" (Unit.isEq () (StencilVector.getOrDefault sv 1 ()))
                  , Unit.it "is valid"          (Unit.isTrue (StencilVector.valid sv))
                  , Unit.it "is null"           (Unit.isTrue (StencilVector.null sv))
                  , Unit.it "has 0 as its mask" (Unit.isEq 0 (StencilVector.mask sv))
                  , Unit.it "has length 0"      (Unit.isEq 0 (StencilVector.length sv))
                ]
            end,
            let val sv = StencilVector.set (StencilVector.empty) 0 42
            in Unit.group "set (empty) 0 42" [
                    Unit.it "has a member at [0]" (Unit.isTrue (StencilVector.mem sv 0))
                  , Unit.it "provides value with get [0]"          (Unit.isEq 42 (StencilVector.get sv 0))
                  , Unit.it "provides value with getOrDefault [0]" (Unit.isEq 42 (StencilVector.getOrDefault sv 0 ()))
                  , Unit.it "has no other members" [
                        Unit.isFalse (StencilVector.mem sv 1)
                      , Unit.isFalse (StencilVector.mem sv 2)
                      , Unit.isFalse (StencilVector.mem sv 3)
                      , Unit.isFalse (StencilVector.mem sv 7)
                      , Unit.isFalse (StencilVector.mem sv 16)
                      , Unit.isFalse (StencilVector.mem sv 30)
                      , Unit.isFalse (StencilVector.mem sv 31)
                    ]
                  , Unit.it "provides default with getOrDefault [1]" (Unit.isEq () (StencilVector.getOrDefault sv 1 ()))
                  , Unit.it "is valid"          (Unit.isTrue (StencilVector.valid sv))
                  , Unit.it "is not null"       (Unit.isFalse (StencilVector.null sv))
                  , Unit.it "has 1 as its mask" (Unit.isEq 1 (StencilVector.mask sv))
                  , Unit.it "has length 1"      (Unit.isEq 1 (StencilVector.length sv))
                ]
            end,
            let val sv = StencilVector.set (StencilVector.empty) 1 "a"
            in Unit.group "set (empty) 1 'a'" [
                    Unit.it "has a member at [1]" (Unit.isTrue (StencilVector.mem sv 1))
                  , Unit.it "provides value with get [1]"          (Unit.isEq "a" (StencilVector.get sv 1))
                  , Unit.it "provides value with getOrDefault [1]" (Unit.isEq "a" (StencilVector.getOrDefault sv 1 ()))
                  , Unit.it "has no other members" [
                        Unit.isFalse (StencilVector.mem sv 0)
                      , Unit.isFalse (StencilVector.mem sv 2)
                      , Unit.isFalse (StencilVector.mem sv 3)
                      , Unit.isFalse (StencilVector.mem sv 7)
                      , Unit.isFalse (StencilVector.mem sv 16)
                      , Unit.isFalse (StencilVector.mem sv 30)
                      , Unit.isFalse (StencilVector.mem sv 31)
                    ]
                  , Unit.it "provides default with getOrDefault [0]" (Unit.isEq ()  (StencilVector.getOrDefault sv 0 ()))
                  , Unit.it "is valid"          (Unit.isTrue (StencilVector.valid sv))
                  , Unit.it "is not null"       (Unit.isFalse (StencilVector.null sv))
                  , Unit.it "has 2 as its mask" (Unit.isEq 2 (StencilVector.mask sv))
                  , Unit.it "has length 1"      (Unit.isEq 1 (StencilVector.length sv))
                ]
            end,
            let val sv = StencilVector.set (StencilVector.empty) 31 []
            in Unit.group "set (empty) 31 []" [
                    Unit.it "has a member at [31]" (Unit.isTrue (StencilVector.mem sv 31))
                  , Unit.it "provides value with get [31]"          (Unit.isEq [] (StencilVector.get sv 31))
                  , Unit.it "provides value with getOrDefault [31]" (Unit.isEq [] (StencilVector.getOrDefault sv 31 ()))
                  , Unit.it "has no other members" [
                        Unit.isFalse (StencilVector.mem sv 0)
                      , Unit.isFalse (StencilVector.mem sv 1)
                      , Unit.isFalse (StencilVector.mem sv 2)
                      , Unit.isFalse (StencilVector.mem sv 3)
                      , Unit.isFalse (StencilVector.mem sv 7)
                      , Unit.isFalse (StencilVector.mem sv 16)
                      , Unit.isFalse (StencilVector.mem sv 30)
                    ]
                  , Unit.it "provides default with getOrDefault [0]" (Unit.isEq () (StencilVector.getOrDefault sv 0 ()))
                  , Unit.it "is valid"                      (Unit.isTrue (StencilVector.valid sv))
                  , Unit.it "is not null"                   (Unit.isFalse (StencilVector.null sv))
                  , Unit.it "has (-)2147483648 as its mask" (Unit.isEq (-2147483648) (StencilVector.mask sv))
                  , Unit.it "has length 1"                  (Unit.isEq 1 (StencilVector.length sv))
                ]
            end,
            let val sv  = StencilVector.singleton 2 42
                val sv' = StencilVector.set (StencilVector.empty) 2 42
            in Unit.group "singleton 2 42" [
                    Unit.it "is equivalent to (set (empty) 2 42)" (Unit.isEq sv' sv)
                ]
            end,
            let val sv  = StencilVector.singleton 4 "b"
                val sv' = StencilVector.set (StencilVector.empty) 4 "b"
            in Unit.group "singleton 4 'b'" [
                    Unit.it "is equivalent to (set (empty) 4 'b')" (Unit.isEq sv' sv)
                ]
            end,
            let val sv = StencilVector.set (StencilVector.singleton 0 (0,21)) 1 (1,42)
            in Unit.group "set (singleton 0 (0,21)) 1 (1,42)" [
                    Unit.it "has a member at [0]" (Unit.isTrue (StencilVector.mem sv 0))
                  , Unit.it "provides value with get [0]"          (Unit.isEq (0,21) (StencilVector.get sv 0))
                  , Unit.it "provides value with getOrDefault [0]" (Unit.isEq (0,21) (StencilVector.getOrDefault sv 0 (-1)))
                  , Unit.it "has a member at [1]" (Unit.isTrue (StencilVector.mem sv 1))
                  , Unit.it "provides value with get [1]"          (Unit.isEq (1,42) (StencilVector.get sv 1))
                  , Unit.it "provides value with getOrDefault [1]" (Unit.isEq (1,42) (StencilVector.getOrDefault sv 1 (-1)))
                  , Unit.it "has no other members" [
                        Unit.isFalse (StencilVector.mem sv 2)
                      , Unit.isFalse (StencilVector.mem sv 3)
                      , Unit.isFalse (StencilVector.mem sv 4)
                      , Unit.isFalse (StencilVector.mem sv 7)
                      , Unit.isFalse (StencilVector.mem sv 16)
                      , Unit.isFalse (StencilVector.mem sv 30)
                      , Unit.isFalse (StencilVector.mem sv 31)
                    ]
                  , Unit.it "provides default with getOrDefault [2]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 2 (-1)))
                  , Unit.it "provides default with getOrDefault [4]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 4 (-1)))
                  , Unit.it "is valid"           (Unit.isTrue (StencilVector.valid sv))
                  , Unit.it "is not null"        (Unit.isFalse (StencilVector.null sv))
                  , Unit.it "has 3 as its mask"  (Unit.isEq 3 (StencilVector.mask sv))
                  , Unit.it "has length 2"       (Unit.isEq 2 (StencilVector.length sv))
                ]
            end,
            let val sv = StencilVector.set (StencilVector.singleton 1 (1,42)) 0 (0,21)
            in Unit.group "set (singleton 1 (1,42)) 0 (0,21)" [
                    Unit.it "has a member at [0]" (Unit.isTrue (StencilVector.mem sv 0))
                  , Unit.it "provides value with get [0]"          (Unit.isEq (0,21) (StencilVector.get sv 0))
                  , Unit.it "provides value with getOrDefault [0]" (Unit.isEq (0,21) (StencilVector.getOrDefault sv 0 (-1)))
                  , Unit.it "has a member at [1]" (Unit.isTrue (StencilVector.mem sv 1))
                  , Unit.it "provides value with get [1]"          (Unit.isEq (1,42) (StencilVector.get sv 1))
                  , Unit.it "provides value with getOrDefault [1]" (Unit.isEq (1,42) (StencilVector.getOrDefault sv 1 (-1)))
                  , Unit.it "has no other members" [
                        Unit.isFalse (StencilVector.mem sv 2)
                      , Unit.isFalse (StencilVector.mem sv 3)
                      , Unit.isFalse (StencilVector.mem sv 4)
                      , Unit.isFalse (StencilVector.mem sv 7)
                      , Unit.isFalse (StencilVector.mem sv 16)
                      , Unit.isFalse (StencilVector.mem sv 30)
                      , Unit.isFalse (StencilVector.mem sv 31)
                    ]
                  , Unit.it "provides default with getOrDefault [2]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 2 (-1)))
                  , Unit.it "provides default with getOrDefault [4]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 4 (-1)))
                  , Unit.it "is valid"           (Unit.isTrue (StencilVector.valid sv))
                  , Unit.it "is not null"        (Unit.isFalse (StencilVector.null sv))
                  , Unit.it "has 3 as its mask"  (Unit.isEq 3 (StencilVector.mask sv))
                  , Unit.it "has length 2"       (Unit.isEq 2 (StencilVector.length sv))
                ]
            end,
            let val sv = StencilVector.set (StencilVector.set (StencilVector.singleton 0 (0,true)) 1 (1,42)) 0 (0,false)
            in Unit.group "set (set (singleton 0 (0,true)) 1 (1,42)) 0 (0,false)" [
                    Unit.it "has a member at [0]" (Unit.isTrue (StencilVector.mem sv 0))
                  , Unit.it "provides value with get [0]"          (Unit.isEq (0,false) (StencilVector.get sv 0))
                  , Unit.it "provides value with getOrDefault [0]" (Unit.isEq (0,false) (StencilVector.getOrDefault sv 0 (-1)))
                  , Unit.it "has a member at [1]" (Unit.isTrue (StencilVector.mem sv 1))
                  , Unit.it "provides value with get [1]"          (Unit.isEq (1,42) (StencilVector.get sv 1))
                  , Unit.it "provides value with getOrDefault [1]" (Unit.isEq (1,42) (StencilVector.getOrDefault sv 1 (-1)))
                  , Unit.it "has no other members" [
                        Unit.isFalse (StencilVector.mem sv 2)
                      , Unit.isFalse (StencilVector.mem sv 3)
                      , Unit.isFalse (StencilVector.mem sv 4)
                      , Unit.isFalse (StencilVector.mem sv 7)
                      , Unit.isFalse (StencilVector.mem sv 16)
                      , Unit.isFalse (StencilVector.mem sv 30)
                      , Unit.isFalse (StencilVector.mem sv 31)
                    ]
                  , Unit.it "provides default with getOrDefault [2]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 2 (-1)))
                  , Unit.it "provides default with getOrDefault [4]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 4 (-1)))
                  , Unit.it "is valid"           (Unit.isTrue (StencilVector.valid sv))
                  , Unit.it "is not null"        (Unit.isFalse (StencilVector.null sv))
                  , Unit.it "has 3 as its mask"  (Unit.isEq 3 (StencilVector.mask sv))
                  , Unit.it "has length 2"       (Unit.isEq 2 (StencilVector.length sv))
                ]
            end,
            let val sv = StencilVector.set (StencilVector.singleton 1 42) 3 21
            in Unit.group "set (singleton 1 42) 3 21" [
                    Unit.it "has a member at [1]" (Unit.isTrue (StencilVector.mem sv 1))
                  , Unit.it "provides value with get [1]"          (Unit.isEq 42 (StencilVector.get sv 1))
                  , Unit.it "provides value with getOrDefault [1]" (Unit.isEq 42 (StencilVector.getOrDefault sv 1 (-1)))
                  , Unit.it "has a member at [3]" (Unit.isTrue (StencilVector.mem sv 3))
                  , Unit.it "provides value with get [3]"          (Unit.isEq 21 (StencilVector.get sv 3))
                  , Unit.it "provides value with getOrDefault [1]" (Unit.isEq 21 (StencilVector.getOrDefault sv 3 (-1)))
                  , Unit.it "has no other members" [
                        Unit.isFalse (StencilVector.mem sv 0)
                      , Unit.isFalse (StencilVector.mem sv 2)
                      , Unit.isFalse (StencilVector.mem sv 4)
                      , Unit.isFalse (StencilVector.mem sv 7)
                      , Unit.isFalse (StencilVector.mem sv 16)
                      , Unit.isFalse (StencilVector.mem sv 30)
                      , Unit.isFalse (StencilVector.mem sv 31)
                    ]
                  , Unit.it "provides default with getOrDefault [2]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 2 (-1)))
                  , Unit.it "provides default with getOrDefault [4]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 4 (-1)))
                  , Unit.it "is valid"           (Unit.isTrue (StencilVector.valid sv))
                  , Unit.it "is not null"        (Unit.isFalse (StencilVector.null sv))
                  , Unit.it "has 10 as its mask" (Unit.isEq 10 (StencilVector.mask sv))
                  , Unit.it "has length 2"       (Unit.isEq 2 (StencilVector.length sv))
                ]
            end,
            let val sv = StencilVector.set (StencilVector.singleton 2 false) 2 true
            in Unit.group "set (singleton 2 false) 2 true" [
                    Unit.it "has a member at [2]" (Unit.isTrue (StencilVector.mem sv 2))
                  , Unit.it "provides value with get [2]" (Unit.isEq true (StencilVector.get sv 2))
                  , Unit.it "has no other members" [
                        Unit.isFalse (StencilVector.mem sv 0)
                      , Unit.isFalse (StencilVector.mem sv 1)
                      , Unit.isFalse (StencilVector.mem sv 3)
                      , Unit.isFalse (StencilVector.mem sv 4)
                      , Unit.isFalse (StencilVector.mem sv 7)
                      , Unit.isFalse (StencilVector.mem sv 16)
                      , Unit.isFalse (StencilVector.mem sv 30)
                      , Unit.isFalse (StencilVector.mem sv 31)
                    ]
                  , Unit.it "is valid"          (Unit.isTrue (StencilVector.valid sv))
                  , Unit.it "is not null"       (Unit.isFalse (StencilVector.null sv))
                  , Unit.it "has 4 as its mask" (Unit.isEq 4 (StencilVector.mask sv))
                  , Unit.it "has length 1"      (Unit.isEq 1 (StencilVector.length sv))
                ]
            end,
            let val sv = StencilVector.unset (StencilVector.singleton 7 42) 7
            in Unit.group "unset (singleton 7 42) 7" [
                    Unit.it "is equivalent to (empty)" (Unit.isEq StencilVector.empty sv)
                ]
            end,
            let val sv = StencilVector.unset (StencilVector.set (StencilVector.singleton 2 false) 4 true) 4
            in Unit.group "unset (set (singleton 2 false) 4 true) 2" [
                    Unit.it "is equivalent to (singleton 2 false)" (Unit.isEq (StencilVector.singleton 2 false) sv)
                  , Unit.it "provides value with getOrDefault [2]" (Unit.isEq false (StencilVector.getOrDefault sv 2 (-1)))
                  , Unit.it "provides default with getOrDefault [4]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 4 (-1)))
                ]
            end,
            let val sv = StencilVector.unset (StencilVector.set (StencilVector.set (StencilVector.empty) 2 false) 4 true) 2
            in Unit.group "unset (set (set (empty) 2 false) 4 true) 2" [
                    Unit.it "is equivalent to (singleton 4 true)" (Unit.isEq (StencilVector.singleton 4 true) sv)
                  , Unit.it "provides default with getOrDefault [2]" (Unit.isEq (-1) (StencilVector.getOrDefault sv 2 (-1)))
                  , Unit.it "provides value with getOrDefault [4]" (Unit.isEq true (StencilVector.getOrDefault sv 4 (-1)))
                ]
            end,
            let fun inc x = x+1
                fun dec x = x-1
            in Unit.group "map (+/- 1)" [
                    Unit.it "does nothing to (empty)" (Unit.isEq StencilVector.empty (StencilVector.map inc StencilVector.empty))
                  , let val sv  = StencilVector.singleton 2 1
                        val sv' = StencilVector.map inc (StencilVector.singleton 2 0)
                    in Unit.it "can increment (singleton 2 0)" (Unit.isEq sv sv')
                    end
                  , let val sv  = StencilVector.set (StencilVector.singleton 1 2) 3 3
                        val sv' = StencilVector.map inc (StencilVector.set (StencilVector.singleton 1 1) 3 2)
                    in Unit.it "can increment (set (singleton 1 1) 3 2)" (Unit.isEq sv sv')
                    end
                  , let val sv  = StencilVector.set (StencilVector.singleton 1 0) 3 1
                        val sv' = StencilVector.map dec (StencilVector.set (StencilVector.singleton 1 1) 3 2)
                    in Unit.it "can decrement (set (singleton 1 1) 3 2)" (Unit.isEq sv sv')
                    end
                ]
            end,
            let fun sum (x,y) = x+y
            in Unit.group "fold (+)" [
                    Unit.it "returns initial value for (empty)" (Unit.isEq 0 (StencilVector.fold sum 0 StencilVector.empty))
                  , let val sv = StencilVector.singleton 4 42
                    in Unit.it "computes 42 for (singleton 4 42)" (Unit.isEq 42 (StencilVector.fold sum 0 sv))
                    end
                  , let val sv = StencilVector.set (StencilVector.singleton 4 42) 2 21
                    in Unit.it "computes 64 for (set (singleton 4 42) 2 21)" (Unit.isEq 63 (StencilVector.fold sum 0 sv))
                    end
                ]
            end
        ]
in Unit.run authority tests end
