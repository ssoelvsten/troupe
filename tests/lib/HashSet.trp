import Unit
import Hash
import HashSet

let val empty     = HashSet.empty Hash.hash
    val singleton = HashSet.singleton Hash.hash
    fun insert s  = HashSet.insert s authority
    fun remove s  = HashSet.remove s authority
    fun mem    s  = HashSet.mem s authority
    val fromList  = HashSet.fromList Hash.hash authority

    val tests = Unit.group "HashSet" [
            (* -- Empty, size, and mem -- *)
            let val m = empty
            in Unit.group "empty" [
                    Unit.it "is null"                           (Unit.isTrue  (HashSet.null m))
                  , Unit.it "has size 0"                        (Unit.isEq 0  (HashSet.size m))
                  , Unit.it "does not contain 0"                (Unit.isFalse (mem m 0))
                  , Unit.it "does not contain 1"                (Unit.isFalse (mem m 1))
                ]
            end,
            (* -- Insert / Singleton, size, and mem -- *)
            let val m = insert (empty) 0
            in Unit.group "insert (empty) 0" [
                    Unit.it "is not null"                (Unit.isFalse   (HashSet.null m))
                  , Unit.it "has size 1"                 (Unit.isEq 1    (HashSet.size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (mem m 0))
                  , Unit.it "does not contain 1"         (Unit.isFalse   (mem m 1))
                ]
            end,
            let val m = singleton 0
            in Unit.group "singleton 0" [
                    Unit.it "is equivalent to 'insert (empty) 0'"
                            (Unit.isEq (insert empty 0) m)
                ]
            end,
            (* -- Insert (fromList), size, and mem -- *)
            let val m = fromList [0]
            in Unit.group "fromList [0]" [
                    Unit.it "is equivalent to 'insert (empty) 0'"
                            (Unit.isEq (insert empty 0) m)
                    ]
            end,
            let val m = fromList [1]
            in Unit.group "fromList [1]" [
                    Unit.it "is not null"                (Unit.isFalse   (HashSet.null m))
                  , Unit.it "has size 1"                 (Unit.isEq 1    (HashSet.size m))
                  , Unit.it "does not contain 0"         (Unit.isFalse   (mem m 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (mem m 1))
                ]
            end,
            let val m = insert (fromList [0]) 0
            in Unit.group "insert (fromList [0]) 0" [
                    Unit.it "is not null"                 (Unit.isFalse   (HashSet.null m))
                  , Unit.it "has size 1"                  (Unit.isEq 1    (HashSet.size m))
                  , Unit.it "contains 0"                  (Unit.isTrue    (mem m 0))
                  , Unit.it "does not contain 1"          (Unit.isFalse   (mem m 1))
                ]
            end,
            let val m = fromList [1, 0]
            in Unit.group "fromList [1, 0]" [
                    Unit.it "is not null"                (Unit.isFalse   (HashSet.null m))
                  , Unit.it "has size 2"                 (Unit.isEq 2    (HashSet.size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (mem m 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (mem m 1))
                ]
            end,
            let val m = fromList [0, 1]
            in Unit.group "fromList [1, 0]" [
                    Unit.it "is not null"                (Unit.isFalse   (HashSet.null m))
                  , Unit.it "has size 2"                 (Unit.isEq 2    (HashSet.size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (mem m 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (mem m 1))
                ]
            end,
            (* -- Insert (fromList), delete, size, and findOpt (mem and find) -- *)
            let val m  = remove (fromList [0]) 0
                val exp = fromList []
            in Unit.group "remove (fromList [0]) 0" [
                    Unit.it "is equivalent to fromList []" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [0, 1]) 0
                val exp = fromList [1]
            in Unit.group "remove (fromList [0, 1]) 0" [
                    Unit.it "is equivalent to fromList [1]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [0, 1]) 1
                val exp = fromList [0]
            in Unit.group "remove (fromList [0, 1]) 1" [
                    Unit.it "is equivalent to fromList [0]" (Unit.isEq exp m)
                ]
            end,
            (* -- keys, values, and toList -- *)
            (* NOTE: Failure in these tests may also be due to changes to the traversal order in
             *       'HashSet.fold' or changes to `Hash.hash`. *)
            Unit.group "elems / toList" [
                let val m   = fromList []
                in Unit.it "converts []" [
                        (Unit.isEq [] (HashSet.elems m))
                      , (Unit.isEq [] (HashSet.toList m))
                    ]
                end
              , let val m   = fromList [0]
                in Unit.it "converts [0]" [
                        (Unit.isEq [0] (HashSet.elems m))
                      , (Unit.isEq [0] (HashSet.toList m))
                    ]
                end
              , let val m   = fromList [0, 1]
                in Unit.it "converts [0, 1]" [
                        (Unit.isEq [1, 0] (HashSet.elems m))
                      , (Unit.isEq [1, 0] (HashSet.toList m))
                    ]
                end
            ]
        ]
in Unit.run authority tests end
