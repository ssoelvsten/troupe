import Unit
import Hash
import HashSet

let val empty     = HashSet.empty Hash.hash
    val singleton = HashSet.singleton Hash.hash
    val fromList  = HashSet.fromList Hash.hash

    val tests = group "HashSet" [
            (* -- Empty, size, and mem -- *)
            let val m = empty
            in group "empty" [
                    it "is null"                           (isTrue  (null m))
                  , it "has size 0"                        (isEq 0  (size m))
                  , it "does not contain 0"                (isFalse (mem m 0))
                  , it "does not contain 1"                (isFalse (mem m 1))
                ]
            end,
            (* -- Insert / Singleton, size, and mem -- *)
            let val m = insert (empty) 0
            in group "insert (empty) 0" [
                    it "is not null"                (isFalse   (null m))
                  , it "has size 1"                 (isEq 1    (size m))
                  , it "contains 0"                 (isTrue    (mem m 0))
                  , it "does not contain 1"         (isFalse   (mem m 1))
                ]
            end,
            let val m = singleton 0
            in group "singleton 0" [
                    it "is equivalent to 'insert (empty) 0'"
                            (isEq (insert empty 0) m)
                ]
            end,
            (* -- Insert (fromList), size, and mem -- *)
            let val m = fromList [0]
            in group "fromList [0]" [
                    it "is equivalent to 'insert (empty) 0'"
                            (isEq (insert empty 0) m)
                    ]
            end,
            let val m = fromList [1]
            in group "fromList [1]" [
                    it "is not null"                (isFalse   (null m))
                  , it "has size 1"                 (isEq 1    (size m))
                  , it "does not contain 0"         (isFalse   (mem m 0))
                  , it "contains 1"                 (isTrue    (mem m 1))
                ]
            end,
            let val m = insert (fromList [0]) 0
            in group "insert (fromList [0]) 0" [
                    it "is not null"                 (isFalse   (null m))
                  , it "has size 1"                  (isEq 1    (size m))
                  , it "contains 0"                  (isTrue    (mem m 0))
                  , it "does not contain 1"          (isFalse   (mem m 1))
                ]
            end,
            let val m = fromList [1, 0]
            in group "fromList [1, 0]" [
                    it "is not null"                (isFalse   (null m))
                  , it "has size 2"                 (isEq 2    (size m))
                  , it "contains 0"                 (isTrue    (mem m 0))
                  , it "contains 1"                 (isTrue    (mem m 1))
                ]
            end,
            let val m = fromList [0, 1]
            in group "fromList [1, 0]" [
                    it "is not null"                (isFalse   (null m))
                  , it "has size 2"                 (isEq 2    (size m))
                  , it "contains 0"                 (isTrue    (mem m 0))
                  , it "contains 1"                 (isTrue    (mem m 1))
                ]
            end,
            (* -- Insert (fromList), delete, size, and findOpt (mem and find) -- *)
            let val m  = remove (fromList [0]) 0
                val exp = fromList []
            in group "remove (fromList [0]) 0" [
                    it "is equivalent to fromList []" (isEq exp m)
                ]
            end,
            let val m   = remove (fromList [0, 1]) 0
                val exp = fromList [1]
            in group "remove (fromList [0, 1]) 0" [
                    it "is equivalent to fromList [1]" (isEq exp m)
                ]
            end,
            let val m   = remove (fromList [0, 1]) 1
                val exp = fromList [0]
            in group "remove (fromList [0, 1]) 1" [
                    it "is equivalent to fromList [0]" (isEq exp m)
                ]
            end,
            (* -- keys, values, and toList -- *)
            (* NOTE: Failure in these tests may also be due to changes to the traversal order in
             *       'fold' or changes to `hash`. *)
            group "elems / toList" [
                let val m   = fromList []
                in it "converts []" [
                        (isEq [] (elems m))
                      , (isEq [] (toList m))
                    ]
                end
              , let val m   = fromList [0]
                in it "converts [0]" [
                        (isEq [0] (elems m))
                      , (isEq [0] (toList m))
                    ]
                end
              , let val m   = fromList [0, 1]
                in it "converts [0, 1]" [
                        (isEq [1, 0] (elems m))
                      , (isEq [1, 0] (toList m))
                    ]
                end
            ]
        ]
in run authority tests end
