import Unit
import String

let val tests = group "String" [
            group "size" [
                it "is 0 for ''"         (isEq 0 (size ""))
              , it "is 1 for 'a'"        (isEq 1 (size "a"))
              , it "is 1 for 'b'"        (isEq 1 (size "b"))
              , it "is 5 for 'Hello'"    (isEq 5 (size "Hello"))
              , it "is 7 for 'Troupe!'"  (isEq 7 (size "Troupe!"))
            ],
            let val s = "Hello"
            in group "sub" [
                    it "is 'H' for 0" (isEq "H" (sub (s, 0)))
                  , it "is 'e' for 1" (isEq "e" (sub (s, 1)))
                  , it "is 'l' for 2" (isEq "l" (sub (s, 2)))
                  , it "is 'l' for 3" (isEq "l" (sub (s, 3)))
                  , it "is 'o' for 4" (isEq "o" (sub (s, 4)))
                  , it "is ''  for 5" (isEq ""  (sub (s, 5)))
                  , it "is ''  for 6" (isEq ""  (sub (s, 6)))
                ]
            end,
            let val s = "World!"
            in group "subCode" [
                    it "is 87 for 0"  (isEq 87  (subCode (s,0)))
                  , it "is 111 for 1" (isEq 111 (subCode (s,1)))
                  , it "is 114 for 2" (isEq 114 (subCode (s,2)))
                  , it "is 108 for 3" (isEq 108 (subCode (s,3)))
                  , it "is 100 for 4" (isEq 100 (subCode (s,4)))
                  , it "is 33  for 5" (isEq 33  (subCode (s,5)))
                  , it "is 0   for 6" (isEq 0   (subCode (s,6)))
                ]
            end,
            let val s = "Hello Troupe!"
            in group "substring" [
                    it "is 'Hello' for 0 5"    (isEq "Hello" (substring (s, 0, 5)))
                  , it "is 'Troupe' for 6 12"  (isEq "Troupe" (substring (s, 6, 12)))
                  , it "is 'Troupe!' for 6 13" (isEq "Troupe!" (substring (s, 6, 13)))
                  , it "is 'Troupe!' for 6 14" (isEq "Troupe!" (substring (s, 6, 13)))
                ]
            end,
            group "concat" [
                it "is '' for []"           (isEq ""   (concat []))
              , it "is 'a' for ['a']"       (isEq "a"  (concat ["a"]))
              , it "is 'a' for ['', 'a']"   (isEq "a"  (concat ["", "a"]))
              , it "is 'a' for ['a', '']"   (isEq "a"  (concat ["a", ""]))
              , it "is 'ab' for ['a', 'b']" (isEq "ab" (concat ["a", "b"]))
            ],
            group "concatWith" [
                it "is '' for []"                       (isEq ""      (concatWith "," []))
              , it "skips separator for ['a']"          (isEq "a"     (concatWith "," ["a"]))
              , it "skips separator for ['b']"          (isEq "b"     (concatWith "," ["b"]))
              , it "adds separator for ['a', 'b']"      (isEq "a,b"   (concatWith "," ["a", "b"]))
              , it "adds separator for ['a', 'b', 'c']" (isEq "a,b,c" (concatWith "," ["a", "b","c"]))
              , it "adds separator around '' too"       (isEq "a..b"  (concatWith "." ["a","", "b"]))
            ],
            group "implode" [
                it "is '' for []"           (isEq ""    (implode []))
              , it "is 'a' for ['a']"       (isEq "a"   (implode ["a"]))
              , it "is 'b' for ['b']"       (isEq "b"   (implode ["b"]))
              , it "is 'ab' for ['a','b']"  (isEq "ab"  (implode ["a","b"]))
              , it "is 'ba' for ['b','a']"  (isEq "ba"  (implode ["b","a"]))
            ],
            group "explode" [
                it "is [] for ''"           (isEq []        (explode ""))
              , it "is ['a'] for 'a'"       (isEq ["a"]     (explode "a"))
              , it "is ['b'] for 'b'"       (isEq ["b"]     (explode "b"))
              , it "is ['a','b'] for 'ab'"  (isEq ["a","b"] (explode "ab"))
              , it "is ['b','a'] for 'ba'"  (isEq ["b","a"] (explode "ba"))
            ],
            let fun f "a" = "b"
                  | f "b" = "a"
                  | f c   = c
            in group "map" [
                    it "is '' for ''"       (isEq ""   (map f ""))
                  , it "is 'b' for 'a'"     (isEq "b"  (map f "a"))
                  , it "is 'a' for 'b'"     (isEq "a"  (map f "b"))
                  , it "is 'ba' for 'ab'"   (isEq "ba" (map f "ab"))
                  , it "is 'a b' for 'b a'" (isEq "a b" (map f "b a"))
                ]
            end,
            let fun f c = c ^ "_"
            in group "translate" [
                    it "is '' for ''"       (isEq ""     (translate f ""))
                  , it "is 'a_' for 'a'"    (isEq "a_"   (translate f "a"))
                  , it "is 'b_' for 'b'"    (isEq "b_"   (translate f "b"))
                  , it "is 'a_b_' for 'ab'" (isEq "a_b_" (translate f "ab"))
                  , it "is 'b_a_' for 'ba'" (isEq "b_a_" (translate f "ba"))
                ]
            end
        ]
in run authority tests end
