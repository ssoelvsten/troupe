import Hash

let (* Tests for 'hashString' *)
    val _ = print ""
    val _ = print ("Hash.hashString ''   = " ^ (intToString (Hash.hashString "")))
    val _ = print ("Hash.hashString 'a'  = " ^ (intToString (Hash.hashString "a")))
    val _ = print ("Hash.hashString 'b'  = " ^ (intToString (Hash.hashString "b")))
    val _ = print ("Hash.hashString 'c'  = " ^ (intToString (Hash.hashString "c")))
    val _ = print ("Hash.hashString 'aa' = " ^ (intToString (Hash.hashString "aa")))
    val _ = print ("Hash.hashString 'ab' = " ^ (intToString (Hash.hashString "ab")))
    val _ = print ("Hash.hashString 'ba' = " ^ (intToString (Hash.hashString "ba")))
    val _ = print ("Hash.hashString 'bb' = " ^ (intToString (Hash.hashString "bb")))
    val _ = print ("Hash.hashString 'bc' = " ^ (intToString (Hash.hashString "bc")))
    val _ = print ("Hash.hashString 'cb' = " ^ (intToString (Hash.hashString "cb")))
    val _ = print ("Hash.hashString 'ac' = " ^ (intToString (Hash.hashString "ac")))
    val _ = print ("Hash.hashString 'ca' = " ^ (intToString (Hash.hashString "ca")))
    val _ = print ("Hash.hashString 'aslan'  = " ^ (intToString (Hash.hashString "aslan")))
    val _ = print ("Hash.hashString 'ananas' = " ^ (intToString (Hash.hashString "ananas")))
    val _ = print ("Hash.hashString 'banana' = " ^ (intToString (Hash.hashString "banana")))

    (* Tests for 'hashMultiplyShift' *)
    val _ = print ("Hash.hashMultiplyShift -42 31   = " ^ (intToString (Hash.hashMultiplyShift (-42)  31  )))
    val _ = print ("Hash.hashMultiplyShift -42 16   = " ^ (intToString (Hash.hashMultiplyShift (-42)  16  )))
    val _ = print ("Hash.hashMultiplyShift -1  31   = " ^ (intToString (Hash.hashMultiplyShift (-1)   31  )))
    val _ = print ("Hash.hashMultiplyShift  0  31   = " ^ (intToString (Hash.hashMultiplyShift  0     31  )))
    val _ = print ("Hash.hashMultiplyShift  1  -1   = " ^ (intToString (Hash.hashMultiplyShift  1    (-1))))
    val _ = print ("Hash.hashMultiplyShift  1   0   = " ^ (intToString (Hash.hashMultiplyShift  1      0  )))
    val _ = print ("Hash.hashMultiplyShift  1   3   = " ^ (intToString (Hash.hashMultiplyShift  1      3  )))
    val _ = print ("Hash.hashMultiplyShift  1   8   = " ^ (intToString (Hash.hashMultiplyShift  1      8  )))
    val _ = print ("Hash.hashMultiplyShift  1  31   = " ^ (intToString (Hash.hashMultiplyShift  1     31  )))
    val _ = print ("Hash.hashMultiplyShift  42  8   = " ^ (intToString (Hash.hashMultiplyShift  42     8  )))
    val _ = print ("Hash.hashMultiplyShift  42  8.5 = " ^ (intToString (Hash.hashMultiplyShift  42   (17/2))))
    val _ = print ("Hash.hashMultiplyShift  42 12   = " ^ (intToString (Hash.hashMultiplyShift  42    12  )))
    val _ = print ("Hash.hashMultiplyShift  42 31   = " ^ (intToString (Hash.hashMultiplyShift  42    31  )))

    (* Tests for 'Hash.hashInt' *)
    val _ = print ""
    val _ = print ("Hash.hashInt -100 = " ^ (intToString (Hash.hashInt (-100))))
    val _ = print ("Hash.hashInt -11  = " ^ (intToString (Hash.hashInt (-11))))
    val _ = print ("Hash.hashInt -10  = " ^ (intToString (Hash.hashInt (-10))))
    val _ = print ("Hash.hashInt -7   = " ^ (intToString (Hash.hashInt (-7))))
    val _ = print ("Hash.hashInt -5   = " ^ (intToString (Hash.hashInt (-5))))
    val _ = print ("Hash.hashInt -3   = " ^ (intToString (Hash.hashInt (-3))))
    val _ = print ("Hash.hashInt -2   = " ^ (intToString (Hash.hashInt (-2))))
    val _ = print ("Hash.hashInt -1   = " ^ (intToString (Hash.hashInt (-1))))
    val _ = print ("Hash.hashInt  0   = " ^ (intToString (Hash.hashInt  0)))
    val _ = print ("Hash.hashInt  1   = " ^ (intToString (Hash.hashInt  1)))
    val _ = print ("Hash.hashInt  2   = " ^ (intToString (Hash.hashInt  2)))
    val _ = print ("Hash.hashInt  3   = " ^ (intToString (Hash.hashInt  3)))
    val _ = print ("Hash.hashInt  4   = " ^ (intToString (Hash.hashInt  4)))
    val _ = print ("Hash.hashInt  5   = " ^ (intToString (Hash.hashInt  5)))
    val _ = print ("Hash.hashInt  6   = " ^ (intToString (Hash.hashInt  6)))
    val _ = print ("Hash.hashInt  7   = " ^ (intToString (Hash.hashInt  7)))
    val _ = print ("Hash.hashInt  8   = " ^ (intToString (Hash.hashInt  8)))
    val _ = print ("Hash.hashInt  9   = " ^ (intToString (Hash.hashInt  9)))
    val _ = print ("Hash.hashInt  10  = " ^ (intToString (Hash.hashInt  10)))
    val _ = print ("Hash.hashInt  11  = " ^ (intToString (Hash.hashInt  11)))
    val _ = print ("Hash.hashInt  13  = " ^ (intToString (Hash.hashInt  13)))
    val _ = print ("Hash.hashInt  42  = " ^ (intToString (Hash.hashInt  42)))
    val _ = print ("Hash.hashInt  63  = " ^ (intToString (Hash.hashInt  63)))
    val _ = print ("Hash.hashInt  64  = " ^ (intToString (Hash.hashInt  64)))
    val _ = print ("Hash.hashInt  100 = " ^ (intToString (Hash.hashInt  100)))
    val _ = print ("Hash.hashInt  127 = " ^ (intToString (Hash.hashInt  127)))

    (* Tests for 'Hash.hashNumber' *)
    val _ = print ""
    val _ = print ("Hash.hashNumber 1/4  = " ^ (intToString (Hash.hashNumber (1/4))))
    val _ = print ("Hash.hashNumber 1/3  = " ^ (intToString (Hash.hashNumber (1/3))))
    val _ = print ("Hash.hashNumber 1/2  = " ^ (intToString (Hash.hashNumber (1/2))))
    val _ = print ("Hash.hashNumber   1  = " ^ (intToString (Hash.hashNumber  1)))
    val _ = print ("Hash.hashNumber 4/3  = " ^ (intToString (Hash.hashNumber (4/3))))
    val _ = print ("Hash.hashNumber 4/2  = " ^ (intToString (Hash.hashNumber (4/2))))
    val _ = print ("Hash.hashNumber 5/2  = " ^ (intToString (Hash.hashNumber (5/2))))
    val _ = print ("Hash.hashNumber 21/2 = " ^ (intToString (Hash.hashNumber (21/2))))

    (* Tests for 'hash' *)
    val _ = print ""
    val _ = print ("hash 0    = " ^ (intToString (hash 0)))
    val _ = print ("hash 42   = " ^ (intToString (hash 42)))
    val _ = print ("hash 21/2 = " ^ (intToString (hash (21/2))))
    val _ = print ("hash 100  = " ^ (intToString (hash 100)))
    val _ = print ("hash ''   = " ^ (intToString (hash "")))
    val _ = print ("hash 'a'  = " ^ (intToString (hash "a")))
    val _ = print ("hash 'ba' = " ^ (intToString (hash "ba")))

in () end
