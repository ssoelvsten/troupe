import Unit
import Hash
import HashMap

let (* Hash based on the lowest ten bits only. This way we can easily force various scenarios. *)
    fun hf x = x andb ((1 << 10) -1)

    val empty     = HashMap.empty hf
    val singleton = HashMap.singleton hf
    val fromList  = HashMap.fromList hf

    val tests = group "HashMap" [
            (* -- Empty, size, and findOpt (mem, find) -- *)
            let val m = empty
            in group "empty" [
                    it "is null"                           (isTrue  (null m))
                  , it "has size 0"                        (isEq 0  (size m))
                  , it "does not contain 0"                (isFalse (mem m 0))
                  , it "returns [] for findOpt 0"          (isEq [] (findOpt m 0))
                  , it "does not contain 1"                (isFalse (mem m 1))
                  , it "returns [] for findOpt 1"          (isEq [] (findOpt m 1))
                  , it "is not equal to 'empty Hash.hash'" (isNeq (HashMap.empty Hash.hash) m)
                ]
            end,
            (* -- Insert / Singleton, size, and findOpt (mem, find) -- *)
            let val m = insert (empty) 0 42
            in group "insert (empty) 0 42" [
                    it "is not null"                (isFalse   (null m))
                  , it "has size 1"                 (isEq 1    (size m))
                  , it "contains 0"                 (isTrue    (mem m 0))
                  , it "returns [42] for findOpt 0" (isEq [42] (findOpt m 0))
                  , it "returns 42 for find 0"      (isEq 42   (find m 0))
                  , it "does not contain 1"         (isFalse   (mem m 1))
                  , it "returns [] for findOpt 1"   (isEq []   (findOpt m 1))
                ]
            end,
            let val m = singleton 0 42
            in group "singleton 0 42" [
                    it "is equivalent to 'insert (empty) 0 42'"
                            (isEq (insert empty 0 42) m)
                ]
            end,
            (* -- Insert (fromList), size, and findOpt (mem, find) -- *)
            let val m = fromList [(0,42)]
            in group "fromList [(0,42)]" [
                    it "is equivalent to 'insert (empty) 0 42'"
                            (isEq (insert empty 0 42) m)
                    ]
            end,
            let val m = fromList [(1,42)]
            in group "fromList [(1,42)]" [
                    it "is not null"                (isFalse   (null m))
                  , it "has size 1"                 (isEq 1    (size m))
                  , it "does not contain 0"         (isFalse   (mem m 0))
                  , it "returns [] for findOpt 0"   (isEq []   (findOpt m 0))
                  , it "contains 1"                 (isTrue    (mem m 1))
                  , it "returns [42] for findOpt 1" (isEq [42] (findOpt m 1))
                  , it "returns 42 for find 1"      (isEq 42   (find m 1))
                ]
            end,
            let val m = insert (fromList [(0,42)]) 0 "a"
            in group "insert (fromList [(0,42)]) 0 'a'" [
                    it "is not null"                 (isFalse   (null m))
                  , it "has size 1"                  (isEq 1    (size m))
                  , it "contains 0"                  (isTrue    (mem m 0))
                  , it "returns ['a'] for findOpt 0" (isEq ["a"] (findOpt m 0))
                  , it "returns 'a' for find 0"      (isEq "a"   (find m 0))
                  , it "does not contain 1"          (isFalse   (mem m 1))
                  , it "returns [] for findOpt 1"    (isEq []   (findOpt m 1))
                ]
            end,
            let val m = fromList [(1,42), (0,21)]
            in group "fromList [(1,42), (0,21)]" [
                    it "is not null"                (isFalse   (null m))
                  , it "has size 2"                 (isEq 2    (size m))
                  , it "contains 0"                 (isTrue    (mem m 0))
                  , it "returns [21] for findOpt 0" (isEq [21] (findOpt m 0))
                  , it "returns 21 for find 0"      (isEq 21   (find m 0))
                  , it "contains 1"                 (isTrue    (mem m 1))
                  , it "returns [42] for findOpt 1" (isEq [42] (findOpt m 1))
                  , it "returns 42 for find 1"      (isEq 42   (find m 1))
                ]
            end,
            let val m = fromList [(0,21),(1,42)]
            in group "fromList [(1,42), (0,21)]" [
                    it "is not null"                (isFalse   (null m))
                  , it "has size 2"                 (isEq 2    (size m))
                  , it "contains 0"                 (isTrue    (mem m 0))
                  , it "returns [21] for findOpt 0" (isEq [21] (findOpt m 0))
                  , it "returns 21 for find 0"      (isEq 21   (find m 0))
                  , it "contains 1"                 (isTrue    (mem m 1))
                  , it "returns [42] for findOpt 1" (isEq [42] (findOpt m 1))
                  , it "returns 42 for find 1"      (isEq 42   (find m 1))
                ]
            end,
            let val m = fromList [(1024,42), (0,21), (2048,"a")]
            in group "fromList [(1024,42), (0,21), (2048,'a')] (collision)" [
                    it "is not null"                    (isFalse    (null m))
                  , it "has size 3"                     (isEq 3     (size m))
                  , it "contains 0"                     (isTrue     (mem m 0))
                  , it "returns [21] for findOpt 0"     (isEq [21]  (findOpt m 0))
                  , it "returns 21 for find 0"          (isEq 21    (find m 0))
                  , it "contains 1024"                  (isTrue     (mem m 1024))
                  , it "returns [42] for findOpt 1024"  (isEq [42]  (findOpt m 1024))
                  , it "returns 42 for find 1024"       (isEq 42    (find m 1024))
                  , it "contains 2048"                  (isTrue     (mem m 2048))
                  , it "returns ['a'] for findOpt 2048" (isEq ["a"] (findOpt m 2048))
                  , it "returns 'a' for find 2048"      (isEq "a"   (find m 2048))
                ]
            end,
            let val m = fromList [(1024,42), (1,"a"), (0,21), (1025, "b")]
            in group "fromList [(1024,42), (1,'a'), (0,21), (1025,'b')] (collisions)" [
                    it "is not null"                    (isFalse    (null m))
                  , it "has size 4"                     (isEq 4     (size m))
                  , it "contains 0"                     (isTrue     (mem m 0))
                  , it "returns [21] for findOpt 0"     (isEq [21]  (findOpt m 0))
                  , it "returns 21 for find 0"          (isEq 21    (find m 0))
                  , it "contains 1"                     (isTrue     (mem m 1))
                  , it "returns ['b'] for findOpt 1"    (isEq ["a"] (findOpt m 1))
                  , it "returns 'b' for find 1"         (isEq "a"   (find m 1))
                  , it "contains 1024"                  (isTrue     (mem m 1024))
                  , it "returns [42] for findOpt 1024"  (isEq [42]  (findOpt m 1024))
                  , it "returns 42 for find 1024"       (isEq 42    (find m 1024))
                  , it "contains 1025"                  (isTrue     (mem m 1025))
                  , it "returns ['a'] for findOpt 1025" (isEq ["b"] (findOpt m 1025))
                  , it "returns 'a' for find 1025"      (isEq "b"   (find m 1025))
                  , it "does not contains 2"            (isFalse    (mem m 2))
                  , it "returns [] for findOpt 2"       (isEq []    (findOpt m 2))
                ]
            end,
            let val m  = fromList [(0,"a"), (1,"b"), (32,"c")]
            in group "fromList [(0,'a'), (1,'b'), (32,'c')] (trie of depth 2)" [
                    it "is not null"                        (isFalse    (null m))
                  , it "has size 3"                         (isEq 3     (size m))
                  , it "contains 0"                         (isTrue     (mem m 0))
                  , it "returns [21] for findOpt 0"         (isEq ["a"] (findOpt m 0))
                  , it "returns 21 for find 0"              (isEq "a"   (find m 0))
                  , it "contains 1"                         (isTrue     (mem m 1))
                  , it "returns ['b'] for findOpt 1"        (isEq ["b"] (findOpt m 1))
                  , it "returns 'b' for find 1"             (isEq "b"   (find m 1))
                  , it "contains 32"                        (isTrue     (mem m 32))
                  , it "returns ['c'] for findOpt 32"       (isEq ["c"] (findOpt m 32))
                  , it "returns 'c' for find 32"            (isEq "c"   (find m 32))
                  , it "does not contains 2"                (isFalse    (mem m 2))
                  , it "returns [] for findOpt 2"           (isEq []    (findOpt m 2))
                ]
            end,
            (* -- Insert (fromList), delete, size, and findOpt (mem and find) -- *)
            let val m  = remove (fromList [(0,42)]) 0
                val exp = fromList []
            in group "remove (fromList [(0,42)]) 0" [
                    it "is equivalent to fromList []" (isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21)]) 0
                val exp = fromList [(1,21)]
            in group "remove (fromList [(0,42), (1,21)]) 0" [
                    it "is equivalent to fromList [(1,21)]" (isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21)]) 1
                val exp = fromList [(0,42)]
            in group "remove (fromList [(0,42), (1,21)]) 1" [
                    it "is equivalent to fromList [(0,42)]" (isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21), (33,8)]) 0
                val exp = fromList [(1,21), (33,8)]
            in group "remove (fromList [(0,42), (1,21), (33,8)]) 0" [
                    it "is equivalent to fromList [(1,21), (33,8)]" (isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21), (33,8)]) 1
                val exp = fromList [(0,42), (33,8)]
            in group "remove (fromList [(0,42), (1,21), (33,8)]) 1" [
                    it "is equivalent to fromList [(0,42), (33,8)]" (isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21), (33,8)]) 33
                val exp = fromList [(0,42), (1,21)]
            in group "remove (fromList [(0,42), (1,21), (33,8)]) 33" [
                    it "is equivalent to fromList [(0,42), (1,21)]" (isEq exp m)
                ]
            end,
            let val m   = remove (remove (fromList [(0,42), (1,21), (33,8)]) 33) 1
                val exp = fromList [(0,42)]
            in group "remove (remove (fromList [(0,42), (1,21), (33,8)]) 33) 1" [
                    it "is equivalent to fromList [(0,42)]" (isEq exp m)
                ]
            end,
            (* -- keys, values, and toList -- *)
            (* NOTE: Failure in these tests may also be due to changes to the traversal order in
             *       'fold'. *)
            group "keys, values, and toList" [
                let val m   = fromList []
                in it "converts []" [
                        (isEq [] (keys m))
                      , (isEq [] (values m))
                      , (isEq [] (toList m))
                    ]
                end
              , let val m   = fromList [(0,"a")]
                in it "converts [(0,'a')]" [
                        (isEq [0] (keys m))
                      , (isEq ["a"] (values m))
                      , (isEq [(0,"a")] (toList m))
                    ]
                end
              , let val m   = fromList [(0,"a"), (1,"b")]
                in it "converts [(0,'a'), (1,'b')]" [
                        (isEq [1, 0] (keys m))
                      , (isEq ["b", "a"] (values m))
                      , (isEq [(1, "b"), (0,"a")] (toList m))
                    ]
                end
              , let val m   = fromList [(0,"a"), (1,"b"), (32,"c")]
                in it "converts [(0,'a'), (1, 'b'), (32, 'c')]" [
                        (isEq [1, 32, 0] (keys m))
                      , (isEq ["b", "c", "a"] (values m))
                      , (isEq [(1, "b"), (32, "c"), (0,"a")] (toList m))
                    ]
                end
            ]
        ]
in run authority tests end
