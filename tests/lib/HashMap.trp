import Unit
import Hash
import HashMap

let (* Hash based on the lowest ten bits only. This way we can easily force various scenarios. *)
    fun hf x = x andb ((1 << 10) -1)

    val empty     = HashMap.empty hf
    val singleton = HashMap.singleton hf
    val fromList  = HashMap.fromList hf

    val tests = Unit.group "HashMap" [
            (* -- Empty, size, and findOpt (mem, find) -- *)
            let val m = empty
            in Unit.group "empty" [
                    Unit.it "is null"                           (Unit.isTrue  (HashMap.null m))
                  , Unit.it "has size 0"                        (Unit.isEq 0  (HashMap.size m))
                  , Unit.it "does not contain 0"                (Unit.isFalse (HashMap.mem m 0))
                  , Unit.it "returns [] for findOpt 0"          (Unit.isEq [] (HashMap.findOpt m 0))
                  , Unit.it "does not contain 1"                (Unit.isFalse (HashMap.mem m 1))
                  , Unit.it "returns [] for findOpt 1"          (Unit.isEq [] (HashMap.findOpt m 1))
                  , Unit.it "is not equal to 'empty Hash.hash'" (Unit.isNeq (HashMap.empty Hash.hash) m)
                ]
            end,
            (* -- Insert / Singleton, size, and findOpt (mem, find) -- *)
            let val m = HashMap.insert (empty) 0 42
            in Unit.group "insert (empty) 0 42" [
                    Unit.it "is not null"                (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 1"                 (Unit.isEq 1    (HashMap.size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (HashMap.mem m 0))
                  , Unit.it "returns [42] for findOpt 0" (Unit.isEq [42] (HashMap.findOpt m 0))
                  , Unit.it "returns 42 for find 0"      (Unit.isEq 42   (HashMap.find m 0))
                  , Unit.it "does not contain 1"         (Unit.isFalse   (HashMap.mem m 1))
                  , Unit.it "returns [] for findOpt 1"   (Unit.isEq []   (HashMap.findOpt m 1))
                ]
            end,
            let val m = singleton 0 42
            in Unit.group "singleton 0 42" [
                    Unit.it "is equivalent to 'insert (empty) 0 42'"
                            (Unit.isEq (HashMap.insert empty 0 42) m)
                ]
            end,
            (* -- Insert (fromList), size, and findOpt (mem, find) -- *)
            let val m = fromList [(0,42)]
            in Unit.group "fromList [(0,42)]" [
                    Unit.it "is equivalent to 'insert (empty) 0 42'"
                            (Unit.isEq (HashMap.insert empty 0 42) m)
                    ]
            end,
            let val m = fromList [(1,42)]
            in Unit.group "fromList [(1,42)]" [
                    Unit.it "is not null"                (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 1"                 (Unit.isEq 1    (HashMap.size m))
                  , Unit.it "does not contain 0"         (Unit.isFalse   (HashMap.mem m 0))
                  , Unit.it "returns [] for findOpt 0"   (Unit.isEq []   (HashMap.findOpt m 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (HashMap.mem m 1))
                  , Unit.it "returns [42] for findOpt 1" (Unit.isEq [42] (HashMap.findOpt m 1))
                  , Unit.it "returns 42 for find 1"      (Unit.isEq 42   (HashMap.find m 1))
                ]
            end,
            let val m = HashMap.insert (fromList [(0,42)]) 0 "a"
            in Unit.group "insert (fromList [(0,42)]) 0 'a'" [
                    Unit.it "is not null"                 (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 1"                  (Unit.isEq 1    (HashMap.size m))
                  , Unit.it "contains 0"                  (Unit.isTrue    (HashMap.mem m 0))
                  , Unit.it "returns ['a'] for findOpt 0" (Unit.isEq ["a"] (HashMap.findOpt m 0))
                  , Unit.it "returns 'a' for find 0"      (Unit.isEq "a"   (HashMap.find m 0))
                  , Unit.it "does not contain 1"          (Unit.isFalse   (HashMap.mem m 1))
                  , Unit.it "returns [] for findOpt 1"    (Unit.isEq []   (HashMap.findOpt m 1))
                ]
            end,
            let val m = fromList [(1,42), (0,21)]
            in Unit.group "fromList [(1,42), (0,21)]" [
                    Unit.it "is not null"                (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 2"                 (Unit.isEq 2    (HashMap.size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (HashMap.mem m 0))
                  , Unit.it "returns [21] for findOpt 0" (Unit.isEq [21] (HashMap.findOpt m 0))
                  , Unit.it "returns 21 for find 0"      (Unit.isEq 21   (HashMap.find m 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (HashMap.mem m 1))
                  , Unit.it "returns [42] for findOpt 1" (Unit.isEq [42] (HashMap.findOpt m 1))
                  , Unit.it "returns 42 for find 1"      (Unit.isEq 42   (HashMap.find m 1))
                ]
            end,
            let val m = fromList [(0,21),(1,42)]
            in Unit.group "fromList [(1,42), (0,21)]" [
                    Unit.it "is not null"                (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 2"                 (Unit.isEq 2    (HashMap.size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (HashMap.mem m 0))
                  , Unit.it "returns [21] for findOpt 0" (Unit.isEq [21] (HashMap.findOpt m 0))
                  , Unit.it "returns 21 for find 0"      (Unit.isEq 21   (HashMap.find m 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (HashMap.mem m 1))
                  , Unit.it "returns [42] for findOpt 1" (Unit.isEq [42] (HashMap.findOpt m 1))
                  , Unit.it "returns 42 for find 1"      (Unit.isEq 42   (HashMap.find m 1))
                ]
            end,
            let val m = fromList [(1024,42), (0,21), (2048,"a")]
            in Unit.group "fromList [(1024,42), (0,21), (2048,'a')] (collision)" [
                    Unit.it "is not null"                    (Unit.isFalse    (HashMap.null m))
                  , Unit.it "has size 3"                     (Unit.isEq 3     (HashMap.size m))
                  , Unit.it "contains 0"                     (Unit.isTrue     (HashMap.mem m 0))
                  , Unit.it "returns [21] for findOpt 0"     (Unit.isEq [21]  (HashMap.findOpt m 0))
                  , Unit.it "returns 21 for find 0"          (Unit.isEq 21    (HashMap.find m 0))
                  , Unit.it "contains 1024"                  (Unit.isTrue     (HashMap.mem m 1024))
                  , Unit.it "returns [42] for findOpt 1024"  (Unit.isEq [42]  (HashMap.findOpt m 1024))
                  , Unit.it "returns 42 for find 1024"       (Unit.isEq 42    (HashMap.find m 1024))
                  , Unit.it "contains 2048"                  (Unit.isTrue     (HashMap.mem m 2048))
                  , Unit.it "returns ['a'] for findOpt 2048" (Unit.isEq ["a"] (HashMap.findOpt m 2048))
                  , Unit.it "returns 'a' for find 2048"      (Unit.isEq "a"   (HashMap.find m 2048))
                ]
            end,
            let val m = fromList [(1024,42), (1,"a"), (0,21), (1025, "b")]
            in Unit.group "fromList [(1024,42), (1,'a'), (0,21), (1025,'b')] (collisions)" [
                    Unit.it "is not null"                    (Unit.isFalse    (HashMap.null m))
                  , Unit.it "has size 4"                     (Unit.isEq 4     (HashMap.size m))
                  , Unit.it "contains 0"                     (Unit.isTrue     (HashMap.mem m 0))
                  , Unit.it "returns [21] for findOpt 0"     (Unit.isEq [21]  (HashMap.findOpt m 0))
                  , Unit.it "returns 21 for find 0"          (Unit.isEq 21    (HashMap.find m 0))
                  , Unit.it "contains 1"                     (Unit.isTrue     (HashMap.mem m 1))
                  , Unit.it "returns ['b'] for findOpt 1"    (Unit.isEq ["a"] (HashMap.findOpt m 1))
                  , Unit.it "returns 'b' for find 1"         (Unit.isEq "a"   (HashMap.find m 1))
                  , Unit.it "contains 1024"                  (Unit.isTrue     (HashMap.mem m 1024))
                  , Unit.it "returns [42] for findOpt 1024"  (Unit.isEq [42]  (HashMap.findOpt m 1024))
                  , Unit.it "returns 42 for find 1024"       (Unit.isEq 42    (HashMap.find m 1024))
                  , Unit.it "contains 1025"                  (Unit.isTrue     (HashMap.mem m 1025))
                  , Unit.it "returns ['b'] for findOpt 1025" (Unit.isEq ["b"] (HashMap.findOpt m 1025))
                  , Unit.it "returns 'b' for find 1025"      (Unit.isEq "b"   (HashMap.find m 1025))
                  , Unit.it "does not contains 2"            (Unit.isFalse    (HashMap.mem m 2))
                  , Unit.it "returns [] for findOpt 2"       (Unit.isEq []    (HashMap.findOpt m 2))
                ]
            end,
            let val m  = fromList [(0,"a"), (1,"b"), (32,"c")]
            in Unit.group "fromList [(0,'a'), (1,'b'), (32,'c')] (trie of depth 2)" [
                    Unit.it "is not null"                        (Unit.isFalse    (HashMap.null m))
                  , Unit.it "has size 3"                         (Unit.isEq 3     (HashMap.size m))
                  , Unit.it "contains 0"                         (Unit.isTrue     (HashMap.mem m 0))
                  , Unit.it "returns ['a'] for findOpt 0"        (Unit.isEq ["a"] (HashMap.findOpt m 0))
                  , Unit.it "returns 'a' for find 0"             (Unit.isEq "a"   (HashMap.find m 0))
                  , Unit.it "contains 1"                         (Unit.isTrue     (HashMap.mem m 1))
                  , Unit.it "returns ['b'] for findOpt 1"        (Unit.isEq ["b"] (HashMap.findOpt m 1))
                  , Unit.it "returns 'b' for find 1"             (Unit.isEq "b"   (HashMap.find m 1))
                  , Unit.it "contains 32"                        (Unit.isTrue     (HashMap.mem m 32))
                  , Unit.it "returns ['c'] for findOpt 32"       (Unit.isEq ["c"] (HashMap.findOpt m 32))
                  , Unit.it "returns 'c' for find 32"            (Unit.isEq "c"   (HashMap.find m 32))
                  , Unit.it "does not contains 2"                (Unit.isFalse    (HashMap.mem m 2))
                  , Unit.it "returns [] for findOpt 2"           (Unit.isEq []    (HashMap.findOpt m 2))
                ]
            end,
            (* -- Insert (fromList), delete, size, and findOpt (mem and find) -- *)
            let val m  = HashMap.remove (fromList [(0,42)]) 0
                val exp = fromList []
            in Unit.group "remove (fromList [(0,42)]) 0" [
                    Unit.it "is equivalent to fromList []" (Unit.isEq exp m)
                ]
            end,
            let val m   = HashMap.remove (fromList [(0,42), (1,21)]) 0
                val exp = fromList [(1,21)]
            in Unit.group "remove (fromList [(0,42), (1,21)]) 0" [
                    Unit.it "is equivalent to fromList [(1,21)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = HashMap.remove (fromList [(0,42), (1,21)]) 1
                val exp = fromList [(0,42)]
            in Unit.group "remove (fromList [(0,42), (1,21)]) 1" [
                    Unit.it "is equivalent to fromList [(0,42)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = HashMap.remove (fromList [(0,42), (1,21), (33,8)]) 0
                val exp = fromList [(1,21), (33,8)]
            in Unit.group "remove (fromList [(0,42), (1,21), (33,8)]) 0" [
                    Unit.it "is equivalent to fromList [(1,21), (33,8)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = HashMap.remove (fromList [(0,42), (1,21), (33,8)]) 1
                val exp = fromList [(0,42), (33,8)]
            in Unit.group "remove (fromList [(0,42), (1,21), (33,8)]) 1" [
                    Unit.it "is equivalent to fromList [(0,42), (33,8)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = HashMap.remove (fromList [(0,42), (1,21), (33,8)]) 33
                val exp = fromList [(0,42), (1,21)]
            in Unit.group "remove (fromList [(0,42), (1,21), (33,8)]) 33" [
                    Unit.it "is equivalent to fromList [(0,42), (1,21)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = HashMap.remove (HashMap.remove (fromList [(0,42), (1,21), (33,8)]) 33) 1
                val exp = fromList [(0,42)]
            in Unit.group "remove (remove (fromList [(0,42), (1,21), (33,8)]) 33) 1" [
                    Unit.it "is equivalent to fromList [(0,42)]" (Unit.isEq exp m)
                ]
            end,
            (* -- keys, values, and toList -- *)
            (* NOTE: Failure in these tests may also be due to changes to the traversal order in
             *       'HashMap.fold'. *)
            Unit.group "keys, values, and toList" [
                let val m   = fromList []
                in Unit.it "converts []" [
                        (Unit.isEq [] (HashMap.keys m))
                      , (Unit.isEq [] (HashMap.values m))
                      , (Unit.isEq [] (HashMap.toList m))
                    ]
                end
              , let val m   = fromList [(0,"a")]
                in Unit.it "converts [(0,'a')]" [
                        (Unit.isEq [0] (HashMap.keys m))
                      , (Unit.isEq ["a"] (HashMap.values m))
                      , (Unit.isEq [(0,"a")] (HashMap.toList m))
                    ]
                end
              , let val m   = fromList [(0,"a"), (1,"b")]
                in Unit.it "converts [(0,'a'), (1,'b')]" [
                        (Unit.isEq [1, 0] (HashMap.keys m))
                      , (Unit.isEq ["b", "a"] (HashMap.values m))
                      , (Unit.isEq [(1, "b"), (0,"a")] (HashMap.toList m))
                    ]
                end
              , let val m   = fromList [(0,"a"), (1,"b"), (32,"c")]
                in Unit.it "converts [(0,'a'), (1, 'b'), (32, 'c')]" [
                        (Unit.isEq [1, 32, 0] (HashMap.keys m))
                      , (Unit.isEq ["b", "c", "a"] (HashMap.values m))
                      , (Unit.isEq [(1, "b"), (32, "c"), (0,"a")] (HashMap.toList m))
                    ]
                end
            ]
        ]
in Unit.run authority tests end
