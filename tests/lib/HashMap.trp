import Unit
import Hash
import HashMap

let (* Hash based on the lowest ten bits only. This way we can easily force various scenarios. *)
    fun hf x = x andb ((1 << 10) -1)

    val empty           = HashMap.empty hf
    val singleton       = HashMap.singleton hf
    fun null          m = HashMap.null m
    fun insert        m = HashMap.insert m authority
    fun remove        m = HashMap.remove m authority
    fun findAll       m = HashMap.findAll m authority
    fun findOpt       m = HashMap.findOpt m authority
    fun find          m = HashMap.find m authority
    fun findOrDefault m = HashMap.findOrDefault m authority
    fun mem           m = HashMap.mem m authority
    fun size          m = HashMap.size m
    val fromList        = HashMap.fromList hf authority

    val tests = Unit.group "HashMap" [
            (* -- Empty, size, and findAll (mem, find) -- *)
            let val m = empty
            in Unit.group "empty" [
                    Unit.it "is null"                           (Unit.isTrue  (null m))
                  , Unit.it "has size 0"                        (Unit.isEq 0  (size m))
                  , Unit.it "does not contain 0"                (Unit.isFalse (mem m 0))
                  , Unit.it "returns [] for findAll 0"          (Unit.isEq [] (findAll m 0))
                  , Unit.it "returns [] for findOpt 0"          (Unit.isEq [] (findOpt m 0))
                  , Unit.it "returns '?' for findOrDefault 0 '?'" (Unit.isEq "?" (findOrDefault m 0 "?"))
                  , Unit.it "does not contain 1"                  (Unit.isFalse (mem m 1))
                  , Unit.it "returns [] for findAll 1"            (Unit.isEq [] (findAll m 1))
                  , Unit.it "returns [] for findOpt 1"            (Unit.isEq [] (findOpt m 1))
                  , Unit.it "returns '!' for findOrDefault 1 '!'" (Unit.isEq "!" (findOrDefault m 1 "!"))
                  , Unit.it "is not equal to 'empty Hash.hash'"   (Unit.isNeq (HashMap.empty Hash.hash) m)
                ]
            end,
            (* -- Insert / Singleton, size, and findAll (mem, find) -- *)
            let val m = insert (empty) 0 42
            in Unit.group "insert (empty) 0 42" [
                    Unit.it "is not null"                (Unit.isFalse   (null m))
                  , Unit.it "has size 1"                 (Unit.isEq 1    (size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (mem m 0))
                  , Unit.it "returns [42] for findAll 0" (Unit.isEq [42] (findAll m 0))
                  , Unit.it "returns [42] for findOpt 0" (Unit.isEq [42] (findOpt m 0))
                  , Unit.it "returns 42 for find 0"      (Unit.isEq 42   (find m 0))
                  , Unit.it "returns 42 for findOrDefault 0 '¡'"  (Unit.isEq 42   (findOrDefault m 0 "¡"))
                  , Unit.it "does not contain 1"         (Unit.isFalse   (mem m 1))
                  , Unit.it "returns [] for findAll 1"   (Unit.isEq []   (findAll m 1))
                  , Unit.it "returns [] for findOpt 1"   (Unit.isEq []   (findOpt m 1))
                  , Unit.it "returns '@' for findOrDefault 1 '@'" (Unit.isEq "@" (findOrDefault m 1 "@"))
                ]
            end,
            let val m = singleton 0 42
            in Unit.group "singleton 0 42" [
                    Unit.it "is equivalent to 'insert (empty) 0 42'"
                            (Unit.isEq (insert empty 0 42) m)
                ]
            end,
            (* -- Insert (fromList), size, and findAll (mem, find) -- *)
            let val m = fromList [(0,42)]
            in Unit.group "fromList [(0,42)]" [
                    Unit.it "is equivalent to 'insert (empty) 0 42'"
                            (Unit.isEq (insert empty 0 42) m)
                    ]
            end,
            let val m = fromList [(1,42)]
            in Unit.group "fromList [(1,42)]" [
                    Unit.it "is not null"                (Unit.isFalse   (null m))
                  , Unit.it "has size 1"                 (Unit.isEq 1    (size m))
                  , Unit.it "does not contain 0"         (Unit.isFalse   (mem m 0))
                  , Unit.it "returns [] for findAll 0"   (Unit.isEq []   (findAll m 0))
                  , Unit.it "returns [] for findOpt 0"   (Unit.isEq []   (findOpt m 0))
                  , Unit.it "returns '$' for findOrDefault 0 '$'" (Unit.isEq "$"  (findOrDefault m 0 "$"))
                  , Unit.it "contains 1"                 (Unit.isTrue    (mem m 1))
                  , Unit.it "returns [42] for findAll 1" (Unit.isEq [42] (findAll m 1))
                  , Unit.it "returns [42] for findOpt 1" (Unit.isEq [42] (findOpt m 1))
                  , Unit.it "returns 42 for find 1"      (Unit.isEq 42   (find m 1))
                  , Unit.it "returns 42 for findOrDefault 1 '#'"  (Unit.isEq 42   (findOrDefault m 1 "#"))
                ]
            end,
            let val m = insert (fromList [(0,42)]) 0 "a"
            in Unit.group "insert (fromList [(0,42)]) 0 'a'" [
                    Unit.it "is not null"                 (Unit.isFalse   (null m))
                  , Unit.it "has size 1"                  (Unit.isEq 1    (size m))
                  , Unit.it "contains 0"                  (Unit.isTrue    (mem m 0))
                  , Unit.it "returns ['a'] for findAll 0" (Unit.isEq ["a"] (findAll m 0))
                  , Unit.it "returns ['a'] for findOpt 0" (Unit.isEq ["a"] (findOpt m 0))
                  , Unit.it "returns 'a' for find 0"      (Unit.isEq "a"   (find m 0))
                  , Unit.it "returns 'a' for findOrDefault 0 ''" (Unit.isEq "a"   (findOrDefault m 0 ""))
                  , Unit.it "does not contain 1"          (Unit.isFalse   (mem m 1))
                  , Unit.it "returns [] for findAll 1"    (Unit.isEq []   (findAll m 1))
                  , Unit.it "returns [] for findOpt 1"    (Unit.isEq []   (findOpt m 1))
                  , Unit.it "returns '' for findOrDefault 1 ''"  (Unit.isEq ""    (findOrDefault m 1 ""))
                ]
            end,
            let val m = fromList [(1,42), (0,21)]
            in Unit.group "fromList [(1,42), (0,21)]" [
                    Unit.it "is not null"                (Unit.isFalse   (null m))
                  , Unit.it "has size 2"                 (Unit.isEq 2    (size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (mem m 0))
                  , Unit.it "returns [21] for findAll 0" (Unit.isEq [21] (findAll m 0))
                  , Unit.it "returns [21] for findOpt 0" (Unit.isEq [21] (findOpt m 0))
                  , Unit.it "returns 21 for find 0"      (Unit.isEq 21   (find m 0))
                  , Unit.it "returns 21 for findOrDefault 0 '!'" (Unit.isEq 21   (findOrDefault m 0 "!"))
                  , Unit.it "contains 1"                 (Unit.isTrue    (mem m 1))
                  , Unit.it "returns [42] for findAll 1" (Unit.isEq [42] (findAll m 1))
                  , Unit.it "returns [42] for findOpt 1" (Unit.isEq [42] (findOpt m 1))
                  , Unit.it "returns 42 for find 1"      (Unit.isEq 42   (find m 1))
                  , Unit.it "returns 42 for findOrDefault 1 '@'" (Unit.isEq 42   (findOrDefault m 1 "@"))
                ]
            end,
            let val m = fromList [(0,21),(1,42)]
            in Unit.group "fromList [(0,21), (1,42)]" [
                    Unit.it "is not null"                (Unit.isFalse   (null m))
                  , Unit.it "has size 2"                 (Unit.isEq 2    (size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (mem m 0))
                  , Unit.it "returns [21] for findAll 0" (Unit.isEq [21] (findAll m 0))
                  , Unit.it "returns [21] for findOpt 0" (Unit.isEq [21] (findOpt m 0))
                  , Unit.it "returns 21 for find 0"      (Unit.isEq 21   (find m 0))
                  , Unit.it "returns 21 for findOrDefault 0 0" (Unit.isEq 21 (findOrDefault m 0 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (mem m 1))
                  , Unit.it "returns [42] for findAll 1" (Unit.isEq [42] (findAll m 1))
                  , Unit.it "returns [42] for findOpt 1" (Unit.isEq [42] (findOpt m 1))
                  , Unit.it "returns 42 for find 1"      (Unit.isEq 42   (find m 1))
                  , Unit.it "returns 42 for findOrDefault 1 0" (Unit.isEq 42   (findOrDefault m 1 0))
                ]
            end,
            let val m = fromList [(1024,42), (0,21), (2048,"a")]
            in Unit.group "fromList [(1024,42), (0,21), (2048,'a')] (collision)" [
                    Unit.it "is not null"                    (Unit.isFalse    (null m))
                  , Unit.it "has size 3"                     (Unit.isEq 3     (size m))
                  , Unit.it "contains 0"                     (Unit.isTrue     (mem m 0))
                  , Unit.it "returns [21] for findAll 0"     (Unit.isEq [21]  (findAll m 0))
                  , Unit.it "returns [21] for findOpt 0"     (Unit.isEq [21]  (findOpt m 0))
                  , Unit.it "returns 21 for find 0"          (Unit.isEq 21    (find m 0))
                  , Unit.it "returns 21 for findOrDefault 0 -1"     (Unit.isEq 21    (findOrDefault m 0 (-1)))
                  , Unit.it "contains 1024"                  (Unit.isTrue     (mem m 1024))
                  , Unit.it "returns [42] for findAll 1024"  (Unit.isEq [42]  (findAll m 1024))
                  , Unit.it "returns [42] for findOpt 1024"  (Unit.isEq [42]  (findOpt m 1024))
                  , Unit.it "returns 42 for find 1024"       (Unit.isEq 42    (find m 1024))
                  , Unit.it "contains 2048"                  (Unit.isTrue     (mem m 2048))
                  , Unit.it "returns ['a'] for findAll 2048" (Unit.isEq ["a"] (findAll m 2048))
                  , Unit.it "returns ['a'] for findOpt 2048" (Unit.isEq ["a"] (findOpt m 2048))
                  , Unit.it "returns 'a' for find 2048"      (Unit.isEq "a"   (find m 2048))
                  , Unit.it "returns 'a' for findOrDefault 2048 -1" (Unit.isEq "a"   (findOrDefault m 2048 (-1)))
                ]
            end,
            let val m = fromList [(1024,42), (1,"a"), (0,21), (1025, "b")]
            in Unit.group "fromList [(1024,42), (1,'a'), (0,21), (1025,'b')] (collisions)" [
                    Unit.it "is not null"                    (Unit.isFalse    (null m))
                  , Unit.it "has size 4"                     (Unit.isEq 4     (size m))
                  , Unit.it "contains 0"                     (Unit.isTrue     (mem m 0))
                  , Unit.it "returns [21] for findAll 0"     (Unit.isEq [21]  (findAll m 0))
                  , Unit.it "returns [21] for findOpt 0"     (Unit.isEq [21]  (findOpt m 0))
                  , Unit.it "returns 21 for find 0"          (Unit.isEq 21    (find m 0))
                  , Unit.it "returns 21 for findOrDefault 0 '42'"  (Unit.isEq 21    (findOrDefault m 0 "42"))
                  , Unit.it "contains 1"                     (Unit.isTrue     (mem m 1))
                  , Unit.it "returns ['b'] for findAll 1"    (Unit.isEq ["a"] (findAll m 1))
                  , Unit.it "returns ['b'] for findOpt 1"    (Unit.isEq ["a"] (findOpt m 1))
                  , Unit.it "returns 'b' for find 1"         (Unit.isEq "a"   (find m 1))
                  , Unit.it "returns 'b' for findOrDefault 1 '!'"  (Unit.isEq "a"   (findOrDefault m 1 "!"))
                  , Unit.it "contains 1024"                  (Unit.isTrue     (mem m 1024))
                  , Unit.it "returns [42] for findAll 1024"  (Unit.isEq [42]  (findAll m 1024))
                  , Unit.it "returns [42] for findOpt 1024"  (Unit.isEq [42]  (findOpt m 1024))
                  , Unit.it "returns 42 for find 1024"       (Unit.isEq 42    (find m 1024))
                  , Unit.it "returns 42 for findOrDefault 1024 '?'" (Unit.isEq 42    (findOrDefault m 1024 "?"))
                  , Unit.it "contains 1025"                  (Unit.isTrue     (mem m 1025))
                  , Unit.it "returns ['a'] for findAll 1025" (Unit.isEq ["b"] (findAll m 1025))
                  , Unit.it "returns ['b'] for findOpt 1025" (Unit.isEq ["b"] (findOpt m 1025))
                  , Unit.it "returns 'b' for find 1025"      (Unit.isEq "b"   (find m 1025))
                  , Unit.it "returns 'b' for findOrDefault 1025 -1" (Unit.isEq "b"   (findOrDefault m 1025 (-1)))
                  , Unit.it "does not contains 2"            (Unit.isFalse    (mem m 2))
                  , Unit.it "returns [] for findOpt 2"       (Unit.isEq []    (findOpt m 2))
                  , Unit.it "returns -1 for findOrDefault 2 -1"     (Unit.isEq (-1)  (findOrDefault m 2 (-1)))
                ]
            end,
            let val m  = fromList [(0,"a"), (1,"b"), (32,"c")]
            in Unit.group "fromList [(0,'a'), (1,'b'), (32,'c')] (trie of depth 2)" [
                    Unit.it "is not null"                        (Unit.isFalse    (null m))
                  , Unit.it "has size 3"                         (Unit.isEq 3     (size m))
                  , Unit.it "contains 0"                         (Unit.isTrue     (mem m 0))
                  , Unit.it "returns [21] for findAll 0"         (Unit.isEq ["a"] (findAll m 0))
                  , Unit.it "returns ['a'] for findOpt 0"        (Unit.isEq ["a"] (findOpt m 0))
                  , Unit.it "returns 'a' for find 0"             (Unit.isEq "a"   (find m 0))
                  , Unit.it "returns 'a' for findOrDefault 0 ''"  (Unit.isEq "a"   (findOrDefault m 0 ""))
                  , Unit.it "contains 1"                         (Unit.isTrue     (mem m 1))
                  , Unit.it "returns ['b'] for findAll 1"        (Unit.isEq ["b"] (findAll m 1))
                  , Unit.it "returns ['b'] for findOpt 1"        (Unit.isEq ["b"] (findOpt m 1))
                  , Unit.it "returns 'b' for find 1"             (Unit.isEq "b"   (find m 1))
                  , Unit.it "returns 'b' for findOrDefault 1 ''"  (Unit.isEq "b"   (findOrDefault m 1 ""))
                  , Unit.it "contains 32"                        (Unit.isTrue     (mem m 32))
                  , Unit.it "returns ['c'] for findAll 32"       (Unit.isEq ["c"] (findAll m 32))
                  , Unit.it "returns ['c'] for findOpt 32"       (Unit.isEq ["c"] (findOpt m 32))
                  , Unit.it "returns 'c' for find 32"            (Unit.isEq "c"   (find m 32))
                  , Unit.it "returns 'c' for findOrDefault 32 ''" (Unit.isEq "c"   (findOrDefault m 32 ""))
                  , Unit.it "does not contains 2"                (Unit.isFalse    (mem m 2))
                  , Unit.it "returns [] for findAll 2"           (Unit.isEq []    (findAll m 2))
                  , Unit.it "returns [] for findOpt 2"           (Unit.isEq []    (findOpt m 2))
                  , Unit.it "returns '' for findOrDefault 2 ''"   (Unit.isEq ""    (findOrDefault m 2 ""))
                ]
            end,
            (* -- Insert (fromList), delete, size, and findAll (mem and find) -- *)
            let val m  = remove (fromList [(0,42)]) 0
                val exp = fromList []
            in Unit.group "remove (fromList [(0,42)]) 0" [
                    Unit.it "is equivalent to fromList []" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21)]) 0
                val exp = fromList [(1,21)]
            in Unit.group "remove (fromList [(0,42), (1,21)]) 0" [
                    Unit.it "is equivalent to fromList [(1,21)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21)]) 1
                val exp = fromList [(0,42)]
            in Unit.group "remove (fromList [(0,42), (1,21)]) 1" [
                    Unit.it "is equivalent to fromList [(0,42)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21), (33,8)]) 0
                val exp = fromList [(1,21), (33,8)]
            in Unit.group "remove (fromList [(0,42), (1,21), (33,8)]) 0" [
                    Unit.it "is equivalent to fromList [(1,21), (33,8)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21), (33,8)]) 1
                val exp = fromList [(0,42), (33,8)]
            in Unit.group "remove (fromList [(0,42), (1,21), (33,8)]) 1" [
                    Unit.it "is equivalent to fromList [(0,42), (33,8)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21), (33,8)]) 33
                val exp = fromList [(0,42), (1,21)]
            in Unit.group "remove (fromList [(0,42), (1,21), (33,8)]) 33" [
                    Unit.it "is equivalent to fromList [(0,42), (1,21)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (remove (fromList [(0,42), (1,21), (33,8)]) 33) 1
                val exp = fromList [(0,42)]
            in Unit.group "remove (remove (fromList [(0,42), (1,21), (33,8)]) 33) 1" [
                    Unit.it "is equivalent to fromList [(0,42)]" (Unit.isEq exp m)
                ]
            end,
            (* -- keys, values, and toList -- *)
            (* NOTE: Failure in these tests may also be due to changes to the traversal order in
             *       'HashMap.fold'. *)
            Unit.group "keys, values, and toList" [
                let val m   = fromList []
                in Unit.it "converts []" [
                        (Unit.isEq [] (HashMap.keys m))
                      , (Unit.isEq [] (HashMap.values m))
                      , (Unit.isEq [] (HashMap.toList m))
                    ]
                end
              , let val m   = fromList [(0,"a")]
                in Unit.it "converts [(0,'a')]" [
                        (Unit.isEq [0] (HashMap.keys m))
                      , (Unit.isEq ["a"] (HashMap.values m))
                      , (Unit.isEq [(0,"a")] (HashMap.toList m))
                    ]
                end
              , let val m   = fromList [(0,"a"), (1,"b")]
                in Unit.it "converts [(0,'a'), (1,'b')]" [
                        (Unit.isEq [1, 0] (HashMap.keys m))
                      , (Unit.isEq ["b", "a"] (HashMap.values m))
                      , (Unit.isEq [(1, "b"), (0,"a")] (HashMap.toList m))
                    ]
                end
              , let val m   = fromList [(0,"a"), (1,"b"), (32,"c")]
                in Unit.it "converts [(0,'a'), (1, 'b'), (32, 'c')]" [
                        (Unit.isEq [1, 32, 0] (HashMap.keys m))
                      , (Unit.isEq ["b", "c", "a"] (HashMap.values m))
                      , (Unit.isEq [(1, "b"), (32, "c"), (0,"a")] (HashMap.toList m))
                    ]
                end
            ],
            (* -- IFC-aware insertions and deletions -- *)
            let val bot   = `<; #root-integrity>`
                val alice = `<alice; #root-integrity>`
                val bob   = `<bob; #root-integrity>`

                val m = fromList [ (0 raisedTo alice, 42) ]
            in Unit.group "fromList [(0@{alice}, 42)]" [
                    Unit.it "is not null"           (Unit.isFalse    (null m))
                  , Unit.it "SHOW"                  (Unit.isEq ("")  (toStringL m.1))
                  , Unit.it "has size 0@{}"         (Unit.isEq (0) (size m))
                  , Unit.it "has size 1@{alice}"    (Unit.isEq (1 raisedTo alice)
                                                               (size m))
                  , Unit.it "has size 0@{bob}"      (Unit.isEq (0 raisedTo bob)
                                                               (size m))
                  , Unit.it "returns [42]@{alice} for findAll 0@{alice}"
                            (Unit.isEq ([42] raisedTo alice)
                                       (findAll m (0 raisedTo alice)))
                  , Unit.it "returns [42]@{alice} for findOpt 0@{alice}"
                            (Unit.isEq ([42] raisedTo alice)
                                       (findOpt m (0 raisedTo alice)))
                  , Unit.it "returns true@{alice} for mem 0@{alice}"
                            (Unit.isEq (true raisedTo alice)
                                       (mem m (0 raisedTo alice)))
                  , Unit.it "returns []@{bob} for findAll 0@{bob}"
                            (Unit.isEq ([] raisedTo bob)
                                       (findAll m (0 raisedTo bob)))
                  , Unit.it "returns []@{bob} for findOpt 0@{bob}"
                            (Unit.isEq ([] raisedTo bob)
                                       (findOpt m (0 raisedTo bob)))
                  , Unit.it "returns false@{bob} for mem 0@{bob}"
                            (Unit.isEq (false raisedTo bob)
                                       (mem m (0 raisedTo bob)))
                  , Unit.it "returns []@{} for findAll 0@{}"
                            (Unit.isEq [] (findAll m (0)))
                  , Unit.it "returns []@{} for findOpt 0@{}"
                            (Unit.isEq [] (findOpt m (0)))
                  , Unit.it "returns false@{} for mem 0@{}"
                            (Unit.isEq false (mem m (0)))
                ]
            end,
            let val bot   = `<; #root-integrity>`
                val alice = `<alice; #root-integrity>`
                val bob   = `<bob; #root-integrity>`

                val m = fromList [ (0, 21), (0 raisedTo alice, 42) ]
            in Unit.group "fromList [(0@{}, 21), (0@{alice}, 42)]" [
                    Unit.it "is not null"           (Unit.isFalse    (null m))
                  , Unit.it "SHOW"                  (Unit.isEq ("")  (toStringL m.1))
                  , Unit.it "has size 1@{}"         (Unit.isEq (1) (size m))
                  , Unit.it "has size 1@{alice}"    (Unit.isEq (1 raisedTo alice)
                                                               (size m))
                  , Unit.it "has size 1@{bob}"      (Unit.isEq (1 raisedTo bob)
                                                               (size m))
                  , Unit.it "returns [42]@{alice} for findAll 0@{alice}"
                            (Unit.isEq ([42] raisedTo alice)
                                       (findAll m (0 raisedTo alice)))
                  , Unit.it "returns [42]@{alice} for findOpt 0@{alice}"
                            (Unit.isEq ([42] raisedTo alice)
                                       (findOpt m (0 raisedTo alice)))
                  , Unit.it "returns true@{alice} for mem 0@{alice}"
                            (Unit.isEq (true raisedTo alice)
                                       (mem m (0 raisedTo alice)))
                  , Unit.it "returns [21]@{bob} for findAll 0@{bob}"
                            (Unit.isEq ([21] raisedTo bob)
                                       (findAll m (0 raisedTo bob)))
                  , Unit.it "returns [21]@{bob} for findOpt 0@{bob}"
                            (Unit.isEq ([21] raisedTo bob)
                                       (findOpt m (0 raisedTo bob)))
                  , Unit.it "returns true@{bob} for mem 0@{bob}"
                            (Unit.isEq (true raisedTo bob)
                                       (mem m (0 raisedTo bob)))
                  , Unit.it "returns [21]@{} for findAll 0@{}"
                            (Unit.isEq [21] (findAll m (0)))
                  , Unit.it "returns [21]@{} for findOpt 0@{}"
                            (Unit.isEq [21] (findOpt m (0)))
                  , Unit.it "returns true@{} for mem 0@{}"
                            (Unit.isEq (true) (mem m (0)))
                ]
            end,
            let val bot   = `<; #root-integrity>`
                val alice = `<alice; #root-integrity>`
                val bob   = `<bob; #root-integrity>`

            val m = fromList [ (0 raisedTo alice, 42), (0, 21) ]
            in Unit.group "fromList [(0@{alice}, 42), (0@{}, 21)]" [
                    Unit.it "is not null"           (Unit.isFalse    (null m))
                  , Unit.it "SHOW"                  (Unit.isEq ("")  (toStringL m.1))
                  , Unit.it "has size 1@{}"         (Unit.isEq (1) (size m))
                  , Unit.it "has size 1@{alice}"    (Unit.isEq (1 raisedTo alice)
                                                               (size m))
                  , Unit.it "has size 1@{bob}"      (Unit.isEq (1 raisedTo bob)
                                                               (size m))
                  , Unit.it "returns [21]@{alice} for findAll 0@{alice}"
                            (Unit.isEq ([21] raisedTo alice)
                                       (findAll m (0 raisedTo alice)))
                  , Unit.it "returns [21]@{alice} for findOpt 0@{alice}"
                            (Unit.isEq ([21] raisedTo alice)
                                       (findOpt m (0 raisedTo alice)))
                  , Unit.it "returns true@{alice} for mem 0@{alice}"
                            (Unit.isEq (true raisedTo alice)
                                       (mem m (0 raisedTo alice)))
                  , Unit.it "returns [21]@{bob} for findAll 0@{bob}"
                            (Unit.isEq ([21] raisedTo bob)
                                       (findAll m (0 raisedTo bob)))
                  , Unit.it "returns [21]@{bob} for findOpt 0@{bob}"
                            (Unit.isEq ([21] raisedTo bob)
                                       (findOpt m (0 raisedTo bob)))
                  , Unit.it "returns true@{bob} for mem 0@{bob}"
                            (Unit.isEq (true raisedTo bob)
                                       (mem m (0 raisedTo bob)))
                  , Unit.it "returns [21]@{} for findAll 0@{}"
                            (Unit.isEq [21] (findAll m (0)))
                  , Unit.it "returns [21]@{} for findOpt 0@{}"
                            (Unit.isEq [21] (findOpt m (0)))
                  , Unit.it "returns true@{} for mem 0@{}"
                            (Unit.isEq (true) (mem m (0)))
                ]
            end,
            let val bot       = `<; #root-integrity>`
                val alice     = `<alice; #root-integrity>`
                val bob       = `<bob; #root-integrity>`
                val alice_bob = `<alice & bob; #root-integrity>`

                val m = fromList [ (0 raisedTo alice, 42), (0 raisedTo bob, 21) ]
            in Unit.group "fromList [(0@{alice}, 42), (0@{bob}, 21)]" [
                    Unit.it "is not null"            (Unit.isFalse    (null m))
                  , Unit.it "SHOW"                  (Unit.isEq ("")  (toStringL m.1))
                  , Unit.it "has size 0@{}"          (Unit.isEq (1) (size m))
                  , Unit.it "has size 1@{alice}"     (Unit.isEq (1 raisedTo alice)
                                                                (size m))
                  , Unit.it "has size 1@{bob}"       (Unit.isEq (1 raisedTo bob)
                                                                (size m))
                  , Unit.it "has size 1@{alice_bob}" (Unit.isEq (1 raisedTo alice_bob)
                                                                (size m))
                  , Unit.it "returns [42]@{alice} for findAll 0@{alice}"
                            (Unit.isEq ([42] raisedTo alice)
                                       (findAll m (0 raisedTo alice)))
                  , Unit.it "returns [42]@{alice} for findOpt 0@{alice}"
                            (Unit.isEq ([42] raisedTo alice)
                                       (findOpt m (0 raisedTo alice)))
                  , Unit.it "returns [21]@{bob} for findAll 0@{bob}"
                            (Unit.isEq ([21] raisedTo bob)
                                       (findAll m (0 raisedTo bob)))
                  , Unit.it "returns [21]@{bob} for findOpt 0@{bob}"
                            (Unit.isEq ([21] raisedTo bob)
                                       (findOpt m (0 raisedTo bob)))
                  , Unit.it "returns true@{bob} for mem 0@{bob}"
                            (Unit.isEq (true raisedTo bob)
                                       (mem m (0 raisedTo bob)))
                  , Unit.it "returns [21]@{alice, bob} for findAll 0@{alice, bob}"
                            (Unit.isEq ([21, 42] raisedTo alice_bob)
                                       (findAll m (0 raisedTo alice_bob)))
                  , Unit.it "returns [21]@{alice, bob} for findOpt 0@{alice, bob}"
                            (Unit.isEq ([21] raisedTo alice_bob)
                                       (findOpt m (0 raisedTo alice_bob)))
                  , Unit.it "returns true@{alice, bob} for mem 0@{alice, bob}"
                            (Unit.isEq (true raisedTo alice_bob)
                                       (mem m (0 raisedTo alice_bob)))
                  , Unit.it "returns []@{} for findAll 0@{}"
                            (Unit.isEq [] (findAll m (0)))
                  , Unit.it "returns []@{} for findOpt 0@{}"
                            (Unit.isEq [] (findOpt m (0)))
                  , Unit.it "returns false@{} for mem 0@{}"
                            (Unit.isEq false (mem m (0)))
                ]
            end,
            let val bot   = `<; #root-integrity>`
                val alice = `<alice; #root-integrity>`
                val bob   = `<bob; #root-integrity>`

            val m = fromList [ (0 raisedTo alice, 42), (1024, 21) ]
            in Unit.group "fromList [(0@{alice}, 42), (1024@{}, 21)] (collision)" [
                    Unit.it "is not null"           (Unit.isFalse    (null m))
                  , Unit.it "SHOW"                  (Unit.isEq ("")  (toStringL m.1))
                  , Unit.it "has size 1@{}"         (Unit.isEq (1) (size m))
                  , Unit.it "has size 1@{alice}"    (Unit.isEq (2 raisedTo alice)
                                                               (size m))
                  , Unit.it "has size 1@{bob}"      (Unit.isEq (1 raisedTo bob)
                                                               (size m))
                  , Unit.it "returns [21]@{alice} for findAll 0@{alice}"
                            (Unit.isEq ([42] raisedTo alice)
                                       (findAll m (0 raisedTo alice)))
                  , Unit.it "returns [21]@{alice} for findOpt 0@{alice}"
                            (Unit.isEq ([42] raisedTo alice)
                                       (findOpt m (0 raisedTo alice)))
                  , Unit.it "returns true@{alice} for mem 0@{alice}"
                            (Unit.isEq (true raisedTo alice)
                                       (mem m (0 raisedTo alice)))
                  , Unit.it "returns []@{bob} for findAll 0@{bob}"
                            (Unit.isEq ([] raisedTo bob)
                                       (findAll m (0 raisedTo bob)))
                  , Unit.it "returns []@{bob} for findOpt 0@{bob}"
                            (Unit.isEq ([] raisedTo bob)
                                       (findOpt m (0 raisedTo bob)))
                  , Unit.it "returns false@{bob} for mem 0@{bob}"
                            (Unit.isEq (false raisedTo bob)
                                       (mem m (0 raisedTo bob)))
                  , Unit.it "returns []@{} for findAll 0@{}"
                            (Unit.isEq [] (findAll m (0)))
                  , Unit.it "returns []@{} for findOpt 0@{}"
                            (Unit.isEq [] (findOpt m (0)))
                  , Unit.it "returns false@{} for mem 0@{}"
                            (Unit.isEq false (mem m (0)))
                  , Unit.it "returns [21]@{alice} for findAll 1@{alice}"
                            (Unit.isEq ([21] raisedTo alice)
                                       (findAll m (1024 raisedTo alice)))
                  , Unit.it "returns [21]@{alice} for findOpt 1@{alice}"
                            (Unit.isEq ([21] raisedTo alice)
                                       (findOpt m (1024 raisedTo alice)))
                  , Unit.it "returns true@{alice} for mem 1@{alice}"
                            (Unit.isEq (true raisedTo alice)
                                       (mem m (1024 raisedTo alice)))
                  , Unit.it "returns []@{bob} for findAll 1@{bob}"
                            (Unit.isEq ([21] raisedTo bob)
                                       (findAll m (1024 raisedTo bob)))
                  , Unit.it "returns []@{bob} for findOpt 1@{bob}"
                            (Unit.isEq ([21] raisedTo bob)
                                       (findOpt m (1024 raisedTo bob)))
                  , Unit.it "returns false@{bob} for mem 1@{bob}"
                            (Unit.isEq (true raisedTo bob)
                                       (mem m (1024 raisedTo bob)))
                  , Unit.it "returns [21]@{} for findAll 1@{}"
                            (Unit.isEq [21] (findAll m (1024)))
                  , Unit.it "returns [21]@{} for findOpt 1@{}"
                            (Unit.isEq [21] (findOpt m (1024)))
                  , Unit.it "returns true@{} for mem 1@{}"
                            (Unit.isEq true (mem m (1024)))
                ]
            end
        ]
in Unit.run authority tests end
