import Unit
import Hash
import HashMap

let (* Hash based on the lowest ten bits only. This way we can easily force various scenarios. *)
    fun hf x = x andb ((1 << 10) -1)

    val empty     = HashMap.empty hf
    val singleton = HashMap.singleton hf
    fun insert  m = HashMap.insert m authority
    fun remove  m = HashMap.remove m authority
    fun findAll m = HashMap.findAll m authority
    fun find    m = HashMap.find m authority
    fun mem     m = HashMap.mem m authority
    val fromList  = HashMap.fromList hf authority

    val tests = Unit.group "HashMap" [
            (* -- Empty, size, and findAll (mem, find) -- *)
            let val m = empty
            in Unit.group "empty" [
                    Unit.it "is null"                           (Unit.isTrue  (HashMap.null m))
                  , Unit.it "has size 0"                        (Unit.isEq 0  (HashMap.size m))
                  , Unit.it "does not contain 0"                (Unit.isFalse (mem m 0))
                  , Unit.it "returns [] for findAll 0"          (Unit.isEq [] (findAll m 0))
                  , Unit.it "does not contain 1"                (Unit.isFalse (mem m 1))
                  , Unit.it "returns [] for findAll 1"          (Unit.isEq [] (findAll m 1))
                  , Unit.it "is not equal to 'empty Hash.hash'" (Unit.isNeq (HashMap.empty Hash.hash) m)
                ]
            end,
            (* -- Insert / Singleton, size, and findAll (mem, find) -- *)
            let val m = insert (empty) 0 42
            in Unit.group "insert (empty) 0 42" [
                    Unit.it "is not null"                (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 1"                 (Unit.isEq 1    (HashMap.size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (mem m 0))
                  , Unit.it "returns [42] for findAll 0" (Unit.isEq [42] (findAll m 0))
                  , Unit.it "returns 42 for find 0"      (Unit.isEq 42   (find m 0))
                  , Unit.it "does not contain 1"         (Unit.isFalse   (mem m 1))
                  , Unit.it "returns [] for findAll 1"   (Unit.isEq []   (findAll m 1))
                ]
            end,
            let val m = singleton 0 42
            in Unit.group "singleton 0 42" [
                    Unit.it "is equivalent to 'insert (empty) 0 42'"
                            (Unit.isEq (insert empty 0 42) m)
                ]
            end,
            (* -- Insert (fromList), size, and findAll (mem, find) -- *)
            let val m = fromList [(0,42)]
            in Unit.group "fromList [(0,42)]" [
                    Unit.it "is equivalent to 'insert (empty) 0 42'"
                            (Unit.isEq (insert empty 0 42) m)
                    ]
            end,
            let val m = fromList [(1,42)]
            in Unit.group "fromList [(1,42)]" [
                    Unit.it "is not null"                (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 1"                 (Unit.isEq 1    (HashMap.size m))
                  , Unit.it "does not contain 0"         (Unit.isFalse   (mem m 0))
                  , Unit.it "returns [] for findAll 0"   (Unit.isEq []   (findAll m 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (mem m 1))
                  , Unit.it "returns [42] for findAll 1" (Unit.isEq [42] (findAll m 1))
                  , Unit.it "returns 42 for find 1"      (Unit.isEq 42   (find m 1))
                ]
            end,
            let val m = insert (fromList [(0,42)]) 0 "a"
            in Unit.group "insert (fromList [(0,42)]) 0 'a'" [
                    Unit.it "is not null"                 (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 1"                  (Unit.isEq 1    (HashMap.size m))
                  , Unit.it "contains 0"                  (Unit.isTrue    (mem m 0))
                  , Unit.it "returns ['a'] for findAll 0" (Unit.isEq ["a"] (findAll m 0))
                  , Unit.it "returns 'a' for find 0"      (Unit.isEq "a"   (find m 0))
                  , Unit.it "does not contain 1"          (Unit.isFalse   (mem m 1))
                  , Unit.it "returns [] for findAll 1"    (Unit.isEq []   (findAll m 1))
                ]
            end,
            let val m = fromList [(1,42), (0,21)]
            in Unit.group "fromList [(1,42), (0,21)]" [
                    Unit.it "is not null"                (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 2"                 (Unit.isEq 2    (HashMap.size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (mem m 0))
                  , Unit.it "returns [21] for findAll 0" (Unit.isEq [21] (findAll m 0))
                  , Unit.it "returns 21 for find 0"      (Unit.isEq 21   (find m 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (mem m 1))
                  , Unit.it "returns [42] for findAll 1" (Unit.isEq [42] (findAll m 1))
                  , Unit.it "returns 42 for find 1"      (Unit.isEq 42   (find m 1))
                ]
            end,
            let val m = fromList [(0,21),(1,42)]
            in Unit.group "fromList [(1,42), (0,21)]" [
                    Unit.it "is not null"                (Unit.isFalse   (HashMap.null m))
                  , Unit.it "has size 2"                 (Unit.isEq 2    (HashMap.size m))
                  , Unit.it "contains 0"                 (Unit.isTrue    (mem m 0))
                  , Unit.it "returns [21] for findAll 0" (Unit.isEq [21] (findAll m 0))
                  , Unit.it "returns 21 for find 0"      (Unit.isEq 21   (find m 0))
                  , Unit.it "contains 1"                 (Unit.isTrue    (mem m 1))
                  , Unit.it "returns [42] for findAll 1" (Unit.isEq [42] (findAll m 1))
                  , Unit.it "returns 42 for find 1"      (Unit.isEq 42   (find m 1))
                ]
            end,
            let val m = fromList [(1024,42), (0,21), (2048,"a")]
            in Unit.group "fromList [(1024,42), (0,21), (2048,'a')] (collision)" [
                    Unit.it "is not null"                    (Unit.isFalse    (HashMap.null m))
                  , Unit.it "has size 3"                     (Unit.isEq 3     (HashMap.size m))
                  , Unit.it "contains 0"                     (Unit.isTrue     (mem m 0))
                  , Unit.it "returns [21] for findAll 0"     (Unit.isEq [21]  (findAll m 0))
                  , Unit.it "returns 21 for find 0"          (Unit.isEq 21    (find m 0))
                  , Unit.it "contains 1024"                  (Unit.isTrue     (mem m 1024))
                  , Unit.it "returns [42] for findAll 1024"  (Unit.isEq [42]  (findAll m 1024))
                  , Unit.it "returns 42 for find 1024"       (Unit.isEq 42    (find m 1024))
                  , Unit.it "contains 2048"                  (Unit.isTrue     (mem m 2048))
                  , Unit.it "returns ['a'] for findAll 2048" (Unit.isEq ["a"] (findAll m 2048))
                  , Unit.it "returns 'a' for find 2048"      (Unit.isEq "a"   (find m 2048))
                ]
            end,
            let val m = fromList [(1024,42), (1,"a"), (0,21), (1025, "b")]
            in Unit.group "fromList [(1024,42), (1,'a'), (0,21), (1025,'b')] (collisions)" [
                    Unit.it "is not null"                    (Unit.isFalse    (HashMap.null m))
                  , Unit.it "has size 4"                     (Unit.isEq 4     (HashMap.size m))
                  , Unit.it "contains 0"                     (Unit.isTrue     (mem m 0))
                  , Unit.it "returns [21] for findAll 0"     (Unit.isEq [21]  (findAll m 0))
                  , Unit.it "returns 21 for find 0"          (Unit.isEq 21    (find m 0))
                  , Unit.it "contains 1"                     (Unit.isTrue     (mem m 1))
                  , Unit.it "returns ['b'] for findAll 1"    (Unit.isEq ["a"] (findAll m 1))
                  , Unit.it "returns 'b' for find 1"         (Unit.isEq "a"   (find m 1))
                  , Unit.it "contains 1024"                  (Unit.isTrue     (mem m 1024))
                  , Unit.it "returns [42] for findAll 1024"  (Unit.isEq [42]  (findAll m 1024))
                  , Unit.it "returns 42 for find 1024"       (Unit.isEq 42    (find m 1024))
                  , Unit.it "contains 1025"                  (Unit.isTrue     (mem m 1025))
                  , Unit.it "returns ['a'] for findAll 1025" (Unit.isEq ["b"] (findAll m 1025))
                  , Unit.it "returns 'a' for find 1025"      (Unit.isEq "b"   (find m 1025))
                  , Unit.it "does not contains 2"            (Unit.isFalse    (mem m 2))
                  , Unit.it "returns [] for findAll 2"       (Unit.isEq []    (findAll m 2))
                ]
            end,
            let val m  = fromList [(0,"a"), (1,"b"), (32,"c")]
            in Unit.group "fromList [(0,'a'), (1,'b'), (32,'c')] (trie of depth 2)" [
                    Unit.it "is not null"                        (Unit.isFalse    (HashMap.null m))
                  , Unit.it "has size 3"                         (Unit.isEq 3     (HashMap.size m))
                  , Unit.it "contains 0"                         (Unit.isTrue     (mem m 0))
                  , Unit.it "returns [21] for findAll 0"         (Unit.isEq ["a"] (findAll m 0))
                  , Unit.it "returns 21 for find 0"              (Unit.isEq "a"   (find m 0))
                  , Unit.it "contains 1"                         (Unit.isTrue     (mem m 1))
                  , Unit.it "returns ['b'] for findAll 1"        (Unit.isEq ["b"] (findAll m 1))
                  , Unit.it "returns 'b' for find 1"             (Unit.isEq "b"   (find m 1))
                  , Unit.it "contains 32"                        (Unit.isTrue     (mem m 32))
                  , Unit.it "returns ['c'] for findAll 32"       (Unit.isEq ["c"] (findAll m 32))
                  , Unit.it "returns 'c' for find 32"            (Unit.isEq "c"   (find m 32))
                  , Unit.it "does not contains 2"                (Unit.isFalse    (mem m 2))
                  , Unit.it "returns [] for findAll 2"           (Unit.isEq []    (findAll m 2))
                ]
            end,
            (* -- Insert (fromList), delete, size, and findAll (mem and find) -- *)
            let val m  = remove (fromList [(0,42)]) 0
                val exp = fromList []
            in Unit.group "remove (fromList [(0,42)]) 0" [
                    Unit.it "is equivalent to fromList []" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21)]) 0
                val exp = fromList [(1,21)]
            in Unit.group "remove (fromList [(0,42), (1,21)]) 0" [
                    Unit.it "is equivalent to fromList [(1,21)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21)]) 1
                val exp = fromList [(0,42)]
            in Unit.group "remove (fromList [(0,42), (1,21)]) 1" [
                    Unit.it "is equivalent to fromList [(0,42)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21), (33,8)]) 0
                val exp = fromList [(1,21), (33,8)]
            in Unit.group "remove (fromList [(0,42), (1,21), (33,8)]) 0" [
                    Unit.it "is equivalent to fromList [(1,21), (33,8)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21), (33,8)]) 1
                val exp = fromList [(0,42), (33,8)]
            in Unit.group "remove (fromList [(0,42), (1,21), (33,8)]) 1" [
                    Unit.it "is equivalent to fromList [(0,42), (33,8)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (fromList [(0,42), (1,21), (33,8)]) 33
                val exp = fromList [(0,42), (1,21)]
            in Unit.group "remove (fromList [(0,42), (1,21), (33,8)]) 33" [
                    Unit.it "is equivalent to fromList [(0,42), (1,21)]" (Unit.isEq exp m)
                ]
            end,
            let val m   = remove (remove (fromList [(0,42), (1,21), (33,8)]) 33) 1
                val exp = fromList [(0,42)]
            in Unit.group "remove (remove (fromList [(0,42), (1,21), (33,8)]) 33) 1" [
                    Unit.it "is equivalent to fromList [(0,42)]" (Unit.isEq exp m)
                ]
            end,
            (* -- IFC-aware insertions -- *)
            let val bot       = `<; #root-integrity>`
                val alice     = `<alice; #root-integrity>`
                val bob       = `<bob; #root-integrity>`
                val alice_bob = `<alice & bob; #root-integrity>`
                val bob_charlie = `<bob & charlie; #root-integrity>`

                val m = fromList [ (0 raisedTo bob, 0)
                                 , (1,1)
                                 , (0 raisedTo alice, 2)
                                 ]
            in Unit.group "fromList [(0@{bob}, 0), (1@{}, 1), (0@{alice}, 2)]" [
                    Unit.it "is not null"           (Unit.isFalse    (HashMap.null m))
                  , Unit.it "has size 3"            (Unit.isEq (3 raisedTo alice_bob)
                                                               (HashMap.size m))
                  , Unit.it "finds all 0@{alice,bob}->[2,0]"
                            (Unit.isEq ([2,0] raisedTo alice_bob)
                                       (findAll m (0 raisedTo alice_bob)))
                  , Unit.it "finds all 0@{alice}->[2]"
                            (Unit.isEq ([2] raisedTo alice)
                                       (findAll m (0 raisedTo alice)))
                  , Unit.it "finds all 0@{bob}->[0]"
                            (Unit.isEq ([0] raisedTo bob)
                                       (findAll m (0 raisedTo bob)))
                  , Unit.it "finds all 0@{bob,charlie}->[0]"
                            (Unit.isEq ([0] raisedTo bob_charlie)
                                       (findAll m (0 raisedTo bob_charlie)))
                  , Unit.it "does not contain 0@{}" (Unit.isEq (false raisedTo bot)
                                                               (mem m (0 raisedTo bot)))
                  , Unit.it "contains 0@{alice}->?" (Unit.isEq (true raisedTo alice)
                                                               (mem m (0 raisedTo alice)))
                  , Unit.it "finds 0@{alice}->2"    (Unit.isEq (2 raisedTo alice)
                                                               (find m (0 raisedTo alice)))
                  , Unit.it "contains 0@{bob}->?"   (Unit.isEq (true raisedTo bob)
                                                               (mem m (0 raisedTo bob)))
                  , Unit.it "finds 0@{bob}->0"      (Unit.isEq (0 raisedTo bob)
                                                               (find m (0 raisedTo bob)))
                  , Unit.it "finds 0@{alice,bob}->2"
                            (Unit.isEq (2 raisedTo alice_bob)
                                       (find m (0 raisedTo alice_bob)))
                  , Unit.it "contains 1->?@{}"      (Unit.isEq (true raisedTo bot)
                                                               (mem m (1 raisedTo bot)))
                  , Unit.it "finds 1->1@{}"         (Unit.isEq (1 raisedTo bot)
                                                               (find m (1 raisedTo bot)))
                  , Unit.it "contains 1->?@{alice}" (Unit.isEq (true raisedTo alice)
                                                               (mem m (1 raisedTo alice)))
                  , Unit.it "finds 1->1@{alice}"    (Unit.isEq (1 raisedTo alice)
                                                               (find m (1 raisedTo alice)))
                ]
            end,
            (* -- keys, values, and toList -- *)
            (* NOTE: Failure in these tests may also be due to changes to the traversal order in
             *       'HashMap.fold'. *)
            Unit.group "keys, values, and toList" [
                let val m   = fromList []
                in Unit.it "converts []" [
                        (Unit.isEq [] (HashMap.keys m))
                      , (Unit.isEq [] (HashMap.values m))
                      , (Unit.isEq [] (HashMap.toList m))
                    ]
                end
              , let val m   = fromList [(0,"a")]
                in Unit.it "converts [(0,'a')]" [
                        (Unit.isEq [0] (HashMap.keys m))
                      , (Unit.isEq ["a"] (HashMap.values m))
                      , (Unit.isEq [(0,"a")] (HashMap.toList m))
                    ]
                end
              , let val m   = fromList [(0,"a"), (1,"b")]
                in Unit.it "converts [(0,'a'), (1,'b')]" [
                        (Unit.isEq [1, 0] (HashMap.keys m))
                      , (Unit.isEq ["b", "a"] (HashMap.values m))
                      , (Unit.isEq [(1, "b"), (0,"a")] (HashMap.toList m))
                    ]
                end
              , let val m   = fromList [(0,"a"), (1,"b"), (32,"c")]
                in Unit.it "converts [(0,'a'), (1, 'b'), (32, 'c')]" [
                        (Unit.isEq [1, 32, 0] (HashMap.keys m))
                      , (Unit.isEq ["b", "c", "a"] (HashMap.values m))
                      , (Unit.isEq [(1, "b"), (32, "c"), (0,"a")] (HashMap.toList m))
                    ]
                end
            ]
        ]
in Unit.run authority tests end
