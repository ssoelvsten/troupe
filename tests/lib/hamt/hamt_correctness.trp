(* HAMT Correctness Tests *)

import lists
import hamt  (* Import hamt after lists so its lookup takes precedence *)

(* Option type must match the one in HAMT library *)
datatype Atoms = NONE | SOME

let
  (* Test utilities *)
  fun assert cond msg = 
    if cond then () 
    else let val _ = print ("FAIL: " ^ msg) in exit (authority, 1) end
    
  fun assertEq actual expected msg =
    assert (actual = expected) (msg ^ " - Expected: " ^ toString expected ^ ", Got: " ^ toString actual)
    
  fun assertLookup trie key expected msg =
    case lookup trie key of
      (SOME, v) => assertEq v expected msg
    | _ => assert false (msg ^ " - Key not found: " ^ toString key)
    
  fun assertNotFound trie key msg =
    case lookup trie key of
      NONE => ()
    | _ => assert false (msg ^ " - Key should not be found: " ^ toString key)
    
  (* Test 1: Empty trie operations *)
  val _ = print "Test 1: Empty trie operations"
  val emptyTrie = empty ()
  val _ = assertNotFound emptyTrie "key" "Empty trie should not contain any keys"
  val _ = assert (size emptyTrie = 0) "Empty trie should have size 0"
  val _ = assert (keys emptyTrie = []) "Empty trie should have no keys"
  val _ = assert ((contains emptyTrie "any") = false) "Empty trie should not contain any key"
  
  (* Test 2: Single insertion and lookup *)
  val _ = print "Test 2: Single insertion and lookup"
  val t1 = insert emptyTrie "hello" "world"
  val _ = assertLookup t1 "hello" "world" "Should find inserted key"
  val _ = assertNotFound t1 "goodbye" "Should not find non-existent key"
  val _ = assert (size t1 = 1) "Size should be 1 after single insertion"
  val _ = assert (contains t1 "hello") "Should contain inserted key"
  
  (* Test 3: Multiple insertions *)
  val _ = print "Test 3: Multiple insertions"
  val t2 = insert t1 "foo" "bar"
  val t3 = insert t2 "baz" "qux"
  val _ = assertLookup t3 "hello" "world" "First key should still exist"
  val _ = assertLookup t3 "foo" "bar" "Second key should exist"
  val _ = assertLookup t3 "baz" "qux" "Third key should exist"
  val _ = assert (size t3 = 3) "Size should be 3"
  
  (* Test 4: Update existing key *)
  val _ = print "Test 4: Update existing key"
  val t4 = insert t3 "hello" "updated"
  val _ = assertLookup t4 "hello" "updated" "Value should be updated"
  val _ = assertLookup t4 "foo" "bar" "Other keys should remain unchanged"
  val _ = assert (size t4 = 3) "Size should remain 3 after update"
  
  (* Test 5: Integer keys *)
  val _ = print "Test 5: Integer keys"
  val t5 = insert emptyTrie 42 "answer"
  val t6 = insert t5 100 "century"
  val t7 = insert t6 0 "zero"
  val t8 = insert t7 (0 - 1) "negative"
  val _ = assertLookup t8 42 "answer" "Integer key 42"
  val _ = assertLookup t8 100 "century" "Integer key 100"
  val _ = assertLookup t8 0 "zero" "Integer key 0"
  val _ = assertLookup t8 (0 - 1) "negative" "Negative integer key"
  
  (* Test 6: Removal operations *)
  val _ = print "Test 6: Removal operations"
  val t9 = remove t4 "foo"
  val _ = assertNotFound t9 "foo" "Removed key should not be found"
  val _ = assertLookup t9 "hello" "updated" "Other keys should remain"
  val _ = assertLookup t9 "baz" "qux" "Other keys should remain"
  val _ = assert (size t9 = 2) "Size should be 2 after removal"
  
  (* Test 7: Remove non-existent key *)
  val _ = print "Test 7: Remove non-existent key"
  val t10 = remove t9 "nonexistent"
  val _ = assertLookup t10 "hello" "updated" "Trie should be unchanged"
  val _ = assert (size t10 = 2) "Size should remain unchanged"
  
  (* Test 8: Remove all keys *)
  val _ = print "Test 8: Remove all keys"
  val t11 = remove (remove t10 "hello") "baz"
  val _ = assert (size t11 = 0) "Size should be 0 after removing all"
  val _ = assert (keys t11 = []) "Should have no keys"
  
  (* Test 9: fromList and toList *)
  val _ = print "Test 9: fromList and toList"
  val pairs = [("a", 1), ("b", 2), ("c", 3), ("d", 4)]
  val t12 = fromList pairs
  val _ = assert (size t12 = 4) "Size should match input list"
  val _ = assertLookup t12 "a" 1 "First pair"
  val _ = assertLookup t12 "d" 4 "Last pair"
  val extracted = toList t12
  val _ = assert (length extracted = 4) "Extracted list should have same length"
  
  (* Test 10: Large dataset *)
  val _ = print "Test 10: Large dataset"
  fun insertMany trie n =
    if n = 0 then trie
    else insertMany (insert trie ("key" ^ intToString n) n) (n - 1)
  val large = insertMany emptyTrie 1000
  val _ = assert (size large = 1000) "Large trie should have 1000 entries"
  val _ = assertLookup large "key500" 500 "Should find key in large dataset"
  val _ = assertLookup large "key1" 1 "Should find key in large dataset"
  val _ = assertLookup large "key1000" 1000 "Should find key in large dataset"
  
  (* Test 11: Collision handling *)
  val _ = print "Test 11: Collision handling"
  (* These keys are designed to potentially collide *)
  val coll = fromList [("a", 1), ("aa", 2), ("aaa", 3), ("aaaa", 4)]
  val _ = assertLookup coll "a" 1 "First collision key"
  val _ = assertLookup coll "aa" 2 "Second collision key"
  val _ = assertLookup coll "aaaa" 4 "Fourth collision key"
  val _ = assert (size coll = 4) "All collision keys should be stored"
  
  (* Test 12: Mixed operations *)
  val _ = print "Test 12: Mixed operations"
  val mix1 = insert emptyTrie "first" 1
  val mix2 = insert mix1 "second" 2
  val mix3 = remove mix2 "first"
  val mix4 = insert mix3 "third" 3
  val mix5 = insert mix4 "first" 10
  val _ = assertLookup mix5 "first" 10 "Re-inserted key"
  val _ = assertLookup mix5 "second" 2 "Untouched key"
  val _ = assertLookup mix5 "third" 3 "Added key"
  val _ = assert (size mix5 = 3) "Final size should be 3"
  
  (* Test 13: Persistence verification *)
  val _ = print "Test 13: Persistence verification"
  val orig = fromList [("x", 1), ("y", 2)]
  val modified = insert orig "z" 3
  val _ = assertLookup orig "x" 1 "Original unchanged"
  val _ = assertNotFound orig "z" "Original should not have new key"
  val _ = assertLookup modified "z" 3 "Modified has new key"
  val _ = assert (size orig = 2) "Original size unchanged"
  val _ = assert (size modified = 3) "Modified size increased"
  
  (* Test 14: keys and values functions *)
  val _ = print "Test 14: keys and values functions"
  val t14 = fromList [("one", 1), ("two", 2), ("three", 3)]
  val keys = keys t14
  val values = values t14
  val _ = assert (length keys = 3) "Should have 3 keys"
  val _ = assert (length values = 3) "Should have 3 values"
  val _ = assert (elem "one" keys) "Should contain key 'one'"
  val _ = assert (elem 2 values) "Should contain value 2"
  
  (* Test 15: Special characters and edge cases *)
  val _ = print "Test 15: Special characters and edge cases"
  val special = empty ()
  val s1 = insert special "" "empty string key"
  val s2 = insert s1 " " "space key"
  val s3 = insert s2 "!@#$%^&*()" "symbols"
  val s4 = insert s3 "very long key with many words and characters" "long"
  val _ = assertLookup s4 "" "empty string key" "Empty string key"
  val _ = assertLookup s4 " " "space key" "Space key"
  val _ = assertLookup s4 "!@#$%^&*()" "symbols" "Symbol key"
  val _ = assert (size s4 = 4) "All special keys stored"
  
in
  print "\nAll correctness tests passed!"
end