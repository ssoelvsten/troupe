(* Test integer hashing *)

import hamt

datatype Atoms = NONE | SOME

let
  val _ = print "Testing integer keys..."
  
  (* Test hash values *)
  val h42 = hash 42
  val h100 = hash 100
  val h0 = hash 0
  val hNeg = hash (0 - 1)
  
  val _ = print ("hash(42) = " ^ intToString h42)
  val _ = print ("hash(100) = " ^ intToString h100)
  val _ = print ("hash(0) = " ^ intToString h0)
  val _ = print ("hash(-1) = " ^ intToString hNeg)
  
  (* Test a single integer insertion *)
  val e = empty ()
  val _ = print "\nInserting 42..."
  val t1 = insert e 42 "answer"
  val _ = print ("After insert: " ^ toString t1)
  
  val _ = print "\nLooking up 42..."
  val r = lookup t1 42
  val _ = case r of
            (SOME, v) => print ("Found: " ^ v)
          | NONE => print "Not found"
          
in
  print "\nDone"
end