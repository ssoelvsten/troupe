(* Test multiple integer keys *)

import hamt

datatype Atoms = NONE | SOME

let
  val _ = print "Testing multiple integer keys..."
  
  val e = empty ()
  val _ = print "Inserting 42..."
  val t1 = insert e 42 "answer"
  
  val _ = print "Inserting 100..."
  val t2 = insert t1 100 "century"
  
  val _ = print "Inserting 0..."
  val t3 = insert t2 0 "zero"
  
  val _ = print "Structure after 3 inserts:"
  val _ = print (toString t3)
  
  val _ = print "\nInserting -1..."
  val t4 = insert t3 (0 - 1) "negative"
  
  val _ = print "Done with inserts"
  
in
  print "\nTest complete"
end