import Unit
import ListPair

let val tests = group "ListPair" [
            group "zip" [
                it "merges [] []"        (isEq []            (zip [] []))
              , it "merges [42] ['a']"   (isEq [(42,"a")]    (zip [42] ["a"]))
              , it "merges ['a'] [42]"   (isEq [("a",42)]    (zip ["a"] [42]))
              , it "merges [0,1] [2,3]"  (isEq [(0,2),(1,3)] (zip [0,1] [2,3]))
              , it "drops [] [42]"       (isEq []            (zip [] [42]))
              , it "drops [] [42]"       (isEq []            (zip [42] []))
              , it "drops [0,1,2] [3,4]" (isEq [(0,3),(1,4)] (zip [0,1,2] [3,4]))
              , it "drops [0,1] [2,3,4]" (isEq [(0,2),(1,3)] (zip [0,1] [2,3,4]))
            ],
            group "unzip" [
                it "splits []"             (isEq ([],[])        (unzip []))
              , it "splits [(42,'a')]"     (isEq ([42], ["a"])  (unzip [(42,"a")]))
              , it "splits [(0,1), (2,3)]" (isEq ([0,2], [1,3]) (unzip [(0,1), (2,3)]))
            ],
            group "null" [
                it "accepts []"             (isTrue  (null []))
              , it "rejects [(42,'a')]"     (isFalse (null [(42,"a")]))
              , it "rejects [(0,1), (2,3)]" (isFalse (null [(0,1), (2,3)]))
            ],
            group "length" [
                it "is 0 for []"             (isEq 0 (length []))
              , it "is 1 for [(42,'a')]"     (isEq 1 (length [(42,"a")]))
              , it "is 2 for [(0,1), (2,3)]" (isEq 2 (length [(0,1), (2,3)]))
            ],
            group "reverse" [
                it "reverses []"             (isEq []             (reverse []))
              , it "reverses [(0,1), (2,3)]" (isEq [(2,3), (0,1)] (reverse [(0,1), (2,3)]))
            ],
            group "append" [
                it "appends [] []"             (isEq []             (append [] []))
              , it "appends [] [(0,1), (2,3)]" (isEq [(0,1), (2,3)] (append [] [(0,1), (2,3)]))
              , it "appends [(0,1), (2,3)] []" (isEq [(0,1), (2,3)] (append [(0,1), (2,3)] []))
            ],
            group "revAppend" [
                it "appends [] []"             (isEq []             (revAppend [] []))
              , it "appends [] [(0,1), (2,3)]" (isEq [(0,1), (2,3)] (revAppend [] [(0,1), (2,3)]))
              , it "appends [(0,1), (2,3)] []" (isEq [(2,3), (0,1)] (revAppend [(0,1), (2,3)] []))
            ],
            group "findOpt" [
                it "returns NONE for [] 42"           (isEq [] (findOpt [] 42))
              , it "returns NONE for [(0,42)] 42"     (isEq [] (findOpt [(0,42)] 42))
              , it "returns (SOME 42) for [(0,42)] 0" (isEq [42] (findOpt [(0,42)] 0))
              , it "returns (SOME 42) for [(1,'a'), (0,42), (2,3), (0,'no')] 0"
                        (isEq [42] (findOpt [(1,"a"), (0,42), (2,3), (0,"no")] 0))
            ],
            group "find" [
                it "returns 42 for [(0,42)] 0" (isEq 42 (find [(0,42)] 0))
              , it "returns 42 for [(1,'a'), (0,42), (2,3), (0,'no')] 0"
                        (isEq 42 (find [(1,"a"), (0,42), (2,3), (0,"no")] 0))
            ],
            group "mem" [
                it "rejects [] for 42"       (isFalse (mem [] 42))
              , it "rejects [(0,42)] for 42" (isFalse (mem [(0,42)] 42))
              , it "accepts [(0,42)] for 0"  (isTrue  (mem [(0,42)] 0))
              , it "accepts [(1,'a'), (0,42), (2,3), (0,'no')] for 0"
                        (isTrue (mem [(1,"a"), (0,42), (2,3), (0,"no")] 0))
            ],
            let fun f (x,y) = (x,y+1)
            in group "map" [
                    it "maps [] []"           (isEq [] (map f [] []))
                  , it "maps ['answer'] [41]" (isEq [("answer", 42)] (map f ["answer"] [41]))
                  , it "maps [0,1] [2,8]"     (isEq [(0,3),(1,9)] (map f [0,1] [2,8]))
                  , it "maps [0,1,3] [2,8]"   (isEq [(0,3),(1,9)] (map f [0,1,3] [2,8]))
                  , it "maps [0,1] [2,8,3]"   (isEq [(0,3),(1,9)] (map f [0,1] [2,8,3]))
                ]
            end,
            let fun f ((x,y),acc) = acc*x*y
            in group "foldl" [
                    it "folds (*) 1 [] []"       (isEq 1   (foldl f 1 [] []))
                  , it "folds (*) 1 [] [2]"      (isEq 1   (foldl f 1 [] [2]))
                  , it "folds (*) 1 [2] []"      (isEq 1   (foldl f 1 [2] []))
                  , it "folds (*) 1 [2] [3]"     (isEq 6   (foldl f 1 [2] [3]))
                  , it "folds (*) 0 [2] [3]"     (isEq 0   (foldl f 0 [2] [3]))
                  , it "folds (*) 1 [2,3] [5,7]" (isEq 210 (foldl f 1 [2,3] [5,7]))
                ]
            end
        ]
in run authority tests end
