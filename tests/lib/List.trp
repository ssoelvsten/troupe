import Unit
import List

let val tests = Unit.group "List" [
            Unit.group "reverse" [
                Unit.it "inverts []"      (Unit.isEq [] (List.reverse []))
              , Unit.it "inverts [0]"     (Unit.isEq [0] (List.reverse [0]))
              , Unit.it "inverts [1]"     (Unit.isEq [1] (List.reverse [1]))
              , Unit.it "inverts [1,0]"   (Unit.isEq [0,1] (List.reverse [1,0]))
              , Unit.it "inverts [0,1]"   (Unit.isEq [1,0] (List.reverse [0,1]))
              , Unit.it "inverts [0,2,1]" (Unit.isEq [1,2,0] (List.reverse [0,2,1]))
            ],
            Unit.group "append" [
                Unit.it "appends [] []"       (Unit.isEq []        (List.append [] []))
              , Unit.it "appends [42] []"     (Unit.isEq [42]      (List.append [42] []))
              , Unit.it "appends [21] [42]"   (Unit.isEq [21,42]   (List.append [21] [42]))
              , Unit.it "appends [42] [21]"   (Unit.isEq [42,21]   (List.append [42] [21]))
              , Unit.it "appends [0,1] [2]"   (Unit.isEq [0,1,2]   (List.append [0,1] [2]))
              , Unit.it "appends [1,2] [0,3]" (Unit.isEq [1,2,0,3] (List.append [1,2] [0,3]))
            ],
            Unit.group "revAppend" [
                Unit.it "appends [] []"       (Unit.isEq []        (List.revAppend [] []))
              , Unit.it "appends [42] []"     (Unit.isEq [42]      (List.revAppend [42] []))
              , Unit.it "appends [21] [42]"   (Unit.isEq [21,42]   (List.revAppend [21] [42]))
              , Unit.it "appends [42] [21]"   (Unit.isEq [42,21]   (List.revAppend [42] [21]))
              , Unit.it "appends [0,1] [2]"   (Unit.isEq [1,0,2]   (List.revAppend [0,1] [2]))
              , Unit.it "appends [1,2] [0,3]" (Unit.isEq [2,1,0,3] (List.revAppend [1,2] [0,3]))
            ],
            let fun cmp x y = x < y
                val sort = List.sort cmp
            in Unit.group "sort" [
                    Unit.it "sorts []"                  (Unit.isEq []                  (sort []))
                  , Unit.it "sorts [0]"                 (Unit.isEq [0]                 (sort [0]))
                  , Unit.it "sorts [0,1]"               (Unit.isEq [0,1]               (sort [0,1]))
                  , Unit.it "sorts [1,0]"               (Unit.isEq [0,1]               (sort [1,0]))
                  , Unit.it "sorts [0,0]"               (Unit.isEq [0,0]               (sort [0,0]))
                  , Unit.it "sorts [1,0,0]"             (Unit.isEq [0,0,1]             (sort [1,0,0]))
                  , Unit.it "sorts [1,0,2]"             (Unit.isEq [0,1,2]             (sort [1,0,2]))
                  , Unit.it "sorts [1,3,0,2]"           (Unit.isEq [0,1,2,3]           (sort [1,3,0,2]))
                  , Unit.it "sorts [3,0,2,1,2]"         (Unit.isEq [0,1,2,2,3]         (sort [3,0,2,1,2]))
                  , Unit.it "sorts [3,4,0,2,5,1,6,3,2]" (Unit.isEq [0,1,2,2,3,3,4,5,6] (sort [3,4,0,2,5,1,6,3,2]))
                ]
            end
        ]
in Unit.run authority tests end
