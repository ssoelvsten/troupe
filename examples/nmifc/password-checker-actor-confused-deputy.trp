(* Password Checker: Actor-Based NMIFC Demonstration
   ================================================
   Based on Cecchetti et al. "Nonmalleable Information Flow Control"
   (Section 2.1)

   Works without nmifc (--no-nmifc) but is actually stopped by running
   with --nmifc flag

   ======================
   Author: Aslan Askarov
   ======================

   Confused deputy version: 2025-12-30

   This version presents a slightly more realistic iteration, where the
   server is a confused deputy.

*)


datatype Atoms 
    = AuthRequest | AuthResponse | Timeout | Shutdown |  ConfusedDeputy
    | Loop | Stop 

let
    val stdout = getStdout authority 
    fun out x = fwrite (stdout, x); fwrite (stdout, "\n")
    val server_password = "correct_horse_battery_staple" raisedTo `{server}`

    fun endorse_aux ( v, authority, l) =
        let val v' = endorse ( v, authority, l)
        in case v' of
             (x,y) => let val x' = endorse (x, authority, l)
                          val y' = endorse (y, authority, l)
                       in (x', y')
                       end
           |  _ => v'
        end


    fun auth_request_worker () =
        (* demultixplexed auth processor running in its own thread *)

         let val _ = _setProcessDebuggingName "server_auth"
             (* raise mbox clearance to receive untrusted *)
             val c = raisembox (`<; #null-integrity>`)
             val received_value = 
                rcv ( `<; server>`             
                    , `<; #null-integrity>`    (* NULL *)
                    , [ hn (AuthRequest, x) => (Loop, x)
                      , hn Shutdown => Stop ] )
                                
             val _ = lowermbox (c, authority)             
             val _ = blockdown authority (* observe: new blockdown primitive
                                            (new as of 2025-12-xx) that downgrades 
                                            _both_ integrity and confidentiality
                                          *)
             val received_value_2 = endorse_aux (received_value, authority, `<; server>`)
             (* val _ = printWithLabels received_value_2 *)
          in case received_value_2 of 
                Stop => ()
              | (Loop, (guess, reply_to)) => 
                  let 
                    (* val _ = debugpc () *)
                    (* the pattern of processing this request in a separate worker allows and subsequent downgrades 
                    allows us to systematically bring down the PC/BL to {} *)
                        
                    (* Endorse the incoming guess to the trust level of the server*)
                    (* ************************************)
                    (*                                    *)
                    (* OBS : this is a violation of NMIFC *)
                    (*                                    *)
                    (* ************************************)                    
                    val endorsed_guess = endorse (guess, authority, `<server;server>`)
                    val result = (endorsed_guess = server_password)

                    (* Declassify confidentiality but keep server integrity *)

                    val public_result = 
                        declassify ( result
                                    , authority
                                    , `<#null-confidentiality; server>`)                    
                in 
                    out (if public_result 
                            then "Server: Authentication successful"
                            else "Server: Authentication failed")
                        ; send (reply_to, (AuthResponse, public_result))

                   ; auth_request_worker ()
                end
         end

    fun server_loop auth_pid i =
            out ("Server running, iteration: " ^ intToString (i));
            rcv ( `{}`
                , `<; #null-integrity>`
                ,  [ hn (AuthRequest, guess, reply_to) =>
                          send (auth_pid, (AuthRequest, (guess, reply_to)))       (* demultiplexing / forward to a dedicated process *)
                        ; server_loop auth_pid (i+1)
                   , hn (ConfusedDeputy, f) => 
                          spawn (fn () => f server_password )
                        ; server_loop auth_pid (i+1)
                   , hn Shutdown => 
                            send (auth_pid, Shutdown)
                          ; out "Server: Shutting down"
                   ] )


     fun server () = 
        _setProcessDebuggingName "server" ; 
        (* debugpc (); *)

        let            
            val auth_pid = spawn auth_request_worker (* spawn the worker *)
            val c = raisembox (`<; #null-integrity>`) (* all public messages *)
            val _ = server_loop auth_pid 0  (* main server loop *)
        in lowermbox (c, authority)
        end 

        

    (* ============================================================
       ATTACKER REMOTE EXPOLIT ACTOR
       ============================================================ *)
    fun attacker_remote_exploit attacker_pid server_pid leaked_password =
        let val _ = _setProcessDebuggingName "attacker_remote_exploit"
            val _ = out "Attacker remote exploit: Sending auth request with leaked guess..."
        in  send (server_pid, (AuthRequest, leaked_password, attacker_pid)) 
        end 
    
    (* ============================================================
       ATTACKER ACTOR
       ============================================================ *)

    fun attacker server_pid = 
        let val _ = _setProcessDebuggingName "attacker"
            val attacker_pid = self () 
            (****************************************)
            (* Sending remote exploit to the server *)
            (****************************************)
            val _ = send ( server_pid
                         , (ConfusedDeputy 
                               , attacker_remote_exploit attacker_pid server_pid))
            val _ = spawn (fn () => sleep 1000; send (attacker_pid, Timeout))
            val _ = out "Attacker: Waiting for response..."
            val c = raisembox ( `< ; #null-integrity>` )
        in
            rcv ( `<; attacker>` 
                , `<; #null-integrity>` , [
                hn (AuthResponse, success) =>
                    if success then
                          out "ATTACK SUCCEEDED: Authenticated with stolen password!"                        
                    else
                          out "Attack failed: Wrong password (unexpected)" 
              , hn Timeout =>
                          out "Attack failed: timeout" 
             ])
            ; lowermbox  (c, authority) 
            ; adv ()
        end

            

    (* ============================================================
       MAIN: Start server and run the attack demonstration
       ============================================================ *)
    (* val _ = exitAfterTimeout authority 2000 15 "timeout"  *)
    val _ = out "=== Actor-Based Password Checker NMIFC Demo ==="
    val _ = out ""
    
    val server_pid = spawn server    
    val _ = spawn ( fn () => sleep 2000  
                           ; send (server_pid, Shutdown ))

    val _ = out "Main: Server started"
    val _ = out "Main: Spawning attacker..."
    val _ = out ""

    (* Spawn attacker who will try to authenticate with stolen password *)
    fun corrupt f = 
            if true raisedTo `<;attacker>` then f else (fn _ => ())

    val attacker_pid = spawn (corrupt (fn () => attacker server_pid))
    
in
    ()
end
