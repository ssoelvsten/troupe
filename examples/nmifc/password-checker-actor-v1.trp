(* Password Checker: Actor-Based NMIFC Demonstration
   ================================================
   Based on Cecchetti et al. "Nonmalleable Information Flow Control" (Section 2.1)

   Works without nmifc (--no-nmifc) but is actually stopped by running with --nmifc flag

   ===========

   First iteration, 2025-12-30; AA 

*)

import {exitAfterTimeout} timeout

datatype Atoms = AuthRequest | AuthResponse | Timeout | Shutdown



let
    val stdout = stdout authority 
    fun out x = fwrite (stdout, x); fwrite (stdout, "\n")

    val server_password = "correct_horse_battery_staple" raisedTo `{server}`

    
    fun auth_request_worker () = 
        (* AA; 2025-12-29; we should probably find a name (if it exists in literature already)
           or coin it for this pattern of _demultiplexing_ inputs into channels 
        *)


        (* demultixplexed auth processor running in its own thread *)

        (* note to self: could there be an FP pearl in this? *)

         let val _ = _setProcessDebuggingName "server_auth" 
             val c = raisembox (`<; #null-integrity>`)  (* receive at all levels 
                                                         , assuming this is internal process *)
             val (guess, reply_to) = 
                rcv ( `{}`                     (* ⊥ *)
                    , `<; #null-integrity>`    (* NULL *)
                    , [hn x => x] ) (* id handler, the idea is to get out of the "receive's PC taint" asap *)
                                
             val _ = lowermbox (c, authority)
             
             val _ = blockdown authority (* observe: new blockdown 
                                            (new as of 2025-12-xx) that downgrades 
                                            _both_ integrity and confidentiality 
                                          *)
             (* the pattern of processing this request in a separate worker allows and subsequent downgrades 
               allows us to systematically bring down the PC/BL to {} *)

             (* val _ = debugpc ()   *)
             (* val _ = printWithLabels guess   *)
             (* val _ = printWithLabels reply_to *)
                
             (* endorse the incoming guess to the trust level of the server*)
             val endorsed_guess = endorse (guess, authority, `<server;server>`)
             (* val _ = printWithLabels endorsed_guess *)

             val result = (endorsed_guess = server_password)
             (* Declassify confidentiality but keep server integrity *)

             val public_result = 
                  declassify ( result
                             , authority
                             , `<#null-confidentiality; server>`)
             (* val _ = printWithLabels public_result *)
             (* val _ = debugpc () *)
         in 
            out (if public_result 
                    then "Server: Authentication successful"
                    else "Server: Authentication failed")
                (* ; debugpc () *)
                (* ; printWithLabels reply_to *)
                ; send (reply_to, (AuthResponse, public_result))
         end


    fun server_loop auth_pid i =
            out ("Server running, iteration: " ^ intToString (i));
            rcv ( `{}`
                , `<; #null-integrity>`
                ,  [ hn (AuthRequest, guess, reply_to) =>
                          send (auth_pid, (guess, reply_to))       (* demultiplexing / forward to a dedicated process *)
                        ; server_loop auth_pid (i+1)
                   , hn Shutdown => out "Server: Shutting down"
                   ] )


     fun server () = 
        _setProcessDebuggingName "server" ; 
        (* debugpc (); *)

        let            
            val auth_pid = spawn auth_request_worker (* spawn the worker *)
            val c = raisembox (`<; #null-integrity>`) (* all public messages *)
            val _ = server_loop auth_pid 0  (* main server loop *)
        in lowermbox (c, authority)
        end 

        

    (* ============================================================
       ATTACKER ACTOR

       The attacker has previously stolen the password value
       (through a data breach, log file leak, insider threat, etc.)

       They create a corrupt-labeled value with:
       - The correct password string
       - Label <server; attacker> (secret but attacker-integrity)

       Then they send it as their "guess" hoping to authenticate.
       ============================================================ *)
    fun attacker server_pid =
        let
            val _ = _setProcessDebuggingName "attacker" 
            val _ = out "Attacker: I have the password from a previous breach..."

            (* The attacker knows the password value from a previous breach.
               They create a corrupt label: secret to server, but attacker integrity.
               This models the attacker having obtained secret data illicitly. *)

            val leaked_password = "correct_horse_battery_staple" raisedTo `<server;attacker>`
            (* val _ = debugpc () *)
            val attack_guess = leaked_password 
            val _ = out "Attacker: Sending auth request with corrupt guess..."
            val attacker_pid = self()
            (* val _ = out "Attacker pid" *)
            (* val _ = print attacker_pid *)
            val _ = send (server_pid, (AuthRequest, attack_guess, attacker_pid))
            val _ = out "Attacker: Waiting for response..."
            (* val c = raisembox (`<; #null-integrity>`) *)
            val _ = sleep (10) (* prompt a context switch and message delivery *)
            (* val _ = debugMbox () *)
        in
            rcvp (`<#null-confidentiality; #null-integrity>` , [
                hn (AuthResponse, success) =>
                    if success then
                          out "ATTACK SUCCEEDED: Authenticated with stolen password!"                        
                    else
                          out "Attack failed: Wrong password (unexpected)"                    
             ]); adv ()

        end

    (* ============================================================
       MAIN: Start server and run the attack demonstration
       ============================================================ *)
    val _ = exitAfterTimeout authority 2000 15 "timeout" 
    val _ = out "=== Actor-Based Password Checker NMIFC Demo ==="
    val _ = out ""

    
    val server_pid = spawn server

    val _ = out "Main: Server started"
    val _ = out "Main: Spawning attacker..."
    val _ = out ""

    (* Spawn attacker who will try to authenticate with stolen password *)
    fun corrupt f = 
            if true raisedTo `<;attacker>` then f else (fn _ => ())

    val attacker_pid = spawn (corrupt (fn () => attacker server_pid))
    
in
    ()
end
