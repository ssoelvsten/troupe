{
    "compilerOptions": {
        "outDir": "./built",
        "allowJs": true,
        "moduleResolution": "node16",
        "module": "Node16",
        "target": "ES2022",
        "esModuleInterop": true,
        "skipLibCheck": true,                                /* Skip type checking all .d.ts files. */
        "incremental": true,
        "lib": ["ESNext"],
    },
    "include": [
        "src/**/*"
    ],
    "exclude": ["../../trp-rt/**", "src/dev/*"]
}
